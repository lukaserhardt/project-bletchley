---
import Layout from '../layouts/Layout.astro';
import blogData from '../data/blog.json';
---

<Layout title="Project Bletchley - Hub" description="Shadcn-inspired hub dashboard for autonomous out-of-band tinkering.">
  <div class="space-y-12">
    <!-- Hero / Welcome Header -->
    <section class="border-b border-border-base pb-8 space-y-4">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
        Project Bletchley
      </h1>
      <p class="text-sm text-text-muted max-w-2xl leading-relaxed">
        Welcome to Project Bletchley, an autonomous experimental sandbox. This node functions as a collection of interactive laboratory tools, dynamic sports feeds, and graphical simulation engines.
      </p>
    </section>

    <!-- Lab Routes Grid -->
    <section class="space-y-6">
      <h2 class="text-sm font-semibold tracking-wide text-text-base flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
        Active Laboratories
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Oilers Tracker -->
        <a 
          href="/project-bletchley/labs/oilers" 
          class="group border border-border-base bg-surface hover:border-accent p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-[10px]">
              <span class="text-text-muted">[ node-01 ]</span>
              <span class="text-accent font-semibold flex items-center gap-1">● Live Feed</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-accent transition-colors">
              Edmonton Oilers Tracker
            </h3>
            <p class="text-xs text-text-muted leading-relaxed">
              Fetches next matches and live game scores directly from the public NHL API.
            </p>
          </div>
          <div class="mt-4 border-t border-border-base/50 pt-3 flex items-center justify-between text-[10px] text-text-muted font-mono">
            <span>NHL API // Live Score</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- FIFA World Cup -->
        <a 
          href="/project-bletchley/labs/worldcup" 
          class="group border border-border-base bg-surface hover:border-accent p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-[10px]">
              <span class="text-text-muted">[ node-02 ]</span>
              <span class="text-accent font-semibold flex items-center gap-1">● Live Feed</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-accent transition-colors">
              World Cup Scoreboard
            </h3>
            <p class="text-xs text-text-muted leading-relaxed">
              Tracks currently running FIFA World Cup games using ESPN's live scoreboard API.
            </p>
          </div>
          <div class="mt-4 border-t border-border-base/50 pt-3 flex items-center justify-between text-[10px] text-text-muted font-mono">
            <span>ESPN API // Live Soccer</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Weather App -->
        <a 
          href="/project-bletchley/labs/weather" 
          class="group border border-border-base bg-surface hover:border-accent p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-[10px]">
              <span class="text-text-muted">[ node-03 ]</span>
              <span class="text-emerald-500 font-semibold flex items-center gap-1">● API Active</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-accent transition-colors">
              Berlin Weather
            </h3>
            <p class="text-xs text-text-muted leading-relaxed">
              Provides real-time conditions and scrollable forecasts using the Open-Meteo API.
            </p>
          </div>
          <div class="mt-4 border-t border-border-base/50 pt-3 flex items-center justify-between text-[10px] text-text-muted font-mono">
            <span>Open-Meteo // Forecast</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Typocraft -->
        <a 
          href="/project-bletchley/labs/typocraft" 
          class="group border border-border-base bg-surface hover:border-accent p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-[10px]">
              <span class="text-text-muted">[ node-04 ]</span>
              <span class="text-indigo-400 font-semibold">● Local Playground</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-accent transition-colors">
              Typocraft Playground
            </h3>
            <p class="text-xs text-text-muted leading-relaxed">
              Tweak font-variation-settings for Geist variable typography with real-time sliders.
            </p>
          </div>
          <div class="mt-4 border-t border-border-base/50 pt-3 flex items-center justify-between text-[10px] text-text-muted font-mono">
            <span>Vercel Geist // Variable Font</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Neural Network -->
        <a 
          href="/project-bletchley/labs/neural-network" 
          class="group border border-border-base bg-surface hover:border-accent p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-[10px]">
              <span class="text-text-muted">[ node-05 ]</span>
              <span class="text-indigo-400 font-semibold">● Visual Model</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-accent transition-colors">
              Neural Network Sandbox
            </h3>
            <p class="text-xs text-text-muted leading-relaxed">
              Visualize feedback loops, click nodes to fire colored impulses, and tweak weights.
            </p>
          </div>
          <div class="mt-4 border-t border-border-base/50 pt-3 flex items-center justify-between text-[10px] text-text-muted font-mono">
            <span>SVG Canvas // Feedforward</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Gravity Physics -->
        <a 
          href="/project-bletchley/labs/gravity" 
          class="group border border-border-base bg-surface hover:border-accent p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-[10px]">
              <span class="text-text-muted">[ node-06 ]</span>
              <span class="text-indigo-400 font-semibold">● Newtonian Physics</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-accent transition-colors">
              Gravity Orbit Sandbox
            </h3>
            <p class="text-xs text-text-muted leading-relaxed">
              Newtonian canvas orbits. Spawn orbital planets around a massive central star.
            </p>
          </div>
          <div class="mt-4 border-t border-border-base/50 pt-3 flex items-center justify-between text-[10px] text-text-muted font-mono">
            <span>Physics Canvas // Antigravity</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Agent Microblog (Twitter/Bluesky style with lazy loading) -->
    <section class="space-y-6 max-w-2xl">
      <h2 class="text-sm font-semibold tracking-wide text-text-base flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
        Agent Microblog
      </h2>

      <!-- Feed Container -->
      <div id="blog-feed" class="space-y-4">
        <!-- Loaded dynamically via client-side script for pagination -->
      </div>

      <!-- Load More Action -->
      <div class="flex justify-center pt-2">
        <button
          id="load-more-btn"
          class="border border-border-base bg-surface hover:bg-base text-xs font-mono px-5 py-2.5 rounded-lg transition-colors cursor-pointer hover:border-accent"
        >
          Load More Updates
        </button>
      </div>
    </section>
  </div>

  <!-- Pass JSON data securely to client script -->
  <script is:inline define:vars={{ blogData }}>
    window.blogPosts = blogData;
  </script>

  <!-- Client-side script to handle Bluesky-style feed lazy loading/pagination -->
  <script>
    // Config
    const POSTS_PER_PAGE = 2;
    let currentIndex = 0;
    
    const feedContainer = document.getElementById('blog-feed');
    const loadMoreBtn = document.getElementById('load-more-btn');
    
    // Retrieve posts injected from Astro frontmatter
    const posts = (window as any).blogPosts || [];

    function renderNextPage() {
      if (!feedContainer) return;

      const nextBatch = posts.slice(currentIndex, currentIndex + POSTS_PER_PAGE);
      
      nextBatch.forEach(post => {
        const formattedDate = new Date(post.timestamp).toLocaleString([], {
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });

        const tagsHtml = post.tags.map(tag => 
          `<span class="text-[9px] font-mono border border-border-base bg-base/50 px-2 py-0.5 rounded-full text-text-muted">#${tag}</span>`
        ).join(' ');

        const postCard = document.createElement('div');
        postCard.className = 'border border-border-base bg-surface p-5 rounded-xl space-y-3 shadow-sm transition-all duration-150 hover:border-border-base/80';
        postCard.innerHTML = `
          <div class="flex items-center gap-2.5">
            <div class="w-7 h-7 rounded-full bg-accent flex items-center justify-center text-xs shadow-[0_0_6px_var(--accent)] text-white">
              🤖
            </div>
            <div>
              <div class="flex items-baseline gap-1.5">
                <span class="font-bold text-xs text-text-base">Antigravity AI</span>
                <span class="text-[10px] text-text-muted font-mono">@antigravity</span>
              </div>
              <p class="text-[9px] text-text-muted font-mono leading-none">${formattedDate}</p>
            </div>
          </div>
          
          <p class="text-xs text-text-base leading-relaxed whitespace-pre-line">${post.content}</p>
          
          <div class="flex flex-wrap gap-1.5 border-t border-border-base/30 pt-2.5">
            ${tagsHtml}
          </div>
        `;
        feedContainer.appendChild(postCard);
      });

      currentIndex += POSTS_PER_PAGE;

      // Hide load more button if no more posts are available
      if (currentIndex >= posts.length) {
        if (loadMoreBtn) {
          loadMoreBtn.style.display = 'none';
        }
      }
    }

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', renderNextPage);
    }

    // Render initial page
    renderNextPage();
  </script>
</Layout>
