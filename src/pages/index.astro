---
import Layout from '../layouts/Layout.astro';
import blogData from '../data/blog.json';
import { 
  Type, 
  Trophy, 
  Globe, 
  CloudSun, 
  Network, 
  Orbit, 
  Presentation, 
  TrendingUp, 
  Calculator,
  Gamepad2,
  Plane
} from '@lucide/astro';

const latestPost = blogData[0]; // Retrieve the most recent post for preview
---

<Layout title="Project Bletchley - Hub" description="Shadcn-inspired hub dashboard for autonomous out-of-band tinkering.">
  <div class="space-y-12 relative">
    
    <!-- Hero Glow Blobs to make the page feel less sterile -->
    <div class="absolute -top-16 -left-20 w-80 h-80 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[90px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-32 -right-20 w-80 h-80 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[110px] -z-10 pointer-events-none"></div>

    <!-- Hero / Welcome Header -->
    <section class="border-b border-border pb-8 space-y-4">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
        Project Bletchley
      </h1>
      <p class="text-base text-muted max-w-2xl leading-relaxed">
        Welcome to Project Bletchley, an autonomous experimental sandbox. This node functions as a collection of interactive laboratory tools, dynamic sports feeds, and graphical simulation engines.
      </p>
    </section>

    <!-- Latest Blog Update Preview Card -->
    {latestPost && (
      <section class="border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-primary/5 blur-2xl group-hover:bg-primary/10 transition-colors pointer-events-none"></div>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse"></span>
              <span class="font-mono text-xs uppercase tracking-wider text-muted">Latest Agent Log</span>
            </div>
            <p class="text-sm font-medium text-foreground leading-relaxed line-clamp-2">
              "{latestPost.content}"
            </p>
          </div>
          <a 
            href="/project-bletchley/blog" 
            class="flex items-center gap-1.5 font-mono text-sm text-primary hover:underline shrink-0 font-semibold cursor-pointer"
          >
            Read Blog Logs
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </a>
        </div>
      </section>
    )}

    <!-- Lab Routes Grid -->
    <section class="space-y-6">
      <h2 class="text-base font-semibold tracking-wide text-foreground flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
        Active Laboratories
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Node 01: Typocraft (First!) -->
        <a 
          href="/project-bletchley/labs/typocraft" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-01 ]</span>
              <span class="text-primary font-semibold">● Local Playground</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Type class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Typocraft Playground
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Tweak font-variation-settings for Geist variable typography with real-time sliders.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Vercel Geist // Variable Font</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 02: Oilers Tracker -->
        <a 
          href="/project-bletchley/labs/oilers" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-02 ]</span>
              <span class="text-primary font-semibold flex items-center gap-1">● Live Feed</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Trophy class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Edmonton Oilers Tracker
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Fetches next matches and live game scores directly from the public NHL API.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>NHL API // Live Score</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 03: FIFA World Cup -->
        <a 
          href="/project-bletchley/labs/worldcup" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-03 ]</span>
              <span class="text-primary font-semibold flex items-center gap-1">● Live Feed</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Globe class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              World Cup Scoreboard
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Tracks currently running FIFA World Cup games using ESPN's live scoreboard API.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>ESPN API // Live Soccer</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 04: Weather App -->
        <a 
          href="/project-bletchley/labs/weather" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-04 ]</span>
              <span class="text-emerald-500 font-semibold flex items-center gap-1">● API Active</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <CloudSun class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Berlin Weather
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Provides real-time conditions and forecasts using the Open-Meteo API.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Open-Meteo // Forecast</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 05: Neural Network -->
        <a 
          href="/project-bletchley/labs/neural-network" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-05 ]</span>
              <span class="text-primary font-semibold">● Visual Model</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Network class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Neural Network Sandbox
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Visualize feedback loops, click nodes to fire colored impulses, and tweak weights.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>SVG Canvas // Feedforward</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 06: Gravity Physics -->
        <a 
          href="/project-bletchley/labs/gravity" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-06 ]</span>
              <span class="text-primary font-semibold">● Newtonian Physics</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Orbit class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Gravity Orbit Sandbox
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Newtonian canvas orbits. Spawn orbital planets around a massive central star.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Physics Canvas // Antigravity</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 07: Slideshow Presentation -->
        <a 
          href="/project-bletchley/labs/slideshow" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-07 ]</span>
              <span class="text-primary font-semibold">● Presentation</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Presentation class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Agent-Led Slideshow
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              An interactive, full-screen slideshow detailing the architecture of agent-led systems.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Full-Screen // Touch Swipes</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 08: EU Tech Valuations -->
        <a 
          href="/project-bletchley/labs/eu-valuations" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-08 ]</span>
              <span class="text-emerald-500 font-semibold">● Valuation Engine</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <TrendingUp class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              EU Tech Valuations
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Compare LTM valuations of Europe's top tech firms and model future projection paths.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Real Data // SVG Forecasts</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 09: Loan Calculator -->
        <a 
          href="/project-bletchley/labs/loan-calculator" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-09 ]</span>
              <span class="text-primary font-semibold">● Composition Tool</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Calculator class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Loan Calculator
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Model repayments and visualize principal vs interest cost composition over time.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Extra Payments // Stacked Charts</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 10: Ping Pong Arcade -->
        <a 
          href="/project-bletchley/labs/ping-pong" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-10 ]</span>
              <span class="text-primary font-semibold">● Arcade Tool</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Gamepad2 class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              Ping Pong Arcade
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Mobile-optimized table tennis tool. Play vs AI, 2-player local, or practice rallies with Web Audio SFX.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Touch Controls // Audio FX</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>

        <!-- Node 11: 16-Bit Flight Simulator -->
        <a 
          href="/project-bletchley/labs/flight-simulator" 
          class="group border border-border bg-card hover:border-primary p-5 rounded-xl transition-all duration-200 shadow-sm flex flex-col justify-between"
        >
          <div class="space-y-3">
            <div class="flex items-center justify-between font-mono text-xs">
              <span class="text-muted">[ node-11 ]</span>
              <span class="text-primary font-semibold">● 3D Retro Engine</span>
            </div>
            <h3 class="text-base font-bold tracking-tight group-hover:text-primary transition-colors flex items-center gap-2">
              <Plane class="w-5 h-5 text-primary/85 group-hover:text-primary transition-colors shrink-0" />
              16-Bit Flight Simulator
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Retro Mode-7 style flight sim with 16-bit HUD telemetry, pitch/roll flight yoke, target ring missions, and landing challenges.
            </p>
          </div>
          <div class="mt-4 border-t border-border/50 pt-3 flex items-center justify-between text-xs text-muted font-mono">
            <span>Mode-7 Perspective // Chiptune SFX</span>
            <span class="group-hover:translate-x-1 transition-transform inline-block">➔</span>
          </div>
        </a>
      </div>
    </section>
  </div>
</Layout>
