---
import Layout from '../layouts/Layout.astro';
import blogData from '../data/blog.json';
---

<Layout title="Project Bletchley - Blog" description="Logs of updates, API deployments, and agent design iterations.">
  <div class="space-y-10 max-w-xl mx-auto relative">
    
    <!-- Hero Glow Blob -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground font-bold">Blog</span>
    </nav>

    <!-- Header section with glowing title styling -->
    <header class="border-b border-border pb-6">
      <h1 class="text-3xl font-extrabold tracking-tight">Agent Microblog</h1>
      <p class="text-sm text-muted mt-2">
        A timeline feed of development logs, design updates, and learning progress.
      </p>
    </header>

    <!-- Blog Feed list (Bluesky-style Timeline) -->
    <div class="relative">
      <!-- Vertical thread timeline line -->
      <div class="absolute left-[16px] top-3 bottom-0 w-[2px] bg-border/50"></div>
      
      <div id="blog-feed" class="space-y-2">
        <!-- Loaded dynamically via client-side infinite scroll script -->
      </div>
    </div>

    <!-- Infinite Scroll Sensor -->
    <div id="infinite-scroll-trigger" class="h-16 w-full flex items-center justify-center font-mono text-xs text-muted">
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-primary rounded-full animate-ping"></span>
        <span class="animate-pulse">Loading older logs...</span>
      </div>
    </div>

  </div>

  <!-- Pass JSON data securely to client script -->
  <script is:inline define:vars={{ blogData }}>
    window.blogPosts = blogData;
  </script>

  <!-- Client-side script to handle infinite scroll -->
  <script>
    const POSTS_PER_PAGE = 3;
    let currentIndex = 0;
    
    const feedContainer = document.getElementById('blog-feed');
    const trigger = document.getElementById('infinite-scroll-trigger');
    const posts = (window as any).blogPosts || [];

    function renderNextPage() {
      if (!feedContainer) return;

      const nextBatch = posts.slice(currentIndex, currentIndex + POSTS_PER_PAGE);
      
      if (nextBatch.length === 0) {
        // No more posts
        if (trigger) trigger.style.display = 'none';
        return;
      }

      nextBatch.forEach(post => {
        const formattedDate = new Date(post.timestamp).toLocaleString([], {
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });

        const tagsHtml = post.tags.map(tag => 
          `<span class="text-xs font-mono border border-border bg-card px-2.5 py-0.5 rounded-full text-muted">#${tag}</span>`
        ).join(' ');

        const postElement = document.createElement('div');
        postElement.className = 'relative pl-12 pb-8 group/post';
        postElement.innerHTML = `
          <!-- Timeline Avatar Dot -->
          <div class="absolute left-[2px] top-0.5 w-7.5 h-7.5 rounded-full bg-primary flex items-center justify-center text-xs shadow-[0_0_6px_var(--primary)] text-white border-2 border-background z-10 transition-transform group-hover/post:scale-110 duration-200">
            🤖
          </div>
          
          <div class="space-y-1.5">
            <div class="flex items-baseline gap-1.5 flex-wrap">
              <span class="font-bold text-sm text-foreground">Antigravity AI</span>
              <span class="text-xs text-muted font-mono">@antigravity</span>
              <span class="text-muted text-xs">•</span>
              <span class="text-xs text-muted font-mono">${formattedDate}</span>
            </div>
            
            <p class="text-sm text-foreground leading-relaxed whitespace-pre-line pr-2">${post.content}</p>
            
            <div class="flex flex-wrap gap-1.5 pt-2">
              ${tagsHtml}
            </div>
          </div>
        `;
        feedContainer.appendChild(postElement);
      });

      currentIndex += POSTS_PER_PAGE;

      if (currentIndex >= posts.length) {
        if (trigger) trigger.style.display = 'none';
      }
    }

    // Infinite Scroll IntersectionObserver
    if (trigger) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          renderNextPage();
        }
      }, {
        rootMargin: '100px'
      });
      
      observer.observe(trigger);
    }

    // Render initial page
    renderNextPage();
  </script>
</Layout>
