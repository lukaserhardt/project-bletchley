---
import Layout from '../../layouts/Layout.astro';
import { Calculator } from '@lucide/astro';
---

<Layout title="Project Bletchley - Loan Calculator" description="Model loan repayments, analyze interest/principal payment composition over time, and compare term-based and payment-based payoff schedules in EUR.">
  <div class="space-y-8 flex-grow flex flex-col relative">
    
    <!-- Hero Glow Blobs -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground">Labs</span>
      <span>/</span>
      <span class="text-foreground font-bold">Loan Calculator</span>
    </nav>

    <!-- Header -->
    <header class="border-b border-border pb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="flex items-start gap-4">
        <div class="p-3 bg-primary/10 rounded-xl text-primary mt-1 border border-primary/20 shrink-0">
          <Calculator class="w-8 h-8" />
        </div>
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight">Loan Composition & Payoff Simulator</h1>
          <p class="text-sm text-muted mt-2">
            Model loan amortization, see principal vs. interest breakdown, and project payoff dates based on custom payment schedules in EUR (€).
          </p>
        </div>
      </div>
    </header>

    <!-- Main Content Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      <!-- Left side: Parameters Control (5 cols on lg) -->
      <section class="lg:col-span-5 border border-border bg-card rounded-xl p-5 flex flex-col justify-between shadow-sm space-y-6">
        <div class="space-y-6">
          <div class="border-b border-border pb-2 flex items-center justify-between">
            <h2 class="font-mono text-xs font-bold uppercase tracking-wider text-foreground">
              Simulation Mode
            </h2>
          </div>

          <!-- Mode Tab Switcher -->
          <div class="grid grid-cols-2 gap-2 bg-background border border-border p-1 rounded-md">
            <button 
              id="btn-mode-term" 
              class="text-xs font-mono py-2 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white"
            >
              Calculate Payment
            </button>
            <button 
              id="btn-mode-payoff" 
              class="text-xs font-mono py-2 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground"
            >
              Calculate Payoff Date
            </button>
          </div>

          <!-- Shared Input: Loan Sum -->
          <div class="space-y-1.5">
            <div class="flex justify-between text-xs font-mono">
              <label for="loan-amount" class="uppercase tracking-wider text-muted font-semibold">Loan Sum (€)</label>
              <span class="font-bold text-foreground" id="loan-amount-val">€250.000</span>
            </div>
            <input
              type="range"
              id="loan-amount"
              min="5000"
              max="1500000"
              value="250000"
              step="5000"
              class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
            />
            <input 
              type="number" 
              id="loan-amount-input" 
              value="250000"
              class="w-full bg-background border border-border rounded px-2.5 py-1 text-xs font-mono focus:border-primary focus:outline-none text-foreground mt-1" 
            />
          </div>

          <!-- Shared Input: Interest Rate -->
          <div class="space-y-1.5">
            <div class="flex justify-between text-xs font-mono">
              <label for="interest-rate" class="uppercase tracking-wider text-muted font-semibold">Interest Rate (Annual %)</label>
              <span class="font-bold text-foreground" id="interest-rate-val">4,5%</span>
            </div>
            <input
              type="range"
              id="interest-rate"
              min="0.1"
              max="15.0"
              value="4.5"
              step="0.1"
              class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
            />
            <input 
              type="number" 
              id="interest-rate-input" 
              value="4.5"
              step="0.1"
              class="w-full bg-background border border-border rounded px-2.5 py-1 text-xs font-mono focus:border-primary focus:outline-none text-foreground mt-1" 
            />
          </div>

          <!-- DYNAMIC PANEL A: Term-based Inputs -->
          <div class="space-y-4" id="panel-term-mode">
            <!-- Loan Term -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="loan-term" class="uppercase tracking-wider text-muted font-semibold">Loan Term (Years)</label>
                <span class="font-bold text-foreground" id="loan-term-val">25 Years</span>
              </div>
              <input
                type="range"
                id="loan-term"
                min="1"
                max="30"
                value="25"
                step="1"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
            </div>

            <!-- Extra Monthly Payment -->
            <div class="space-y-1.5 pt-3 border-t border-border/40">
              <div class="flex justify-between text-xs font-mono">
                <label for="extra-payment" class="uppercase tracking-wider text-primary font-semibold flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse"></span>
                  Extra Monthly Payment (€)
                </label>
                <span class="font-bold text-primary" id="extra-payment-val">€0</span>
              </div>
              <input
                type="range"
                id="extra-payment"
                min="0"
                max="3000"
                value="0"
                step="50"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <input 
                type="number" 
                id="extra-payment-input" 
                value="0"
                class="w-full bg-background border border-border rounded px-2.5 py-1 text-xs font-mono focus:border-primary focus:outline-none text-foreground mt-1" 
              />
            </div>
          </div>

          <!-- DYNAMIC PANEL B: Payment-based Inputs -->
          <div class="space-y-4 hidden" id="panel-payoff-mode">
            <!-- Monthly Base Payment -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="monthly-payment-target" class="uppercase tracking-wider text-muted font-semibold">Target Monthly Payment (€)</label>
                <span class="font-bold text-foreground" id="monthly-payment-target-val">€1.200</span>
              </div>
              <input
                type="range"
                id="monthly-payment-target"
                min="100"
                max="10000"
                value="1200"
                step="50"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <input 
                type="number" 
                id="monthly-payment-target-input" 
                value="1200"
                class="w-full bg-background border border-border rounded px-2.5 py-1 text-xs font-mono focus:border-primary focus:outline-none text-foreground mt-1" 
              />
            </div>

            <!-- Annual Extra Payment (Sondertilgung) -->
            <div class="space-y-1.5 pt-3 border-t border-border/40">
              <div class="flex justify-between text-xs font-mono">
                <label for="annual-lump-sum" class="uppercase tracking-wider text-primary font-semibold flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
                  Annual Extra Payment (Lump Sum)
                </label>
                <span class="font-bold text-primary" id="annual-lump-sum-val">€2.500</span>
              </div>
              <input
                type="range"
                id="annual-lump-sum"
                min="0"
                max="25000"
                value="2500"
                step="250"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <input 
                type="number" 
                id="annual-lump-sum-input" 
                value="2500"
                class="w-full bg-background border border-border rounded px-2.5 py-1 text-xs font-mono focus:border-primary focus:outline-none text-foreground mt-1" 
              />
            </div>

            <!-- Month of Lump Sum Payment -->
            <div class="space-y-1.5">
              <label for="lump-sum-month" class="font-mono text-xs uppercase tracking-wider text-muted block">
                Extra Payment Month
              </label>
              <select 
                id="lump-sum-month" 
                class="w-full bg-background border border-border rounded px-2.5 py-2 text-xs font-mono text-foreground focus:border-primary focus:outline-none"
              >
                <option value="12">December (Month 12)</option>
                <option value="11">November (Month 11)</option>
                <option value="6">June (Month 6)</option>
                <option value="1">January (Month 1)</option>
              </select>
            </div>
          </div>
        </div>

        <button
          id="reset-calculator-btn"
          class="w-full border border-border bg-background hover:bg-card hover:border-primary text-xs font-mono py-2 rounded-md transition-colors cursor-pointer text-foreground flex items-center justify-center gap-1.5"
        >
          Reset Parameters
        </button>
      </section>

      <!-- Right side: Graph & Summary (7 cols on lg) -->
      <section class="lg:col-span-7 flex flex-col gap-6 justify-between">
        
        <!-- Summary Cards Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="calculator-summary-grid">
          <!-- Populated by JS -->
        </div>

        <!-- Warning / Notification Box -->
        <div id="negative-amortization-warning" class="border border-red-500/20 bg-red-500/5 p-4 rounded-xl hidden">
          <p class="text-xs text-red-400 font-mono flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span id="warning-text">Warning: Target payment is lower than monthly interest. The loan balance will grow indefinitely.</span>
          </p>
        </div>

        <!-- Payment Composition Chart Card -->
        <div class="border border-border bg-card rounded-xl p-6 shadow-sm flex-grow flex flex-col justify-between">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between border-b border-border pb-4 mb-6 gap-2">
            <h3 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground">
              Payment Composition Over Time
            </h3>
            
            <div class="flex items-center gap-4 text-[10px] font-mono text-muted">
              <span class="flex items-center gap-1">
                <span class="w-2.5 h-2.5 bg-primary rounded-sm inline-block"></span>
                Principal
              </span>
              <span class="flex items-center gap-1">
                <span class="w-2.5 h-2.5 bg-rose-500 rounded-sm inline-block"></span>
                Interest
              </span>
              <span class="flex items-center gap-1">
                <span class="w-2.5 h-2.5 bg-emerald-500 rounded-sm inline-block"></span>
                Extra (Monthly/Lump)
              </span>
            </div>
          </div>

          <!-- SVG Stacked Chart -->
          <div class="w-full h-[280px] relative flex flex-col justify-end" id="loan-chart-wrapper">
            <svg class="w-full h-full overflow-visible" id="loan-composition-svg">
              <!-- Grid lines -->
              <g id="loan-grid-lines" stroke="var(--border)" stroke-width="0.75" stroke-dasharray="4 4"></g>
              
              <!-- Columns / Bars of Composition -->
              <g id="loan-bars"></g>
              
              <!-- Axes -->
              <g id="loan-axes" class="text-[10px] font-mono fill-muted"></g>
            </svg>

            <!-- Chart Tooltip -->
            <div id="loan-tooltip" class="absolute bg-card border border-border p-3 rounded shadow-lg text-xs font-mono hidden pointer-events-none z-20">
              <p class="font-bold text-foreground border-b border-border pb-1 mb-1" id="l-tooltip-title">Year X</p>
              <p class="flex justify-between gap-4"><span class="text-muted">Principal:</span> <span class="text-primary font-bold" id="l-tooltip-principal">--</span></p>
              <p class="flex justify-between gap-4"><span class="text-muted">Interest:</span> <span class="text-rose-500 font-bold" id="l-tooltip-interest">--</span></p>
              <p class="flex justify-between gap-4"><span class="text-muted">Extra Paid:</span> <span class="text-emerald-500 font-bold" id="l-tooltip-extra">--</span></p>
              <p class="flex justify-between gap-4 border-t border-border/50 pt-1 mt-1"><span class="text-muted">Ending Bal:</span> <span class="text-foreground font-semibold" id="l-tooltip-balance">--</span></p>
            </div>
          </div>
        </div>

      </section>
    </div>

    <!-- Amortization Schedule Table Card -->
    <section class="border border-border bg-card rounded-xl p-6 shadow-sm overflow-hidden flex flex-col">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between border-b border-border pb-4 mb-4 gap-3">
        <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground">
          Amortization Schedule (Yearly Summary)
        </h2>
        
        <div class="flex items-center gap-3">
          <label for="table-view-mode" class="font-mono text-xs text-muted uppercase">View Details:</label>
          <select 
            id="table-view-mode" 
            class="bg-background border border-border rounded px-2.5 py-1 text-xs font-mono text-foreground focus:border-primary focus:outline-none"
          >
            <option value="yearly">Yearly Summary</option>
            <option value="monthly">All Monthly Payments</option>
          </select>
        </div>
      </div>

      <div class="overflow-x-auto max-h-[400px] scrollbar-thin">
        <table class="w-full text-left font-mono text-xs border-collapse">
          <thead>
            <tr class="border-b border-border text-muted uppercase tracking-wider sticky top-0 bg-card z-10">
              <th class="py-3 px-4" id="th-period">Period</th>
              <th class="py-3 px-4 text-right">Starting Balance</th>
              <th class="py-3 px-4 text-right">Total Payments</th>
              <th class="py-3 px-4 text-right text-primary">Principal Paid</th>
              <th class="py-3 px-4 text-right text-rose-500">Interest Paid</th>
              <th class="py-3 px-4 text-right text-emerald-500">Extra Paid</th>
              <th class="py-3 px-4 text-right font-semibold">Ending Balance</th>
            </tr>
          </thead>
          <tbody id="amortization-table-body" class="divide-y divide-border/40 text-foreground">
            <!-- Dynamically populated -->
          </tbody>
        </table>
      </div>
    </section>

  </div>

  <script>
    // State Variables
    let activeMode = 'term'; // 'term' or 'payoff'
    let loanAmount = 250000;
    let interestRate = 4.5;
    
    // Panel A State (Calculate Payment Mode)
    let loanTermYears = 25;
    let extraMonthly = 0;
    
    // Panel B State (Calculate Payoff Date Mode)
    let targetMonthlyPayment = 1200;
    let annualLumpSum = 2500;
    let lumpSumMonth = 12; // December

    // DOM Elements
    const btnModeTerm = document.getElementById('btn-mode-term');
    const btnModePayoff = document.getElementById('btn-mode-payoff');
    const panelTermMode = document.getElementById('panel-term-mode');
    const panelPayoffMode = document.getElementById('panel-payoff-mode');

    const loanAmountSlider = document.getElementById('loan-amount');
    const loanAmountInput = document.getElementById('loan-amount-input');
    const loanAmountVal = document.getElementById('loan-amount-val');

    const interestRateSlider = document.getElementById('interest-rate');
    const interestRateInput = document.getElementById('interest-rate-input');
    const interestRateVal = document.getElementById('interest-rate-val');

    // Panel A inputs
    const loanTermSlider = document.getElementById('loan-term');
    const loanTermVal = document.getElementById('loan-term-val');
    const extraPaymentSlider = document.getElementById('extra-payment');
    const extraPaymentInput = document.getElementById('extra-payment-input');
    const extraPaymentVal = document.getElementById('extra-payment-val');

    // Panel B inputs
    const monthlyPaymentTargetSlider = document.getElementById('monthly-payment-target');
    const monthlyPaymentTargetInput = document.getElementById('monthly-payment-target-input');
    const monthlyPaymentTargetVal = document.getElementById('monthly-payment-target-val');

    const annualLumpSumSlider = document.getElementById('annual-lump-sum');
    const annualLumpSumInput = document.getElementById('annual-lump-sum-input');
    const annualLumpSumVal = document.getElementById('annual-lump-sum-val');
    const lumpSumMonthSelect = document.getElementById('lump-sum-month');

    const resetBtn = document.getElementById('reset-calculator-btn');
    const summaryGrid = document.getElementById('calculator-summary-grid');
    const warningBox = document.getElementById('negative-amortization-warning');
    const warningText = document.getElementById('warning-text');

    // Chart
    const svgEl = document.getElementById('loan-composition-svg');
    const svgGrid = document.getElementById('loan-grid-lines');
    const svgBars = document.getElementById('loan-bars');
    const svgAxes = document.getElementById('loan-axes');
    const tooltipEl = document.getElementById('loan-tooltip');
    
    const tooltipTitle = document.getElementById('l-tooltip-title');
    const tooltipPrincipal = document.getElementById('l-tooltip-principal');
    const tooltipInterest = document.getElementById('l-tooltip-interest');
    const tooltipExtra = document.getElementById('l-tooltip-extra');
    const tooltipBalance = document.getElementById('l-tooltip-balance');

    // Table
    const tableBody = document.getElementById('amortization-table-body');
    const tableViewMode = document.getElementById('table-view-mode');
    const thPeriod = document.getElementById('th-period');

    function init() {
      setupModeButtons();
      setupSharedInputs();
      setupPanelAInputs();
      setupPanelBInputs();
      
      resetBtn.addEventListener('click', resetAll);
      tableViewMode.addEventListener('change', calculateLoan);
      window.addEventListener('resize', calculateLoan);

      calculateLoan();
    }

    function setupModeButtons() {
      btnModeTerm.addEventListener('click', () => {
        activeMode = 'term';
        btnModeTerm.className = 'text-xs font-mono py-2 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white';
        btnModePayoff.className = 'text-xs font-mono py-2 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground';
        panelTermMode.classList.remove('hidden');
        panelPayoffMode.classList.add('hidden');
        calculateLoan();
      });

      btnModePayoff.addEventListener('click', () => {
        activeMode = 'payoff';
        btnModePayoff.className = 'text-xs font-mono py-2 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white';
        btnModeTerm.className = 'text-xs font-mono py-2 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground';
        panelPayoffMode.classList.remove('hidden');
        panelTermMode.classList.add('hidden');
        
        // Auto-adjust target monthly payment to be reasonable if it is too low
        const minPayment = Math.ceil(loanAmount * (interestRate / 100) / 12) + 100;
        if (targetMonthlyPayment < minPayment) {
          targetMonthlyPayment = minPayment;
          monthlyPaymentTargetSlider.value = targetMonthlyPayment;
          monthlyPaymentTargetInput.value = targetMonthlyPayment;
          monthlyPaymentTargetVal.textContent = formatCurrency(targetMonthlyPayment, 0);
        }
        calculateLoan();
      });
    }

    function setupSharedInputs() {
      loanAmountSlider.addEventListener('input', (e) => {
        loanAmount = parseFloat(e.target.value);
        loanAmountInput.value = loanAmount;
        loanAmountVal.textContent = formatCurrency(loanAmount, 0);
        calculateLoan();
      });

      loanAmountInput.addEventListener('change', (e) => {
        let val = parseFloat(e.target.value);
        if (isNaN(val) || val < 1000) val = 1000;
        if (val > 10000000) val = 10000000;
        loanAmount = val;
        loanAmountSlider.value = Math.min(val, 1500000);
        loanAmountVal.textContent = formatCurrency(loanAmount, 0);
        loanAmountInput.value = loanAmount;
        calculateLoan();
      });

      interestRateSlider.addEventListener('input', (e) => {
        interestRate = parseFloat(e.target.value);
        interestRateInput.value = interestRate.toFixed(2);
        interestRateVal.textContent = `${interestRate.toFixed(1).replace('.', ',')}%`;
        calculateLoan();
      });

      interestRateInput.addEventListener('change', (e) => {
        let val = parseFloat(e.target.value);
        if (isNaN(val) || val < 0.01) val = 0.01;
        if (val > 50) val = 50;
        interestRate = val;
        interestRateSlider.value = Math.min(val, 15.0);
        interestRateVal.textContent = `${interestRate.toFixed(2).replace('.', ',')}%`;
        interestRateInput.value = interestRate;
        calculateLoan();
      });
    }

    function setupPanelAInputs() {
      loanTermSlider.addEventListener('input', (e) => {
        loanTermYears = parseInt(e.target.value);
        loanTermVal.textContent = `${loanTermYears} Years`;
        calculateLoan();
      });

      extraPaymentSlider.addEventListener('input', (e) => {
        extraMonthly = parseFloat(e.target.value);
        extraPaymentInput.value = extraMonthly;
        extraPaymentVal.textContent = formatCurrency(extraMonthly, 0);
        calculateLoan();
      });

      extraPaymentInput.addEventListener('change', (e) => {
        let val = parseFloat(e.target.value);
        if (isNaN(val) || val < 0) val = 0;
        extraMonthly = val;
        extraPaymentSlider.value = Math.min(val, 3000);
        extraPaymentInput.value = val;
        extraPaymentVal.textContent = formatCurrency(val, 0);
        calculateLoan();
      });
    }

    function setupPanelBInputs() {
      monthlyPaymentTargetSlider.addEventListener('input', (e) => {
        targetMonthlyPayment = parseFloat(e.target.value);
        monthlyPaymentTargetInput.value = targetMonthlyPayment;
        monthlyPaymentTargetVal.textContent = formatCurrency(targetMonthlyPayment, 0);
        calculateLoan();
      });

      monthlyPaymentTargetInput.addEventListener('change', (e) => {
        let val = parseFloat(e.target.value);
        if (isNaN(val) || val < 10) val = 10;
        targetMonthlyPayment = val;
        monthlyPaymentTargetSlider.value = Math.min(val, 10000);
        monthlyPaymentTargetInput.value = val;
        monthlyPaymentTargetVal.textContent = formatCurrency(val, 0);
        calculateLoan();
      });

      annualLumpSumSlider.addEventListener('input', (e) => {
        annualLumpSum = parseFloat(e.target.value);
        annualLumpSumInput.value = annualLumpSum;
        annualLumpSumVal.textContent = formatCurrency(annualLumpSum, 0);
        calculateLoan();
      });

      annualLumpSumInput.addEventListener('change', (e) => {
        let val = parseFloat(e.target.value);
        if (isNaN(val) || val < 0) val = 0;
        annualLumpSum = val;
        annualLumpSumSlider.value = Math.min(val, 25000);
        annualLumpSumInput.value = val;
        annualLumpSumVal.textContent = formatCurrency(val, 0);
        calculateLoan();
      });

      lumpSumMonthSelect.addEventListener('change', (e) => {
        lumpSumMonth = parseInt(e.target.value);
        calculateLoan();
      });
    }

    function resetAll() {
      loanAmount = 250000;
      interestRate = 4.5;
      
      loanTermYears = 25;
      extraMonthly = 0;
      
      targetMonthlyPayment = 1200;
      annualLumpSum = 2500;
      lumpSumMonth = 12;

      // Reset DOM
      loanAmountSlider.value = loanAmount;
      loanAmountInput.value = loanAmount;
      loanAmountVal.textContent = formatCurrency(loanAmount, 0);

      interestRateSlider.value = interestRate;
      interestRateInput.value = interestRate;
      interestRateVal.textContent = `4,5%`;

      loanTermSlider.value = loanTermYears;
      loanTermVal.textContent = `25 Years`;

      extraPaymentSlider.value = extraMonthly;
      extraPaymentInput.value = extraMonthly;
      extraPaymentVal.textContent = `€0`;

      monthlyPaymentTargetSlider.value = targetMonthlyPayment;
      monthlyPaymentTargetInput.value = targetMonthlyPayment;
      monthlyPaymentTargetVal.textContent = formatCurrency(targetMonthlyPayment, 0);

      annualLumpSumSlider.value = annualLumpSum;
      annualLumpSumInput.value = annualLumpSum;
      annualLumpSumVal.textContent = formatCurrency(annualLumpSum, 0);

      lumpSumMonthSelect.value = "12";

      calculateLoan();
    }

    function formatCurrency(val, dec = 2) {
      // German formatting for EUR
      return new Intl.NumberFormat('de-DE', {
        style: 'currency',
        currency: 'EUR',
        minimumFractionDigits: dec,
        maximumFractionDigits: dec
      }).format(val);
    }

    function calculateLoan() {
      warningBox.classList.add('hidden');
      
      if (activeMode === 'term') {
        calculateTermBasedLoan();
      } else {
        calculatePayoffBasedLoan();
      }
    }

    // MODE 1: Input Term, output Monthly payment
    function calculateTermBasedLoan() {
      const monthlyRate = (interestRate / 100) / 12;
      const totalPaymentsCount = loanTermYears * 12;
      
      let baseMonthlyPayment = 0;
      if (monthlyRate === 0) {
        baseMonthlyPayment = loanAmount / totalPaymentsCount;
      } else {
        baseMonthlyPayment = (loanAmount * monthlyRate * Math.pow(1 + monthlyRate, totalPaymentsCount)) / 
                              (Math.pow(1 + monthlyRate, totalPaymentsCount) - 1);
      }

      // Amortization loop
      const extraSchedule = [];
      let balance = loanAmount;
      let totalInterest = 0;
      let totalExtraPaid = 0;

      for (let m = 1; m <= totalPaymentsCount; m++) {
        if (balance <= 0) break;

        const startBal = balance;
        const interestPaid = balance * monthlyRate;
        let principalPaid = baseMonthlyPayment - interestPaid;
        
        if (principalPaid > balance) {
          principalPaid = balance;
        }
        balance -= principalPaid;

        // Apply extra monthly
        let actualExtra = 0;
        if (balance > 0 && extraMonthly > 0) {
          actualExtra = Math.min(extraMonthly, balance);
          balance -= actualExtra;
          totalExtraPaid += actualExtra;
        }

        totalInterest += interestPaid;

        extraSchedule.push({
          month: m,
          startBalance: startBal,
          basePayment: principalPaid + interestPaid,
          principalPaid: principalPaid,
          interestPaid: interestPaid,
          extraPaid: actualExtra,
          endingBalance: balance
        });
      }

      // Calculate base loan (without extra payment) for comparison
      let baseTotalInterest = 0;
      let balBaseCompare = loanAmount;
      for (let m = 1; m <= totalPaymentsCount; m++) {
        const interestPaid = balBaseCompare * monthlyRate;
        let principalPaid = baseMonthlyPayment - interestPaid;
        if (principalPaid > balBaseCompare) principalPaid = balBaseCompare;
        balBaseCompare -= principalPaid;
        baseTotalInterest += interestPaid;
        if (balBaseCompare <= 0) break;
      }

      const interestSaved = baseTotalInterest - totalInterest;
      const actualTermMonths = extraSchedule.length;
      const monthsSaved = totalPaymentsCount - actualTermMonths;
      const yearsSaved = Math.floor(monthsSaved / 12);
      const monthsSavedRem = monthsSaved % 12;

      // Set output cards
      renderSummaryCards([
        {
          label: 'Monthly Payment',
          value: formatCurrency(baseMonthlyPayment + extraMonthly),
          hint: `Base: ${formatCurrency(baseMonthlyPayment)} + ${formatCurrency(extraMonthly)} extra`
        },
        {
          label: 'Total Interest Paid',
          value: formatCurrency(totalInterest, 0),
          hint: `Total cost: ${formatCurrency(loanAmount + totalInterest, 0)}`
        },
        {
          label: 'Interest Saved',
          value: formatCurrency(interestSaved, 0),
          hint: monthsSaved > 0 ? `Term reduced by ${yearsSaved}y ${monthsSavedRem}m` : 'No extra payment applied'
        },
        {
          label: 'Payoff Period',
          value: `${Math.floor(actualTermMonths / 12)} yrs ${actualTermMonths % 12} mos`,
          hint: `Est. Payoff: ${getPayoffCalendarDate(actualTermMonths)}`
        }
      ]);

      processScheduleData(extraSchedule);
    }

    // MODE 2: Input Monthly Payment + Annual Lump Sum, output Payoff Date
    function calculatePayoffBasedLoan() {
      const monthlyRate = (interestRate / 100) / 12;
      const monthlyInterestFirst = loanAmount * monthlyRate;

      // Negative Amortization Check
      if (targetMonthlyPayment <= monthlyInterestFirst) {
        warningBox.classList.remove('hidden');
        warningText.innerHTML = `<strong>Negative Amortization Warning:</strong> Target payment (${formatCurrency(targetMonthlyPayment)}) is less than or equal to the initial monthly interest (${formatCurrency(monthlyInterestFirst)}). The balance will increase forever. Please increase your monthly payment.`;
        
        renderSummaryCards([
          { label: 'Monthly Payment', value: formatCurrency(targetMonthlyPayment), hint: 'Insufficient payment' },
          { label: 'Total Interest Paid', value: '--', hint: 'Infinite loop' },
          { label: 'Interest Saved', value: '--', hint: 'N/A' },
          { label: 'Payoff Period', value: 'Never', hint: 'Balance is increasing' }
        ]);

        tableBody.innerHTML = '<tr><td colspan="7" class="py-6 text-center text-red-400 font-mono">Error: Negative Amortization (Target payment is insufficient)</td></tr>';
        
        // Clear SVG chart
        svgGrid.innerHTML = '';
        svgBars.innerHTML = '';
        svgAxes.innerHTML = '';
        return;
      }

      // Amortization Loop
      const schedule = [];
      let balance = loanAmount;
      let totalInterest = 0;
      let totalLumpSumPaid = 0;
      let maxMonths = 600; // 50 Year limit
      let m = 0;

      while (balance > 0 && m < maxMonths) {
        m++;
        const startBal = balance;
        const interestPaid = balance * monthlyRate;
        
        // Target Monthly Payment
        let principalPaid = targetMonthlyPayment - interestPaid;
        
        if (principalPaid > balance) {
          principalPaid = balance;
        }
        balance -= principalPaid;

        // Apply Annual Extra Payment (Sondertilgung)
        let actualExtra = 0;
        if (balance > 0 && annualLumpSum > 0) {
          // Check if this month matches the extra payment month (e.g. m is month 12, 24, 36...)
          const relativeMonthOfYear = m % 12 === 0 ? 12 : m % 12;
          if (relativeMonthOfYear === lumpSumMonth) {
            actualExtra = Math.min(annualLumpSum, balance);
            balance -= actualExtra;
            totalLumpSumPaid += actualExtra;
          }
        }

        totalInterest += interestPaid;

        schedule.push({
          month: m,
          startBalance: startBal,
          basePayment: principalPaid + interestPaid,
          principalPaid: principalPaid,
          interestPaid: interestPaid,
          extraPaid: actualExtra,
          endingBalance: balance
        });
      }

      // Calculate baseline without the annual lump sum for comparison
      let baseTotalInterest = 0;
      let balBaseCompare = loanAmount;
      let baseM = 0;
      while (balBaseCompare > 0 && baseM < maxMonths) {
        baseM++;
        const interestPaid = balBaseCompare * monthlyRate;
        let principalPaid = targetMonthlyPayment - interestPaid;
        if (principalPaid > balBaseCompare) principalPaid = balBaseCompare;
        balBaseCompare -= principalPaid;
        baseTotalInterest += interestPaid;
      }

      const actualTermMonths = schedule.length;
      const monthsSaved = baseM - actualTermMonths;
      const interestSaved = baseTotalInterest - totalInterest;

      renderSummaryCards([
        {
          label: 'Monthly Payment',
          value: formatCurrency(targetMonthlyPayment),
          hint: `Annual Extra: ${formatCurrency(annualLumpSum)} (Month ${lumpSumMonth})`
        },
        {
          label: 'Total Interest Paid',
          value: formatCurrency(totalInterest, 0),
          hint: `Total cost: ${formatCurrency(loanAmount + totalInterest, 0)}`
        },
        {
          label: 'Interest Saved',
          value: formatCurrency(interestSaved, 0),
          hint: monthsSaved > 0 
            ? `Lump sum reduced term by ${Math.floor(monthsSaved/12)}y ${monthsSaved%12}m`
            : 'No time saved'
        },
        {
          label: 'Payoff Period',
          value: `${Math.floor(actualTermMonths / 12)} yrs ${actualTermMonths % 12} mos`,
          hint: `Est. Payoff: ${getPayoffCalendarDate(actualTermMonths)}`
        }
      ]);

      if (actualTermMonths >= maxMonths) {
        warningBox.classList.remove('hidden');
        warningText.innerHTML = `<strong>Notice:</strong> Payoff exceeds 50 years under these parameters. Schedule has been truncated.`;
      }

      processScheduleData(schedule);
    }

    function renderSummaryCards(cards) {
      if (!summaryGrid) return;
      summaryGrid.innerHTML = '';
      
      cards.forEach(c => {
        const cardDiv = document.createElement('div');
        cardDiv.className = 'border border-border bg-card p-4 rounded-xl shadow-sm';
        cardDiv.innerHTML = `
          <span class="text-[10px] font-mono text-muted uppercase block">${c.label}</span>
          <span class="text-base font-bold text-foreground mt-1 block">${c.value}</span>
          <span class="text-[9px] font-mono text-muted block mt-0.5">${c.hint}</span>
        `;
        summaryGrid.appendChild(cardDiv);
      });
    }

    function getPayoffCalendarDate(monthsAhead) {
      const today = new Date(); // Using current runtime date (approx June 2026)
      today.setMonth(today.getMonth() + monthsAhead);
      return today.toLocaleDateString('de-DE', { year: 'numeric', month: 'long' });
    }

    function processScheduleData(schedule) {
      // 1. Group Schedule by Year
      const yearlySummary = [];
      let currentYear = 1;
      let yrStartBal = loanAmount;
      let yrPrincipal = 0;
      let yrInterest = 0;
      let yrExtra = 0;
      let yrPayment = 0;

      schedule.forEach((row, index) => {
        yrPrincipal += row.principalPaid;
        yrInterest += row.interestPaid;
        yrExtra += row.extraPaid;
        yrPayment += row.basePayment + row.extraPaid;

        const isLastRow = index === schedule.length - 1;
        const isYearEnd = row.month % 12 === 0;

        if (isYearEnd || isLastRow) {
          yearlySummary.push({
            year: currentYear,
            startBalance: yrStartBal,
            payment: yrPayment,
            principalPaid: yrPrincipal,
            interestPaid: yrInterest,
            extraPaid: yrExtra,
            endingBalance: row.endingBalance
          });

          currentYear++;
          yrStartBal = row.endingBalance;
          yrPrincipal = 0;
          yrInterest = 0;
          yrExtra = 0;
          yrPayment = 0;
        }
      });

      // 2. Render Table
      const viewMode = tableViewMode.value;
      if (viewMode === 'yearly') {
        thPeriod.textContent = 'Year';
        renderYearlyTable(yearlySummary);
      } else {
        thPeriod.textContent = 'Month';
        renderMonthlyTable(schedule);
      }

      // 3. Render SVG Chart
      renderChart(yearlySummary);
    }

    function renderYearlyTable(yearlySummary) {
      if (!tableBody) return;
      tableBody.innerHTML = '';

      yearlySummary.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-border/40 hover:bg-primary/5 transition-colors';
        tr.innerHTML = `
          <td class="py-3 px-4 font-bold text-foreground">Year ${row.year}</td>
          <td class="py-3 px-4 text-right">${formatCurrency(row.startBalance, 0)}</td>
          <td class="py-3 px-4 text-right">${formatCurrency(row.payment, 0)}</td>
          <td class="py-3 px-4 text-right text-primary font-semibold">${formatCurrency(row.principalPaid, 0)}</td>
          <td class="py-3 px-4 text-right text-rose-500">${formatCurrency(row.interestPaid, 0)}</td>
          <td class="py-3 px-4 text-right text-emerald-500 font-semibold">${row.extraPaid > 0 ? formatCurrency(row.extraPaid, 0) : '—'}</td>
          <td class="py-3 px-4 text-right font-bold text-foreground">${formatCurrency(row.endingBalance, 0)}</td>
        `;
        tableBody.appendChild(tr);
      });
    }

    function renderMonthlyTable(monthlySchedule) {
      if (!tableBody) return;
      tableBody.innerHTML = '';

      monthlySchedule.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-border/40 hover:bg-primary/5 transition-colors text-muted-foreground';
        
        const yr = Math.floor((row.month - 1) / 12) + 1;
        const mo = ((row.month - 1) % 12) + 1;

        tr.innerHTML = `
          <td class="py-2.5 px-4 font-bold text-foreground">Month ${row.month} <span class="text-[9px] text-muted font-normal block">Year ${yr} / Month ${mo}</span></td>
          <td class="py-2.5 px-4 text-right">${formatCurrency(row.startBalance, 0)}</td>
          <td class="py-2.5 px-4 text-right">${formatCurrency(row.basePayment + row.extraPaid, 0)}</td>
          <td class="py-2.5 px-4 text-right text-primary">${formatCurrency(row.principalPaid, 0)}</td>
          <td class="py-2.5 px-4 text-right text-rose-500">${formatCurrency(row.interestPaid, 0)}</td>
          <td class="py-2.5 px-4 text-right text-emerald-500 font-semibold">${row.extraPaid > 0 ? formatCurrency(row.extraPaid, 0) : '—'}</td>
          <td class="py-2.5 px-4 text-right font-bold text-foreground">${formatCurrency(row.endingBalance, 0)}</td>
        `;
        tableBody.appendChild(tr);
      });
    }

    function renderChart(yearlySummary) {
      if (!svgEl) return;

      const width = svgEl.clientWidth;
      const height = svgEl.clientHeight;
      const paddingLeft = 55;
      const paddingRight = 10;
      const paddingTop = 20;
      const paddingBottom = 30;

      const chartW = width - paddingLeft - paddingRight;
      const chartH = height - paddingTop - paddingBottom;

      // Clear SVG groups
      svgGrid.innerHTML = '';
      svgBars.innerHTML = '';
      svgAxes.innerHTML = '';

      if (yearlySummary.length === 0) return;

      // Find max payment in any year to scale the bars
      const maxYearlySum = Math.max(...yearlySummary.map(d => d.principalPaid + d.interestPaid + d.extraPaid));

      // Draw horizontal Grid lines and Y labels
      const gridLines = 4;
      for (let i = 0; i <= gridLines; i++) {
        const y = paddingTop + (chartH * i) / gridLines;
        
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', String(paddingLeft));
        line.setAttribute('y1', String(y));
        line.setAttribute('x2', String(width - paddingRight));
        line.setAttribute('y2', String(y));
        svgGrid.appendChild(line);

        // Y-axis label
        const val = maxYearlySum - (maxYearlySum * i) / gridLines;
        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', String(paddingLeft - 8));
        text.setAttribute('y', String(y + 4));
        text.setAttribute('text-anchor', 'end');
        text.textContent = formatCompactVal(val);
        svgAxes.appendChild(text);
      }

      // Render Stacked Bars
      const barCount = yearlySummary.length;
      const barSpacing = Math.max(1.5, Math.min(8, chartW / barCount / 4));
      const barW = (chartW / barCount) - barSpacing;

      yearlySummary.forEach((d, idx) => {
        const x = paddingLeft + (idx * (chartW / barCount)) + barSpacing / 2;
        
        const hPrincipal = (d.principalPaid / maxYearlySum) * chartH;
        const hInterest = (d.interestPaid / maxYearlySum) * chartH;
        const hExtra = (d.extraPaid / maxYearlySum) * chartH;

        // Interest Bar (bottom)
        const yInterest = paddingTop + chartH - hInterest;
        const rectInterest = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        rectInterest.setAttribute('x', String(x));
        rectInterest.setAttribute('y', String(yInterest));
        rectInterest.setAttribute('width', String(barW));
        rectInterest.setAttribute('height', String(hInterest));
        rectInterest.setAttribute('fill', 'var(--color-rose-500, #f43f5e)');
        rectInterest.setAttribute('class', 'opacity-85 hover:opacity-100 transition-opacity cursor-pointer');
        svgBars.appendChild(rectInterest);

        // Principal Bar (middle)
        const yPrincipal = yInterest - hPrincipal;
        const rectPrincipal = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        rectPrincipal.setAttribute('x', String(x));
        rectPrincipal.setAttribute('y', String(yPrincipal));
        rectPrincipal.setAttribute('width', String(barW));
        rectPrincipal.setAttribute('height', String(hPrincipal));
        rectPrincipal.setAttribute('fill', 'var(--primary)');
        rectPrincipal.setAttribute('class', 'opacity-85 hover:opacity-100 transition-opacity cursor-pointer');
        svgBars.appendChild(rectPrincipal);

        // Extra Payment Bar (top)
        const yExtra = yPrincipal - hExtra;
        if (hExtra > 0) {
          const rectExtra = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rectExtra.setAttribute('x', String(x));
          rectExtra.setAttribute('y', String(yExtra));
          rectExtra.setAttribute('width', String(barW));
          rectExtra.setAttribute('height', String(hExtra));
          rectExtra.setAttribute('fill', 'var(--color-emerald-500, #10b981)');
          rectExtra.setAttribute('class', 'opacity-85 hover:opacity-100 transition-opacity cursor-pointer');
          svgBars.appendChild(rectExtra);
        }

        // Invisible Hover Overlay Rect for easier Tooltip activation
        const hoverRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        hoverRect.setAttribute('x', String(x - barSpacing/2));
        hoverRect.setAttribute('y', String(paddingTop));
        hoverRect.setAttribute('width', String(barW + barSpacing));
        hoverRect.setAttribute('height', String(chartH));
        hoverRect.setAttribute('fill', 'transparent');
        hoverRect.setAttribute('class', 'cursor-pointer hover:fill-primary/5 transition-colors');
        
        hoverRect.addEventListener('mouseenter', () => {
          tooltipTitle.textContent = `Year ${d.year}`;
          tooltipPrincipal.textContent = formatCurrency(d.principalPaid, 0);
          tooltipInterest.textContent = formatCurrency(d.interestPaid, 0);
          tooltipExtra.textContent = formatCurrency(d.extraPaid, 0);
          tooltipBalance.textContent = formatCurrency(d.endingBalance, 0);

          // Position Tooltip
          const rect = svgEl.getBoundingClientRect();
          const tooltipW = tooltipEl.clientWidth || 140;
          const tooltipH = tooltipEl.clientHeight || 120;
          
          let leftPos = x + barW / 2 - tooltipW / 2;
          let topPos = yExtra - tooltipH - 8;

          if (leftPos < 10) leftPos = 10;
          if (leftPos + tooltipW > rect.width - 10) leftPos = rect.width - tooltipW - 10;
          if (topPos < 10) topPos = yExtra + 8; // flip below if off top

          tooltipEl.style.left = `${leftPos}px`;
          tooltipEl.style.top = `${topPos}px`;
          tooltipEl.classList.remove('hidden');
        });

        hoverRect.addEventListener('mouseleave', () => {
          tooltipEl.classList.add('hidden');
        });

        svgBars.appendChild(hoverRect);

        // X Axis labels (Show every few years if long term to avoid clutter)
        const showLabel = barCount <= 12 || d.year % 5 === 0 || d.year === 1 || d.year === barCount;
        if (showLabel) {
          const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          text.setAttribute('x', String(x + barW / 2));
          text.setAttribute('y', String(height - 8));
          text.setAttribute('text-anchor', 'middle');
          text.textContent = `Y${d.year}`;
          svgAxes.appendChild(text);
        }
      });
    }

    function formatCompactVal(val) {
      if (val >= 1000) {
        return `€${(val / 1000).toFixed(1).replace('.', ',')}k`;
      }
      return `€${Math.round(val)}`;
    }

    init();
  </script>
</Layout>
