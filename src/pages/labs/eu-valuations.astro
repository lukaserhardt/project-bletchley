---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Project Bletchley - EU Tech Valuations & Projections" description="Compare valuations of top European technology companies and project future growth paths using real data.">
  <div class="space-y-8 flex-grow flex flex-col relative">
    
    <!-- Hero Glow Blobs -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground">Labs</span>
      <span>/</span>
      <span class="text-foreground font-bold">EU Tech Valuations</span>
    </nav>

    <!-- Header -->
    <header class="border-b border-border pb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight">EU Tech Valuations & Projections</h1>
        <p class="text-sm text-muted mt-2">
          Compare key financial metrics of Europe's largest technology enterprises and model custom future growth projections.
        </p>
      </div>
      <div class="text-xs font-mono bg-card border border-border px-3 py-1.5 rounded-md text-muted self-start md:self-auto">
        Data Epoch: <span class="text-foreground font-semibold">June 2026</span>
      </div>
    </header>

    <!-- Main Workspace Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      <!-- Compare & Selector Card (Left Col - 12 spans on small, 5 on lg) -->
      <section class="lg:col-span-5 border border-border bg-card rounded-xl p-6 flex flex-col justify-between shadow-sm space-y-6">
        <div>
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider border-b border-border pb-2 text-foreground mb-4">
            Select Company to Project
          </h2>
          <div class="space-y-3" id="company-selector-container">
            <!-- Dynamically populated via JS -->
            <div class="text-center py-8 text-muted font-mono text-xs">Loading companies...</div>
          </div>
        </div>

        <div class="border-t border-border pt-4 space-y-3">
          <h3 class="font-mono text-xs font-semibold uppercase tracking-wider text-muted">Comparative Metrics (LTM)</h3>
          <div class="grid grid-cols-2 gap-2 text-xs font-mono">
            <div class="bg-background/50 p-2.5 rounded border border-border/30">
              <span class="text-muted block text-[10px] uppercase">Combined Cap</span>
              <span class="text-foreground font-bold text-sm" id="combined-cap">--</span>
            </div>
            <div class="bg-background/50 p-2.5 rounded border border-border/30">
              <span class="text-muted block text-[10px] uppercase">Avg P/E Ratio</span>
              <span class="text-foreground font-bold text-sm" id="avg-pe">--</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Projection Simulator Control Panel (Right Col - 7 spans on lg) -->
      <section class="lg:col-span-7 border border-border bg-card rounded-xl p-6 flex flex-col justify-between shadow-sm space-y-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl pointer-events-none"></div>
        
        <div>
          <div class="flex items-center justify-between border-b border-border pb-2 mb-6">
            <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground">
              Projection Engine
            </h2>
            <span class="text-xs font-mono px-2 py-0.5 bg-primary/10 border border-primary/20 text-primary rounded-full font-semibold" id="active-company-badge">
              ASML
            </span>
          </div>

          <!-- Parameter Sliders -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <!-- Revenue Growth -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="growth-rate" class="uppercase tracking-wider text-muted">Annual Revenue Growth</label>
                <span id="growth-rate-val" class="font-bold text-foreground">18%</span>
              </div>
              <input
                type="range"
                id="growth-rate"
                min="-10"
                max="50"
                value="18"
                step="1"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <span class="text-[10px] text-muted font-mono block" id="growth-rate-hint">Historical Average: 18%</span>
            </div>

            <!-- Target Profit Margin -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="target-margin" class="uppercase tracking-wider text-muted">Target Net Margin</label>
                <span id="target-margin-val" class="font-bold text-foreground">27.6%</span>
              </div>
              <input
                type="range"
                id="target-margin"
                min="1"
                max="50"
                value="27.6"
                step="0.5"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <span class="text-[10px] text-muted font-mono block" id="target-margin-hint">Current: 27.6%</span>
            </div>

            <!-- Terminal P/E Multiple -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="terminal-pe" class="uppercase tracking-wider text-muted">Terminal P/E Multiple</label>
                <span id="terminal-pe-val" class="font-bold text-foreground">85x</span>
              </div>
              <input
                type="range"
                id="terminal-pe"
                min="5"
                max="120"
                value="85"
                step="1"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <span class="text-[10px] text-muted font-mono block" id="terminal-pe-hint">Current: 85x</span>
            </div>

            <!-- Discount Rate (NPV) -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="discount-rate" class="uppercase tracking-wider text-muted">Discount Rate (WACC)</label>
                <span id="discount-rate-val" class="font-bold text-foreground">9.0%</span>
              </div>
              <input
                type="range"
                id="discount-rate"
                min="4"
                max="20"
                value="9"
                step="0.5"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <span class="text-[10px] text-muted font-mono block">Required rate of return</span>
            </div>

            <!-- Forecast Horizon (Years) -->
            <div class="space-y-1.5 md:col-span-2">
              <div class="flex justify-between text-xs font-mono">
                <label for="forecast-years" class="uppercase tracking-wider text-muted">Forecast Horizon</label>
                <span id="forecast-years-val" class="font-bold text-foreground">5 Years</span>
              </div>
              <input
                type="range"
                id="forecast-years"
                min="1"
                max="10"
                value="5"
                step="1"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
            </div>
          </div>
        </div>

        <!-- Reset Button -->
        <div class="flex justify-end pt-2">
          <button
            id="reset-simulation-btn"
            class="border border-border bg-background hover:bg-card hover:border-primary text-xs font-mono px-4 py-2 rounded-md transition-colors cursor-pointer text-foreground flex items-center gap-1.5"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Reset to Defaults
          </button>
        </div>
      </section>

    </div>

    <!-- Projection Output Panels -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      <!-- Visual Valuation Projection Graph -->
      <section class="lg:col-span-8 border border-border bg-card rounded-xl p-6 flex flex-col shadow-sm">
        <div class="flex items-center justify-between border-b border-border pb-4 mb-6">
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground">
            Valuation Growth Path
          </h2>
          <div class="flex items-center gap-4 text-[10px] font-mono text-muted">
            <span class="flex items-center gap-1">
              <span class="w-2.5 h-2.5 bg-primary rounded-sm inline-block"></span>
              Market Cap
            </span>
            <span class="flex items-center gap-1">
              <span class="w-2.5 h-2.5 bg-emerald-500 rounded-sm inline-block"></span>
              Revenue
            </span>
          </div>
        </div>

        <!-- SVG Projection Chart -->
        <div class="w-full h-[320px] relative flex flex-col justify-end" id="chart-wrapper">
          <svg class="w-full h-full overflow-visible" id="projection-svg">
            <defs>
              <linearGradient id="primary-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.3"></stop>
                <stop offset="100%" stop-color="var(--primary)" stop-opacity="0.0"></stop>
              </linearGradient>
              <linearGradient id="emerald-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#10b981" stop-opacity="0.25"></stop>
                <stop offset="100%" stop-color="#10b981" stop-opacity="0.0"></stop>
              </linearGradient>
            </defs>
            
            <!-- Grid Lines -->
            <g id="chart-grid-lines" stroke="var(--border)" stroke-width="0.75" stroke-dasharray="4 4"></g>
            
            <!-- Areas under paths -->
            <path id="chart-area-mcap" fill="url(#primary-grad)"></path>
            <path id="chart-area-revenue" fill="url(#emerald-grad)"></path>

            <!-- Lines -->
            <path id="chart-line-mcap" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round"></path>
            <path id="chart-line-revenue" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round"></path>

            <!-- Interactive circles/dots -->
            <g id="chart-dots"></g>
            
            <!-- Axis Labels -->
            <g id="chart-axes" class="text-[10px] font-mono fill-muted"></g>
          </svg>

          <!-- Interactive Tooltip Overlay -->
          <div id="chart-tooltip" class="absolute bg-card border border-border p-3 rounded shadow-lg text-xs font-mono hidden pointer-events-none z-20">
            <p class="font-bold text-foreground border-b border-border pb-1 mb-1" id="tooltip-year">Year X</p>
            <p class="flex justify-between gap-6"><span class="text-muted">Mkt Cap:</span> <span class="text-primary font-bold" id="tooltip-mcap">--</span></p>
            <p class="flex justify-between gap-6"><span class="text-muted">Revenue:</span> <span class="text-emerald-500 font-bold" id="tooltip-rev">--</span></p>
            <p class="flex justify-between gap-6"><span class="text-muted">Net Income:</span> <span class="text-foreground" id="tooltip-income">--</span></p>
          </div>
        </div>
      </section>

      <!-- Projection Model Summary & Grid Table -->
      <section class="lg:col-span-4 border border-border bg-card rounded-xl p-6 flex flex-col justify-between shadow-sm space-y-6">
        <div>
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider border-b border-border pb-2 text-foreground mb-4">
            Projection Overview
          </h2>
          <div class="space-y-4">
            <!-- Growth CAGR -->
            <div class="flex items-center justify-between border-b border-border/40 pb-2.5">
              <span class="text-xs font-mono text-muted uppercase">Terminal Value</span>
              <span class="text-sm font-bold text-foreground" id="proj-terminal-mcap">--</span>
            </div>
            <!-- Net Present Value -->
            <div class="flex items-center justify-between border-b border-border/40 pb-2.5">
              <span class="text-xs font-mono text-muted uppercase">Present Value (NPV)</span>
              <span class="text-sm font-bold text-primary" id="proj-npv">--</span>
            </div>
            <!-- Multiple Growth -->
            <div class="flex items-center justify-between border-b border-border/40 pb-2.5">
              <span class="text-xs font-mono text-muted uppercase">Valuation Multiple</span>
              <span class="text-sm font-bold text-foreground" id="proj-multiple">--</span>
            </div>
            <!-- Implied CAGR -->
            <div class="flex items-center justify-between">
              <span class="text-xs font-mono text-muted uppercase">Implied CAGR</span>
              <span class="text-sm font-bold text-emerald-500" id="proj-cagr">--</span>
            </div>
          </div>
        </div>

        <div class="border-t border-border pt-4 bg-background/30 p-4 rounded-lg border border-border/40">
          <h3 class="font-mono text-xs font-bold uppercase text-foreground mb-1.5 flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
            Simulation Summary
          </h3>
          <p class="text-xs text-muted leading-relaxed font-mono" id="sim-narrative">
            Select parameters above to calculate terminal valuation trends.
          </p>
        </div>
      </section>

    </div>

    <!-- Data Projection Table -->
    <section class="border border-border bg-card rounded-xl p-6 shadow-sm overflow-hidden">
      <h2 class="font-mono text-sm font-bold uppercase tracking-wider border-b border-border pb-2 text-foreground mb-4">
        Detailed Forecast Schedule ($ USD, Billions)
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left font-mono text-xs border-collapse">
          <thead>
            <tr class="border-b border-border text-muted uppercase tracking-wider">
              <th class="py-3 px-4">Year</th>
              <th class="py-3 px-4">Revenue</th>
              <th class="py-3 px-4 text-right">Growth</th>
              <th class="py-3 px-4">Net Income</th>
              <th class="py-3 px-4">Net Margin</th>
              <th class="py-3 px-4 text-right">Projected Market Cap</th>
              <th class="py-3 px-4 text-right">Discount Factor</th>
              <th class="py-3 px-4 text-right">NPV Value</th>
            </tr>
          </thead>
          <tbody id="projection-table-body" class="divide-y divide-border/40 text-foreground">
            <!-- Dynamically populated -->
          </tbody>
        </table>
      </div>
    </section>

  </div>

  <script>
    // Real June 2026 Data for Top European Tech
    const COMPANIES_DATA = [
      {
        id: 'asml',
        name: 'ASML Holding',
        country: 'Netherlands',
        sector: 'Semiconductors',
        marketCap: 695.0, // Billions USD
        revenue: 29.0, // LTM Billions USD
        netIncome: 8.0, // LTM Billions USD
        peRatio: 85.0,
        historicalGrowth: 18.0, // Annual Avg %
        description: 'Global monopolist in EUV photolithography systems essential for leading-edge microchip fabrication.'
      },
      {
        id: 'sap',
        name: 'SAP SE',
        country: 'Germany',
        sector: 'Enterprise Software',
        marketCap: 200.0,
        revenue: 35.0,
        netIncome: 4.5,
        peRatio: 44.0,
        historicalGrowth: 10.0,
        description: 'Multinational ERP software provider powering supply chains and business logistics globally.'
      },
      {
        id: 'infineon',
        name: 'Infineon Technologies',
        country: 'Germany',
        sector: 'Semiconductors',
        marketCap: 114.0,
        revenue: 17.0,
        netIncome: 2.5,
        peRatio: 45.0,
        historicalGrowth: 12.0,
        description: 'Automotive and industrial power semiconductor leader targeting decarbonization and smart driving.'
      },
      {
        id: 'spotify',
        name: 'Spotify Technology',
        country: 'Sweden',
        sector: 'Digital Media',
        marketCap: 96.0,
        revenue: 16.0,
        netIncome: 1.2,
        peRatio: 80.0,
        historicalGrowth: 15.0,
        description: 'World-leading audio streaming platform with dominant market share in podcasts and music subscriptions.'
      },
      {
        id: 'stmicro',
        name: 'STMicroelectronics',
        country: 'Switzerland/FR/IT',
        sector: 'Semiconductors',
        marketCap: 63.0,
        revenue: 16.0,
        netIncome: 2.2,
        peRatio: 28.0,
        historicalGrowth: 8.0,
        description: 'Supplier of integrated analog circuits, sensors, and microcontrollers for automotive and IoT.'
      },
      {
        id: 'adyen',
        name: 'Adyen N.V.',
        country: 'Netherlands',
        sector: 'Fintech Payments',
        marketCap: 32.0,
        revenue: 2.0, // Net Revenue
        netIncome: 0.8,
        peRatio: 40.0,
        historicalGrowth: 22.0,
        description: 'Single-platform payment processor managing transaction channels for global tech enterprises.'
      }
    ];

    // Current State
    let activeCompany = COMPANIES_DATA[0];
    let simGrowth = activeCompany.historicalGrowth;
    let simMargin = (activeCompany.netIncome / activeCompany.revenue) * 100;
    let simTerminalPe = activeCompany.peRatio;
    let simDiscountRate = 9.0;
    let simYears = 5;

    // Elements
    const companySelectorContainer = document.getElementById('company-selector-container');
    const combinedCapEl = document.getElementById('combined-cap');
    const avgPeEl = document.getElementById('avg-pe');
    const activeCompanyBadge = document.getElementById('active-company-badge');
    
    // Sliders & Values
    const growthRateSlider = document.getElementById('growth-rate');
    const growthRateVal = document.getElementById('growth-rate-val');
    const growthRateHint = document.getElementById('growth-rate-hint');
    
    const targetMarginSlider = document.getElementById('target-margin');
    const targetMarginVal = document.getElementById('target-margin-val');
    const targetMarginHint = document.getElementById('target-margin-hint');
    
    const terminalPeSlider = document.getElementById('terminal-pe');
    const terminalPeVal = document.getElementById('terminal-pe-val');
    const terminalPeHint = document.getElementById('terminal-pe-hint');
    
    const discountRateSlider = document.getElementById('discount-rate');
    const discountRateVal = document.getElementById('discount-rate-val');
    
    const forecastYearsSlider = document.getElementById('forecast-years');
    const forecastYearsVal = document.getElementById('forecast-years-val');

    const resetBtn = document.getElementById('reset-simulation-btn');

    // Outputs
    const projTerminalMcap = document.getElementById('proj-terminal-mcap');
    const projNpv = document.getElementById('proj-npv');
    const projMultiple = document.getElementById('proj-multiple');
    const projCagr = document.getElementById('proj-cagr');
    const simNarrative = document.getElementById('sim-narrative');
    const tableBody = document.getElementById('projection-table-body');
    
    // Chart
    const svgEl = document.getElementById('projection-svg');
    const svgGrid = document.getElementById('chart-grid-lines');
    const svgAreaMcap = document.getElementById('chart-area-mcap');
    const svgAreaRev = document.getElementById('chart-area-revenue');
    const svgLineMcap = document.getElementById('chart-line-mcap');
    const svgLineRev = document.getElementById('chart-line-revenue');
    const svgDots = document.getElementById('chart-dots');
    const svgAxes = document.getElementById('chart-axes');
    const chartTooltip = document.getElementById('chart-tooltip');
    const tooltipYear = document.getElementById('tooltip-year');
    const tooltipMcap = document.getElementById('tooltip-mcap');
    const tooltipRev = document.getElementById('tooltip-rev');
    const tooltipIncome = document.getElementById('tooltip-income');

    // Setup Event Listeners
    function init() {
      renderCompanySelectors();
      calculateOverviewMetrics();
      syncSlidersToActiveCompany();
      runSimulation();

      // Sliders input events
      growthRateSlider.addEventListener('input', (e) => {
        simGrowth = parseFloat(e.target.value);
        growthRateVal.textContent = `${simGrowth}%`;
        runSimulation();
      });

      targetMarginSlider.addEventListener('input', (e) => {
        simMargin = parseFloat(e.target.value);
        targetMarginVal.textContent = `${simMargin.toFixed(1)}%`;
        runSimulation();
      });

      terminalPeSlider.addEventListener('input', (e) => {
        simTerminalPe = parseFloat(e.target.value);
        terminalPeVal.textContent = `${simTerminalPe}x`;
        runSimulation();
      });

      discountRateSlider.addEventListener('input', (e) => {
        simDiscountRate = parseFloat(e.target.value);
        discountRateVal.textContent = `${simDiscountRate.toFixed(1)}%`;
        runSimulation();
      });

      forecastYearsSlider.addEventListener('input', (e) => {
        simYears = parseInt(e.target.value);
        forecastYearsVal.textContent = `${simYears} Year${simYears > 1 ? 's' : ''}`;
        runSimulation();
      });

      resetBtn.addEventListener('click', () => {
        syncSlidersToActiveCompany();
        runSimulation();
      });

      // Handle resize for Chart redraw
      window.addEventListener('resize', () => {
        runSimulation();
      });
    }

    function calculateOverviewMetrics() {
      const totalCap = COMPANIES_DATA.reduce((acc, c) => acc + c.marketCap, 0);
      const avgPe = COMPANIES_DATA.reduce((acc, c) => acc + c.peRatio, 0) / COMPANIES_DATA.length;
      
      if (combinedCapEl) combinedCapEl.textContent = `$${totalCap.toFixed(1)}B`;
      if (avgPeEl) avgPeEl.textContent = `${avgPe.toFixed(1)}x`;
    }

    function renderCompanySelectors() {
      if (!companySelectorContainer) return;
      companySelectorContainer.innerHTML = '';

      COMPANIES_DATA.forEach(c => {
        const currentMargin = ((c.netIncome / c.revenue) * 100).toFixed(1);
        const card = document.createElement('button');
        card.className = `w-full text-left p-3.5 rounded-lg border text-xs font-mono transition-all cursor-pointer flex flex-col justify-between gap-1.5 ${
          activeCompany.id === c.id 
            ? 'border-primary bg-primary/5 shadow-inner' 
            : 'border-border bg-background/50 hover:border-border/80 hover:bg-background/80'
        }`;
        
        card.innerHTML = `
          <div class="flex items-center justify-between">
            <span class="font-bold text-foreground text-sm">${c.name}</span>
            <span class="text-[10px] text-muted bg-border/40 px-1.5 py-0.5 rounded uppercase font-semibold">${c.country}</span>
          </div>
          <div class="grid grid-cols-3 gap-2 mt-1 text-[10px] text-muted border-t border-border/20 pt-2">
            <div>Cap: <span class="text-foreground font-semibold">$${c.marketCap}B</span></div>
            <div>PE: <span class="text-foreground font-semibold">${c.peRatio}x</span></div>
            <div>Growth: <span class="text-foreground font-semibold">+${c.historicalGrowth}%</span></div>
          </div>
        `;

        card.addEventListener('click', () => {
          activeCompany = c;
          syncSlidersToActiveCompany();
          renderCompanySelectors();
          runSimulation();
        });

        companySelectorContainer.appendChild(card);
      });
    }

    function syncSlidersToActiveCompany() {
      activeCompanyBadge.textContent = activeCompany.name;
      
      // Update variables
      simGrowth = activeCompany.historicalGrowth;
      simMargin = (activeCompany.netIncome / activeCompany.revenue) * 100;
      simTerminalPe = activeCompany.peRatio;
      simYears = 5;

      // Update Slider inputs
      growthRateSlider.value = simGrowth;
      growthRateVal.textContent = `${simGrowth}%`;
      growthRateHint.textContent = `Historical Average: ${activeCompany.historicalGrowth}%`;

      targetMarginSlider.value = simMargin.toFixed(1);
      targetMarginVal.textContent = `${simMargin.toFixed(1)}%`;
      targetMarginHint.textContent = `Current: ${((activeCompany.netIncome / activeCompany.revenue) * 100).toFixed(1)}%`;

      terminalPeSlider.value = simTerminalPe;
      terminalPeVal.textContent = `${simTerminalPe}x`;
      terminalPeHint.textContent = `Current: ${activeCompany.peRatio}x`;

      forecastYearsSlider.value = simYears;
      forecastYearsVal.textContent = `5 Years`;
    }

    function runSimulation() {
      const dataset = [];
      
      // Year 0 (Current)
      let currentYearRev = activeCompany.revenue;
      let currentYearIncome = activeCompany.netIncome;
      let currentYearMcap = activeCompany.marketCap;

      dataset.push({
        year: 0,
        revenue: currentYearRev,
        growth: 0,
        income: currentYearIncome,
        margin: (currentYearIncome / currentYearRev) * 100,
        mcap: currentYearMcap,
        discountFactor: 1.0,
        npv: currentYearMcap
      });

      // Loop for projection years
      for (let i = 1; i <= simYears; i++) {
        const growthFrac = simGrowth / 100;
        const projectedRev = dataset[i - 1].revenue * (1 + growthFrac);
        const projectedIncome = projectedRev * (simMargin / 100);
        const projectedMcap = projectedIncome * simTerminalPe;
        
        const discountFactor = 1 / Math.pow(1 + (simDiscountRate / 100), i);
        const npv = projectedMcap * discountFactor;

        dataset.push({
          year: i,
          revenue: projectedRev,
          growth: simGrowth,
          income: projectedIncome,
          margin: simMargin,
          mcap: projectedMcap,
          discountFactor: discountFactor,
          npv: npv
        });
      }

      // Render Outputs
      const terminalValuation = dataset[simYears].mcap;
      const presentValue = dataset[simYears].npv;
      const mult = terminalValuation / activeCompany.marketCap;
      const annualizedCagr = (Math.pow(mult, 1 / simYears) - 1) * 100;

      projTerminalMcap.textContent = `$${terminalValuation.toFixed(1)}B`;
      projNpv.textContent = `$${presentValue.toFixed(1)}B`;
      projMultiple.textContent = `${mult.toFixed(2)}x`;
      projCagr.textContent = `${annualizedCagr >= 0 ? '+' : ''}${annualizedCagr.toFixed(1)}%`;

      // Sim Narrative description
      const multText = mult >= 1 ? `grows by ${((mult - 1) * 100).toFixed(0)}%` : `contracts by ${((1 - mult) * 100).toFixed(0)}%`;
      simNarrative.innerHTML = `Under these conditions, ${activeCompany.name} is projected to achieve a terminal market capitalization of <strong>$${terminalValuation.toFixed(1)}B</strong> in Year ${simYears}. Discounted back to today at a <strong>${simDiscountRate}%</strong> rate, this represents a Net Present Value of <strong>$${presentValue.toFixed(1)}B</strong>.`;

      // Render Table
      renderTable(dataset);

      // Render SVG Chart
      renderChart(dataset);
    }

    function renderTable(dataset) {
      if (!tableBody) return;
      tableBody.innerHTML = '';

      dataset.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = `border-b border-border/40 hover:bg-primary/5 transition-colors ${row.year === 0 ? 'bg-primary/[0.02]' : ''}`;
        
        tr.innerHTML = `
          <td class="py-3.5 px-4 font-bold">${row.year === 0 ? 'Current (LTM)' : `Year ${row.year}`}</td>
          <td class="py-3.5 px-4">$${row.revenue.toFixed(2)}B</td>
          <td class="py-3.5 px-4 text-right text-muted">${row.year === 0 ? '--' : `${row.growth >= 0 ? '+' : ''}${row.growth}%`}</td>
          <td class="py-3.5 px-4">$${row.income.toFixed(2)}B</td>
          <td class="py-3.5 px-4">${row.margin.toFixed(1)}%</td>
          <td class="py-3.5 px-4 text-right font-bold text-primary">$${row.mcap.toFixed(2)}B</td>
          <td class="py-3.5 px-4 text-right text-muted">${row.discountFactor.toFixed(3)}</td>
          <td class="py-3.5 px-4 text-right font-semibold text-foreground">$${row.npv.toFixed(2)}B</td>
        `;
        tableBody.appendChild(tr);
      });
    }

    function renderChart(dataset) {
      if (!svgEl) return;

      const width = svgEl.clientWidth;
      const height = svgEl.clientHeight;
      const paddingLeft = 50;
      const paddingRight = 20;
      const paddingTop = 30;
      const paddingBottom = 30;

      const chartW = width - paddingLeft - paddingRight;
      const chartH = height - paddingTop - paddingBottom;

      // Find max values for scales
      const maxMcap = Math.max(...dataset.map(d => d.mcap));
      const maxRev = Math.max(...dataset.map(d => d.revenue));

      // Clear existing children that are generated dynamically
      svgGrid.innerHTML = '';
      svgDots.innerHTML = '';
      svgAxes.innerHTML = '';

      // Grid Lines (Horizontal and Vertical)
      const gridLinesCount = 4;
      for (let i = 0; i <= gridLinesCount; i++) {
        const y = paddingTop + (chartH * i) / gridLinesCount;
        
        // Horizontal Line
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', String(paddingLeft));
        line.setAttribute('y1', String(y));
        line.setAttribute('x2', String(width - paddingRight));
        line.setAttribute('y2', String(y));
        svgGrid.appendChild(line);

        // Y-axis label (Market Cap, left side)
        const labelVal = maxMcap - (maxMcap * i) / gridLinesCount;
        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', String(paddingLeft - 8));
        text.setAttribute('y', String(y + 4));
        text.setAttribute('text-anchor', 'end');
        text.textContent = `$${Math.round(labelVal)}B`;
        svgAxes.appendChild(text);
      }

      // X-axis columns
      const pointsCount = dataset.length;
      const pointsMcap = [];
      const pointsRev = [];

      dataset.forEach((d, idx) => {
        const x = paddingLeft + (chartW * idx) / (pointsCount - 1);
        
        // Calculate Y for Market Cap
        const yMcap = paddingTop + chartH - (d.mcap / maxMcap) * chartH;
        pointsMcap.push({ x, y: yMcap, val: d.mcap, revenue: d.revenue, income: d.income, year: d.year });

        // Calculate Y for Revenue
        const yRev = paddingTop + chartH - (d.revenue / maxRev) * chartH;
        pointsRev.push({ x, y: yRev, val: d.revenue });

        // Vertical Grid Line
        if (idx > 0 && idx < pointsCount - 1) {
          const vLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          vLine.setAttribute('x1', String(x));
          vLine.setAttribute('y1', String(paddingTop));
          vLine.setAttribute('x2', String(x));
          vLine.setAttribute('y2', String(paddingTop + chartH));
          svgGrid.appendChild(vLine);
        }

        // X Axis labels
        const xText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        xText.setAttribute('x', String(x));
        xText.setAttribute('y', String(height - 10));
        xText.setAttribute('text-anchor', 'middle');
        xText.textContent = d.year === 0 ? 'LTM' : `Y${d.year}`;
        svgAxes.appendChild(xText);
      });

      // Build Path strings
      let dMcap = `M ${pointsMcap[0].x} ${pointsMcap[0].y}`;
      let dRev = `M ${pointsRev[0].x} ${pointsRev[0].y}`;
      
      let areaMcap = `M ${pointsMcap[0].x} ${paddingTop + chartH} L ${pointsMcap[0].x} ${pointsMcap[0].y}`;
      let areaRev = `M ${pointsRev[0].x} ${paddingTop + chartH} L ${pointsRev[0].x} ${pointsRev[0].y}`;

      for (let i = 1; i < pointsCount; i++) {
        dMcap += ` L ${pointsMcap[i].x} ${pointsMcap[i].y}`;
        dRev += ` L ${pointsRev[i].x} ${pointsRev[i].y}`;
        
        areaMcap += ` L ${pointsMcap[i].x} ${pointsMcap[i].y}`;
        areaRev += ` L ${pointsRev[i].x} ${pointsRev[i].y}`;
      }

      areaMcap += ` L ${pointsMcap[pointsCount - 1].x} ${paddingTop + chartH} Z`;
      areaRev += ` L ${pointsRev[pointsCount - 1].x} ${paddingTop + chartH} Z`;

      // Set SVG Paths
      svgLineMcap.setAttribute('d', dMcap);
      svgLineRev.setAttribute('d', dRev);
      svgAreaMcap.setAttribute('d', areaMcap);
      svgAreaRev.setAttribute('d', areaRev);

      // Render Dots and Add Tooltip interactivity
      pointsMcap.forEach((p, index) => {
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', String(p.x));
        circle.setAttribute('cy', String(p.y));
        circle.setAttribute('r', '5');
        circle.setAttribute('fill', 'var(--background)');
        circle.setAttribute('stroke', 'var(--primary)');
        circle.setAttribute('stroke-width', '2.5');
        circle.setAttribute('class', 'cursor-pointer hover:r-7 transition-all duration-150');
        
        // Tooltip hover actions
        circle.addEventListener('mouseenter', (e) => {
          tooltipYear.textContent = p.year === 0 ? 'Current (LTM)' : `Year ${p.year}`;
          tooltipMcap.textContent = `$${p.val.toFixed(2)}B`;
          tooltipRev.textContent = `$${p.revenue.toFixed(2)}B`;
          tooltipIncome.textContent = `$${p.income.toFixed(2)}B`;
          
          // Position tooltip
          const rect = svgEl.getBoundingClientRect();
          const tooltipW = chartTooltip.clientWidth || 150;
          const tooltipH = chartTooltip.clientHeight || 110;
          
          let leftPos = p.x - tooltipW / 2;
          let topPos = p.y - tooltipH - 12;

          if (leftPos < 10) leftPos = 10;
          if (leftPos + tooltipW > rect.width - 10) leftPos = rect.width - tooltipW - 10;
          if (topPos < 10) topPos = p.y + 12;

          chartTooltip.style.left = `${leftPos}px`;
          chartTooltip.style.top = `${topPos}px`;
          chartTooltip.classList.remove('hidden');
        });

        circle.addEventListener('mouseleave', () => {
          chartTooltip.classList.add('hidden');
        });

        svgDots.appendChild(circle);
      });
    }

    // Initialize application
    init();
  </script>
</Layout>
