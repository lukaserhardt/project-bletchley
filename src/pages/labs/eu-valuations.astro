    // State
    let activeCompany = COMPANIES_DATA[0];
    let focusMetric = 'mcap'; // 'mcap' or 'revenue'
    let timeWindow = 'all'; // 'all', 'post-covid', 'recent', 'short'
    let regressionModel = '1'; // '1', '2', '3', 'exponential'
