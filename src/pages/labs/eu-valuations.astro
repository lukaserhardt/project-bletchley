    // Matrix Solver for Gaussian Elimination
    function solveMatrix(A, B) {
      const n = B.length;
      for (let i = 0; i < n; i++) {
        let maxEl = Math.abs(A[i][i]);
        let maxRow = i;
        for (let k = i + 1; k < n; k++) {
          if (Math.abs(A[k][i]) > maxEl) {
            maxEl = Math.abs(A[k][i]);
            maxRow = k;
          }
        }
        for (let k = i; k < n; k++) {
          const tmp = A[maxRow][k];
          A[maxRow][k] = A[i][k];
          A[i][k] = tmp;
        }
        const tmp = B[maxRow];
        B[maxRow] = B[i];
        B[i] = tmp;

        for (let k = i + 1; k < n; k++) {
          const c = -A[k][i] / A[i][i];
          for (let j = i; j < n; j++) {
            if (i === j) {
              A[k][j] = 0;
            } else {
              A[k][j] += c * A[i][j];
            }
          }
          B[k] += c * B[i];
        }
      }

      const x = new Array(n).fill(0);
      for (let i = n - 1; i >= 0; i--) {
        x[i] = B[i] / A[i][i];
        for (let k = i - 1; k >= 0; k--) {
          B[k] -= A[k][i] * x[i];
        }
      }
      return x;
    }

    // Fit Polynomial on points {x, y}
    function fitPolynomial(points, degree) {
      const n = points.length;
      const matrixSize = degree + 1;
      const A = Array.from({ length: matrixSize }, () => new Array(matrixSize).fill(0));
      const B = new Array(matrixSize).fill(0);

      for (let row = 0; row < matrixSize; row++) {
        for (let col = 0; col < matrixSize; col++) {
          let sumX = 0;
          for (let i = 0; i < n; i++) {
            sumX += Math.pow(points[i].x, row + col);
          }
          A[row][col] = sumX;
        }
        let sumY = 0;
        for (let i = 0; i < n; i++) {
          sumY += points[i].y * Math.pow(points[i].x, row);
        }
        B[row] = sumY;
      }
      try {
        return solveMatrix(A, B);
      } catch (err) {
        // Fallback to simpler linear if matrix is singular
        console.warn('Matrix singular, falling back to simple linear trend');
        return [points[0].y, 0];
      }
    }

    // Fit Exponential Curve y = a * e^(b * x) using log transformation
    function fitExponential(points) {
      const logPoints = points.map(p => ({ x: p.x, y: Math.log(p.y > 0 ? p.y : 0.01) }));
      const coeffs = fitPolynomial(logPoints, 1); // Linear fit on log values
      return {
        a: Math.exp(coeffs[0]),
        b: coeffs[1]
      };
    }

    function init() {
      renderCompanySelectors();
      calculateOverviewMetrics();
      setupEventListeners();
      runExtrapolation();
    }

    function calculateOverviewMetrics() {
      // Combined Market Cap in EUR of 2026 LTM
      const totalCap = COMPANIES_DATA.reduce((acc, c) => acc + c.history[c.history.length - 1].mcap, 0);
      // Rough Average PE ratio as of 2026
      const avgPe = 52.0; // Typical sector average
      
      if (combinedCapEl) combinedCapEl.textContent = `€${totalCap.toFixed(1)}B`;
      if (avgPeEl) avgPeEl.textContent = `${avgPe.toFixed(1)}x`;
    }

    function renderCompanySelectors() {
      if (!companySelectorContainer) return;
      companySelectorContainer.innerHTML = '';

      COMPANIES_DATA.forEach(c => {
        const ltmPoint = c.history[c.history.length - 1];
        const card = document.createElement('button');
        card.className = `w-full text-left p-3.5 rounded-lg border text-xs font-mono transition-all cursor-pointer flex flex-col justify-between gap-1.5 ${
          activeCompany.id === c.id 
            ? 'border-primary bg-primary/5 shadow-inner' 
            : 'border-border bg-background/50 hover:border-border/80 hover:bg-background/80'
        }`;
        
        card.innerHTML = `
          <div class="flex items-center justify-between">
            <span class="font-bold text-foreground text-sm">${c.name}</span>
            <span class="text-[10px] text-muted bg-border/40 px-1.5 py-0.5 rounded uppercase font-semibold">${c.country}</span>
          </div>
          <p class="text-[10px] text-muted line-clamp-1">${c.description}</p>
          <div class="grid grid-cols-2 gap-2 mt-1 text-[10px] text-muted border-t border-border/20 pt-2">
            <div>Mkt Cap: <span class="text-foreground font-semibold">€${ltmPoint.mcap}B</span></div>
            <div>Revenue: <span class="text-foreground font-semibold">€${ltmPoint.revenue}B</span></div>
          </div>
        `;

        card.addEventListener('click', () => {
          activeCompany = c;
          activeCompanyBadge.textContent = c.name;
          renderCompanySelectors();
          runExtrapolation();
        });

        companySelectorContainer.appendChild(card);
      });
    }

    function setupEventListeners() {
      historicalWindowSelect.addEventListener('change', (e) => {
        timeWindow = e.target.value;
        runExtrapolation();
      });

      regressionModelSelect.addEventListener('change', (e) => {
        regressionModel = e.target.value;
        runExtrapolation();
      });

      forecastYearsSlider.addEventListener('input', (e) => {
        simYears = parseInt(e.target.value);
        forecastYearsVal.textContent = `${simYears} Year${simYears > 1 ? 's' : ''}`;
        runExtrapolation();
      });

      discountRateSlider.addEventListener('input', (e) => {
        discountRate = parseFloat(e.target.value);
        discountRateVal.textContent = `${discountRate.toFixed(1)}%`;
        runExtrapolation();
      });

      metricMcapBtn.addEventListener('click', () => {
        focusMetric = 'mcap';
        metricMcapBtn.className = 'text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white';
        metricRevBtn.className = 'text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground';
        runExtrapolation();
      });

      metricRevBtn.addEventListener('click', () => {
        focusMetric = 'revenue';
        metricRevBtn.className = 'text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white';
        metricMcapBtn.className = 'text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground';
        runExtrapolation();
      });

      resetBtn.addEventListener('click', () => {
        timeWindow = 'all';
        regressionModel = '1';
        simYears = 5;
        discountRate = 8.5;
        focusMetric = 'mcap';

        historicalWindowSelect.value = timeWindow;
        regressionModelSelect.value = regressionModel;
        forecastYearsSlider.value = simYears;
        forecastYearsVal.textContent = `5 Years`;
        discountRateSlider.value = discountRate;
        discountRateVal.textContent = `8.5%`;

        metricMcapBtn.className = 'text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white';
        metricRevBtn.className = 'text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground';

        runExtrapolation();
      });

      window.addEventListener('resize', () => {
        runExtrapolation();
      });
    }

    function runExtrapolation() {
      // 1. Filter historical points based on timeWindow
      const allHistory = activeCompany.history;
      let startYear = 2019;
      if (timeWindow === 'post-covid') startYear = 2021;
      else if (timeWindow === 'recent') startYear = 2023;
      else if (timeWindow === 'short') startYear = 2024;

      const calibrationPoints = allHistory.filter(d => d.year >= startYear);
      
      // Map data into normalized forms (x = year - 2019) to optimize conditioning
      const fitData = calibrationPoints.map(d => ({
        x: d.year - 2019,
        y: focusMetric === 'mcap' ? d.mcap : d.revenue
      }));

      // 2. Perform regression model fitting
      let predictor;
      let modelExpression = '';
      
      if (regressionModel === 'exponential') {
        const fit = fitExponential(fitData);
        predictor = (x) => fit.a * Math.exp(fit.b * x);
        modelExpression = `y = ${fit.a.toFixed(3)} * e^(${fit.b.toFixed(4)} * x)`;
      } else {
        const deg = parseInt(regressionModel);
        const coeffs = fitPolynomial(fitData, deg); // coeffs[0] + coeffs[1]*x + coeffs[2]*x^2 + coeffs[3]*x^3
        predictor = (x) => {
          let sum = 0;
          for (let i = 0; i <= deg; i++) {
            sum += coeffs[i] * Math.pow(x, i);
          }
          return sum;
        };
        // Build pretty model description
        const terms = coeffs.map((c, i) => i === 0 ? c.toFixed(2) : `${c >= 0 ? '+' : ''}${c.toFixed(3)}x^${i}`);
        modelExpression = `y = ${terms.join(' ')}`;
      }

      // Calculate R2 value (goodness of fit)
      const r2 = calculateR2(fitData, predictor);
      fitR2Val.textContent = `Model fit (R²): ${isNaN(r2) ? 'N/A' : r2.toFixed(3)}`;

      // 3. Generate Year-by-Year list (2019 to 2026 + forecast horizon)
      const results = [];
      
      // Historical base (all years from 2019 to 2026)
      allHistory.forEach(d => {
        const xVal = d.year - 2019;
        const actualVal = focusMetric === 'mcap' ? d.mcap : d.revenue;
        const fittedVal = predictor(xVal);
        
        results.push({
          year: d.year,
          actual: actualVal,
          extrapolated: fittedVal,
          type: d.year >= startYear ? 'Calibration Base' : 'Historical Out-of-Sample',
          delta: 0,
          discountFactor: 1.0,
          npv: actualVal
        });
      });

      // Projection years (2027 to 2026 + simYears)
      const currentVal2026 = focusMetric === 'mcap' ? allHistory[allHistory.length - 1].mcap : allHistory[allHistory.length - 1].revenue;
      let prevVal = results[results.length - 1].extrapolated;

      for (let i = 1; i <= simYears; i++) {
        const targetYear = 2026 + i;
        const xVal = targetYear - 2019;
        const projectedVal = Math.max(0.01, predictor(xVal)); // prevent negative values

        const deltaPercent = ((projectedVal - prevVal) / prevVal) * 100;
        const discountFactor = 1 / Math.pow(1 + (discountRate / 100), i);
        const npv = projectedVal * discountFactor;

        results.push({
          year: targetYear,
          actual: null,
          extrapolated: projectedVal,
          type: 'Projected Extrapolation',
          delta: deltaPercent,
          discountFactor: discountFactor,
          npv: npv
        });

        prevVal = projectedVal;
      }

      // 4. Update Summary Cards & Narrative
      const terminalYear = 2026 + simYears;
      const terminalVal = results[results.length - 1].extrapolated;
      const terminalNpv = results[results.length - 1].npv;
      const multipleVal = terminalVal / currentVal2026;
      const cagr = (Math.pow(multipleVal, 1 / simYears) - 1) * 100;

      projTerminalYearLbl.textContent = `Proj. ${terminalYear} ${focusMetric === 'mcap' ? 'Cap' : 'Rev'}`;
      projTerminalVal.textContent = `€${terminalVal.toFixed(2)}B`;
      projNpv.textContent = `€${terminalNpv.toFixed(2)}B`;
      projMultiple.textContent = `${multipleVal.toFixed(2)}x`;
      projCagr.textContent = `${cagr >= 0 ? '+' : ''}${cagr.toFixed(1)}%`;

      const metricLabel = focusMetric === 'mcap' ? 'market cap' : 'annual revenue';
      simNarrative.innerHTML = `
        The model fits trend <strong>${modelExpression}</strong> on data from <strong>${startYear} to 2026</strong>. 
        It projects that ${activeCompany.name}'s ${metricLabel} will reach <strong>€${terminalVal.toFixed(2)}B</strong> in 
        <strong>${terminalYear}</strong>. Present value of this terminal sum (discounted at <strong>${discountRate}%</strong>) is <strong>€${terminalNpv.toFixed(2)}B</strong>.
      `;

      chartTitle.textContent = `${activeCompany.name} - ${focusMetric === 'mcap' ? 'Market Capitalization' : 'Revenue'} Extrapolation`;

      // 5. Render Table & SVG Chart
      renderTable(results);
      renderSVGChart(results, startYear);
    }

    function calculateR2(data, predictor) {
      const yMean = data.reduce((sum, d) => sum + d.y, 0) / data.length;
      let ssTotal = 0;
      let ssRes = 0;
      data.forEach(d => {
        ssTotal += Math.pow(d.y - yMean, 2);
        ssRes += Math.pow(d.y - predictor(d.x), 2);
      });
      return 1 - (ssRes / (ssTotal || 1));
    }

    function renderTable(results) {
      if (!tableBody) return;
      tableBody.innerHTML = '';

      results.forEach((row, idx) => {
        let deltaStr = '--';
        if (row.type === 'Projected Extrapolation') {
          deltaStr = `${row.delta >= 0 ? '+' : ''}${row.delta.toFixed(1)}%`;
        } else if (idx > 0 && results[idx - 1].actual) {
          const actDelta = ((row.actual - results[idx - 1].actual) / results[idx - 1].actual) * 100;
          deltaStr = `${actDelta >= 0 ? '+' : ''}${actDelta.toFixed(1)}% (Hist)`;
        }

        const isProj = row.type === 'Projected Extrapolation';
        const displayVal = row.actual !== null ? row.actual : row.extrapolated;

        const tr = document.createElement('tr');
        tr.className = `border-b border-border/40 hover:bg-primary/5 transition-colors ${isProj ? 'bg-primary/[0.01]' : 'text-muted-foreground'}`;
        
        tr.innerHTML = `
          <td class="py-3 px-4 font-bold ${isProj ? 'text-primary' : 'text-foreground'}">${row.year}</td>
          <td class="py-3 px-4 font-semibold">${focusMetric === 'mcap' ? 'Market Cap' : 'Revenue'}</td>
          <td class="py-3 px-4 text-[10px] uppercase font-mono">${row.type}</td>
          <td class="py-3 px-4 text-right font-bold text-foreground">€${displayVal.toFixed(2)}B</td>
          <td class="py-3 px-4 text-right">${deltaStr}</td>
          <td class="py-3 px-4 text-right">${row.discountFactor.toFixed(3)}</td>
          <td class="py-3 px-4 text-right font-semibold ${isProj ? 'text-primary' : 'text-foreground'}">€${row.npv.toFixed(2)}B</td>
        `;
        tableBody.appendChild(tr);
      });
    }

    function renderSVGChart(results, calibrationStartYear) {
      if (!svgEl) return;

      const width = svgEl.clientWidth;
      const height = svgEl.clientHeight;
      const paddingLeft = 50;
      const paddingRight = 30;
      const paddingTop = 20;
      const paddingBottom = 30;

      const chartW = width - paddingLeft - paddingRight;
      const chartH = height - paddingTop - paddingBottom;

      // Find max extrapolated/actual value to scale the Y axis
      const maxVal = Math.max(...results.map(d => Math.max(d.actual || 0, d.extrapolated || 0))) * 1.1;

      // Clear dynamic SVG elements
      svgGrid.innerHTML = '';
      svgDots.innerHTML = '';
      svgAxes.innerHTML = '';

      // Draw Grid Lines (Horizontal)
      const horizontalGridCount = 4;
      for (let i = 0; i <= horizontalGridCount; i++) {
        const y = paddingTop + (chartH * i) / horizontalGridCount;
        
        // Grid Line
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', String(paddingLeft));
        line.setAttribute('y1', String(y));
        line.setAttribute('x2', String(width - paddingRight));
        line.setAttribute('y2', String(y));
        svgGrid.appendChild(line);

        // Y-axis Label
        const labelVal = maxVal - (maxVal * i) / horizontalGridCount;
        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', String(paddingLeft - 8));
        text.setAttribute('y', String(y + 4));
        text.setAttribute('text-anchor', 'end');
        text.textContent = `€${Math.round(labelVal)}B`;
        svgAxes.appendChild(text);
      }

      // X-Axis Columns and Coordinate mapping
      const pointsCount = results.length;
      const points = [];

      results.forEach((d, idx) => {
        const x = paddingLeft + (chartW * idx) / (pointsCount - 1);
        const yActual = d.actual !== null ? paddingTop + chartH - (d.actual / maxVal) * chartH : null;
        const yExtrapolated = paddingTop + chartH - (d.extrapolated / maxVal) * chartH;

        points.push({
          x,
          yActual,
          yExtrapolated,
          year: d.year,
          actual: d.actual,
          extrapolated: d.extrapolated,
          type: d.type
        });

        // Vertical Grid Line (every 2 years to keep clean)
        if (idx % 2 === 0) {
          const vLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          vLine.setAttribute('x1', String(x));
          vLine.setAttribute('y1', String(paddingTop));
          vLine.setAttribute('x2', String(x));
          vLine.setAttribute('y2', String(paddingTop + chartH));
          svgGrid.appendChild(vLine);
        }

        // X-axis Year Label
        if (idx === 0 || idx === pointsCount - 1 || d.year === 2026 || d.year % 3 === 0) {
          const xText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          xText.setAttribute('x', String(x));
          xText.setAttribute('y', String(height - 8));
          xText.setAttribute('text-anchor', 'middle');
          xText.textContent = String(d.year);
          svgAxes.appendChild(xText);
        }
      });

      // Split coordinates into:
      // A. Historical Fitted (up to year 2026)
      // B. Projected Extrapolation (2026 onwards)
      const historicalPoints = points.filter(p => p.year <= 2026);
      const projectedPoints = points.filter(p => p.year >= 2026);

      // Build Path strings
      let dFitted = `M ${historicalPoints[0].x} ${historicalPoints[0].yExtrapolated}`;
      let areaFitted = `M ${historicalPoints[0].x} ${paddingTop + chartH} L ${historicalPoints[0].x} ${historicalPoints[0].yExtrapolated}`;
      
      historicalPoints.forEach(p => {
        dFitted += ` L ${p.x} ${p.yExtrapolated}`;
        areaFitted += ` L ${p.x} ${p.yExtrapolated}`;
      });

      let dProjected = `M ${projectedPoints[0].x} ${projectedPoints[0].yExtrapolated}`;
      
      projectedPoints.forEach(p => {
        dProjected += ` L ${p.x} ${p.yExtrapolated}`;
        areaFitted += ` L ${p.x} ${p.yExtrapolated}`;
      });

      areaFitted += ` L ${projectedPoints[projectedPoints.length - 1].x} ${paddingTop + chartH} Z`;

      // Set SVG Paths
      svgLineFitted.setAttribute('d', dFitted);
      svgLineProjected.setAttribute('d', dProjected);
      svgAreaFitted.setAttribute('d', areaFitted);

      // Draw historical actual points as glowing circles
      points.forEach(p => {
        if (p.actual !== null) {
          const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          circle.setAttribute('cx', String(p.x));
          circle.setAttribute('cy', String(p.yActual));
          circle.setAttribute('r', '5');
          circle.setAttribute('fill', p.year >= calibrationStartYear ? 'var(--primary)' : 'var(--color-muted, #9ca3af)');
          circle.setAttribute('stroke', 'var(--background)');
          circle.setAttribute('stroke-width', '1.5');
          circle.setAttribute('class', 'cursor-pointer hover:r-7 transition-all duration-150');

          circle.addEventListener('mouseenter', () => {
            tooltipYear.textContent = `${p.year} (Actual)`;
            tooltipMetricLabel.textContent = focusMetric === 'mcap' ? 'Market Cap:' : 'Revenue:';
            tooltipMetricVal.textContent = `€${p.actual.toFixed(2)}B`;
            tooltipTypeVal.textContent = p.year >= calibrationStartYear ? 'Used in Model Fit' : 'Prior History';
            showTooltip(p.x, p.yActual);
          });

          circle.addEventListener('mouseleave', hideTooltip);
          svgDots.appendChild(circle);
        } else {
          // Draw projected dots
          const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          circle.setAttribute('cx', String(p.x));
          circle.setAttribute('cy', String(p.yExtrapolated));
          circle.setAttribute('r', '4');
          circle.setAttribute('fill', 'var(--background)');
          circle.setAttribute('stroke', 'var(--primary)');
          circle.setAttribute('stroke-width', '2');
          circle.setAttribute('class', 'cursor-pointer hover:r-6 transition-all duration-150');

          circle.addEventListener('mouseenter', () => {
            tooltipYear.textContent = `${p.year} (Projected)`;
            tooltipMetricLabel.textContent = focusMetric === 'mcap' ? 'Projected Cap:' : 'Projected Rev:';
            tooltipMetricVal.textContent = `€${p.extrapolated.toFixed(2)}B`;
            tooltipTypeVal.textContent = 'Model Extrapolation';
            showTooltip(p.x, p.yExtrapolated);
          });

          circle.addEventListener('mouseleave', hideTooltip);
          svgDots.appendChild(circle);
        }
      });
    }

    function showTooltip(x, y) {
      const rect = svgEl.getBoundingClientRect();
      const tooltipW = chartTooltip.clientWidth || 150;
      const tooltipH = chartTooltip.clientHeight || 90;

      let leftPos = x - tooltipW / 2;
      let topPos = y - tooltipH - 12;

      if (leftPos < 10) leftPos = 10;
      if (leftPos + tooltipW > rect.width - 10) leftPos = rect.width - tooltipW - 10;
      if (topPos < 10) topPos = y + 12;

      chartTooltip.style.left = `${leftPos}px`;
      chartTooltip.style.top = `${topPos}px`;
      chartTooltip.classList.remove('hidden');
    }

    function hideTooltip() {
      chartTooltip.classList.add('hidden');
    }

    // Initialize application
    init();
  </script>
</Layout>
