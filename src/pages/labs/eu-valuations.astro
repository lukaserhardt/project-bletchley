---
import Layout from '../../layouts/Layout.astro';
import { TrendingUp } from '@lucide/astro';
---

<Layout title="Project Bletchley - EU Tech Valuations & Projections" description="Compare valuations of top European technology companies, select historical windows, and model future projections using customizable polynomial regression models.">
  <div class="space-y-8 flex-grow flex flex-col relative">
    
    <!-- Hero Glow Blobs -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground">Labs</span>
      <span>/</span>
      <span class="text-foreground font-bold">EU Tech Valuations</span>
    </nav>

    <!-- Header -->
    <header class="border-b border-border pb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="flex items-start gap-4">
        <div class="p-3 bg-primary/10 rounded-xl text-primary mt-1 border border-primary/20 shrink-0">
          <TrendingUp class="w-8 h-8" />
        </div>
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight">EU Tech Valuations & Regression Extrapolations</h1>
          <p class="text-sm text-muted mt-2">
            Fit regression curves (Linear, Quadratic, Cubic, Exponential) to historical figures for Europe's largest tech firms, and project growth paths.
          </p>
        </div>
      </div>
      <div class="text-xs font-mono bg-card border border-border px-3 py-1.5 rounded-md text-muted self-start md:self-auto">
        Currency: <span class="text-foreground font-semibold">EUR (€)</span>
      </div>
    </header>

    <!-- Main Workspace Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      <!-- Company Selector (Left Column - 4 cols on lg) -->
      <section class="lg:col-span-4 border border-border bg-card rounded-xl p-5 flex flex-col justify-between shadow-sm space-y-6">
        <div>
          <h2 class="font-mono text-xs font-bold uppercase tracking-wider border-b border-border pb-2 text-foreground mb-4">
            Select Company
          </h2>
          <div class="space-y-2.5 max-h-[380px] overflow-y-auto pr-1 scrollbar-thin" id="company-selector-container">
            <!-- Dynamically populated via JS -->
            <div class="text-center py-8 text-muted font-mono text-xs">Loading companies...</div>
          </div>
        </div>

        <div class="border-t border-border pt-4 space-y-3">
          <h3 class="font-mono text-[10px] font-semibold uppercase tracking-wider text-muted">Comparative Overview (LTM)</h3>
          <div class="grid grid-cols-2 gap-2 text-xs font-mono">
            <div class="bg-background/50 p-2.5 rounded border border-border/30">
              <span class="text-muted block text-[9px] uppercase">Combined Cap</span>
              <span class="text-foreground font-bold" id="combined-cap">--</span>
            </div>
            <div class="bg-background/50 p-2.5 rounded border border-border/30">
              <span class="text-muted block text-[9px] uppercase">Avg P/E Ratio</span>
              <span class="text-foreground font-bold" id="avg-pe">--</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Extrapolation Control Panel (Right Column - 8 cols on lg) -->
      <section class="lg:col-span-8 border border-border bg-card rounded-xl p-6 flex flex-col justify-between shadow-sm space-y-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl pointer-events-none"></div>
        
        <div>
          <div class="flex items-center justify-between border-b border-border pb-2 mb-6">
            <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground">
              Regression & Projection Parameters
            </h2>
            <span class="text-xs font-mono px-2.5 py-0.5 bg-primary/10 border border-primary/20 text-primary rounded-full font-semibold" id="active-company-badge">
              ASML
            </span>
          </div>

          <!-- Parameter Controls -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <!-- Historical Timeframe Selector -->
            <div class="space-y-2">
              <label for="historical-window" class="font-mono text-xs uppercase tracking-wider text-muted block font-semibold">
                Historical Calibration Base
              </label>
              <select 
                id="historical-window" 
                class="w-full bg-background border border-border rounded-md px-3 py-2 text-xs font-mono text-foreground focus:border-primary focus:outline-none"
              >
                <option value="all">All Available (2019–2026)</option>
                <option value="post-covid">Post-COVID (2021–2026)</option>
                <option value="recent">Recent Growth (2023–2026)</option>
                <option value="short">Short Term (2024–2026)</option>
              </select>
              <span class="text-[10px] text-muted font-mono block">Time window to fit the regression trend line.</span>
            </div>

            <!-- Extrapolation Method Selector -->
            <div class="space-y-2">
              <label for="regression-model" class="font-mono text-xs uppercase tracking-wider text-muted block font-semibold">
                Extrapolation Model
              </label>
              <select 
                id="regression-model" 
                class="w-full bg-background border border-border rounded-md px-3 py-2 text-xs font-mono text-foreground focus:border-primary focus:outline-none"
              >
                <option value="1">Linear Regression (Degree 1)</option>
                <option value="2">Quadratic Polynomial (Degree 2)</option>
                <option value="3">Cubic Polynomial (Degree 3)</option>
                <option value="exponential">Exponential Growth Curve</option>
              </select>
              <span class="text-[10px] text-muted font-mono block">Mathematical function to project into future years.</span>
            </div>

            <!-- Projected Years Slider -->
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs font-mono">
                <label for="forecast-years" class="uppercase tracking-wider text-muted">Projected Horizon</label>
                <span id="forecast-years-val" class="font-bold text-foreground">5 Years</span>
              </div>
              <input
                type="range"
                id="forecast-years"
                min="1"
                max="10"
                value="5"
                step="1"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <span class="text-[10px] text-muted font-mono block">Model future path up to 2036.</span>
            </div>

            <!-- Chart Metric Selector (Toggle between Cap and Rev) -->
            <div class="space-y-2">
              <label class="font-mono text-xs uppercase tracking-wider text-muted block font-semibold">
                Chart Focus Metric
              </label>
              <div class="grid grid-cols-2 gap-2 bg-background border border-border p-1 rounded-md">
                <button 
                  id="btn-metric-mcap" 
                  class="text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center font-bold bg-primary text-white"
                >
                  Market Cap
                </button>
                <button 
                  id="btn-metric-rev" 
                  class="text-xs font-mono py-1 rounded transition-colors cursor-pointer text-center text-muted hover:text-foreground"
                >
                  Revenue
                </button>
              </div>
            </div>

            <!-- Discount Rate (NPV) -->
            <div class="space-y-1.5 md:col-span-2 pt-2 border-t border-border/40">
              <div class="flex justify-between text-xs font-mono">
                <label for="discount-rate" class="uppercase tracking-wider text-muted font-semibold text-primary">Discount Rate (NPV Calculation)</label>
                <span id="discount-rate-val" class="font-bold text-primary">8.5%</span>
              </div>
              <input
                type="range"
                id="discount-rate"
                min="3"
                max="20"
                value="8.5"
                step="0.5"
                class="w-full h-1 bg-border appearance-none cursor-pointer accent-primary"
              />
              <span class="text-[10px] text-muted font-mono block">Used to calculate the Net Present Value (€) of future projections.</span>
            </div>
          </div>
        </div>

        <!-- Reset & Narrative Info -->
        <div class="flex items-center justify-between pt-2 border-t border-border/40 text-xs font-mono">
          <span class="text-muted" id="fit-r2-val">Model fit: computing...</span>
          <button
            id="reset-simulation-btn"
            class="border border-border bg-background hover:bg-card hover:border-primary px-3 py-1.5 rounded text-xs transition-colors cursor-pointer text-foreground flex items-center gap-1.5"
          >
            Reset to Defaults
          </button>
        </div>
      </section>

    </div>

    <!-- Projection Output Graph & Table -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      <!-- Visual Valuation Projection Graph -->
      <section class="lg:col-span-8 border border-border bg-card rounded-xl p-6 flex flex-col shadow-sm">
        <div class="flex items-center justify-between border-b border-border pb-4 mb-6">
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground" id="chart-title">
            Valuation Fit & Extrapolation Path
          </h2>
          
