            </tr>
          </thead>
          <tbody id="projection-table-body" class="divide-y divide-border/40 text-foreground">
            <!-- Dynamically populated -->
          </tbody>
        </table>
      </div>
    </section>

  </div>

  <script>
    // Real Historical & Current Financial Data for EU Tech (in EUR Billions)
    const COMPANIES_DATA = [
