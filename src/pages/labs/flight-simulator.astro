---
import Layout from '../../layouts/Layout.astro';
import { Plane, Compass, Volume2, VolumeX, Play, Pause, Zap, Trophy, ShieldAlert, Camera, Flame, Navigation, Maximize, X, HelpCircle, Bot } from '@lucide/astro';
---

<Layout title="Project Bletchley - 16-Bit Flight Simulator" description="Retro 16-bit Mode-7 3D flight simulator featuring realistic F-14 jet physics, 50,000 FT service ceiling, repeating airbases, ILS glide slope approach lights, and Autoland autopilot.">
  <div class="space-y-8 flex-grow flex flex-col relative">
    
    <!-- Hero Background Glow Blobs -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground">Labs</span>
      <span>/</span>
      <span class="text-foreground font-bold">16-Bit Flight Simulator</span>
    </nav>

    <!-- Page Header -->
    <header class="border-b border-border pb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-start gap-4">
        <div class="p-3 bg-primary/10 rounded-xl text-primary mt-1 border border-primary/20 shrink-0">
          <Plane class="w-8 h-8" />
        </div>
        <div>
          <div class="flex items-center gap-2">
            <h1 class="text-3xl font-extrabold tracking-tight">16-Bit Flight Simulator</h1>
            <span class="bg-primary/20 text-primary font-mono text-xs font-semibold px-2.5 py-0.5 rounded-full border border-primary/30">
              Node 11 // Mode-7 3D Engine
            </span>
          </div>
          <p class="text-sm text-muted mt-2 max-w-2xl leading-relaxed">
            Authentic F-14 Tomcat physics, 50,000 FT stratospheric ceiling, repeating runway airbases with ILS approach beacons, and full Autoland autopilot support.
          </p>
        </div>
      </div>
    </header>

    <!-- STAGE 1: Pre-Flight Configuration Card (On Page) -->
    <main class="max-w-4xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Pre-Flight Configuration Form -->
      <div class="lg:col-span-7 border border-border bg-card p-6 sm:p-8 rounded-2xl space-y-6 shadow-lg">
        
        <div class="border-b border-border pb-4 flex items-center justify-between">
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-foreground flex items-center gap-2">
            <span>⚙️ Pre-Flight Avionics & Setup</span>
          </h2>
          <span class="text-xs font-mono text-primary font-semibold">Ready to Launch</span>
        </div>

        <!-- Setup Form Options -->
        <div class="space-y-6">
          
          <!-- 1. Flight Mission Selection -->
          <div class="space-y-3">
            <label class="block font-mono text-xs uppercase tracking-wider text-muted font-bold">1. Select Flight Mission</label>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 font-mono text-xs">
              <button
                type="button"
                id="setup-mission-free"
                class="setup-mission-btn border-2 border-primary bg-primary/15 text-primary p-3 rounded-xl transition-all font-bold cursor-pointer text-left space-y-1 shadow-sm"
              >
                <div class="text-sm">🛩️ Free Flight</div>
                <div class="text-[11px] text-primary/80 font-sans font-normal">Explore 50k FT world</div>
              </button>

              <button
                type="button"
                id="setup-mission-rings"
                class="setup-mission-btn border border-border bg-background hover:border-primary text-foreground p-3 rounded-xl transition-all font-bold cursor-pointer text-left space-y-1 shadow-sm"
              >
                <div class="text-sm text-amber-400">🎯 Ring Course</div>
                <div class="text-[11px] text-muted font-sans font-normal">Fly through 8 target rings</div>
              </button>

              <button
                type="button"
                id="setup-mission-landing"
                class="setup-mission-btn border border-border bg-background hover:border-primary text-foreground p-3 rounded-xl transition-all font-bold cursor-pointer text-left space-y-1 shadow-sm"
              >
                <div class="text-sm text-emerald-400">🛬 Runway Landing</div>
                <div class="text-[11px] text-muted font-sans font-normal">Final approach to Airbase</div>
              </button>
            </div>
          </div>

          <!-- 2. Atmosphere & Sky Theme -->
          <div class="space-y-3 pt-2">
            <label class="block font-mono text-xs uppercase tracking-wider text-muted font-bold">2. Sky & Environment Theme</label>
            <div class="grid grid-cols-3 gap-2.5 font-mono text-xs">
              <button type="button" data-sky="day" class="setup-sky-btn border-2 border-primary bg-primary/15 text-primary p-2.5 rounded-xl transition-all font-bold cursor-pointer text-center">☀️ Daylight</button>
              <button type="button" data-sky="sunset" class="setup-sky-btn border border-border bg-background text-muted p-2.5 rounded-xl transition-all cursor-pointer text-center">🌅 Sunset</button>
              <button type="button" data-sky="night" class="setup-sky-btn border border-border bg-background text-muted p-2.5 rounded-xl transition-all cursor-pointer text-center">🌌 Cyber Night</button>
            </div>
          </div>

          <!-- 3. Sound Toggle Option -->
          <div class="flex items-center justify-between border-t border-border/60 pt-4 font-mono text-xs">
            <span class="text-muted">Synthesizer Sound FX:</span>
            <button
              type="button"
              id="setup-sound-btn"
              class="border border-border bg-background hover:border-primary px-3 py-1.5 rounded-lg text-foreground font-bold transition-all cursor-pointer flex items-center gap-1.5"
            >
              <Volume2 id="setup-sound-icon-on" class="w-4 h-4 text-primary" />
              <VolumeX id="setup-sound-icon-off" class="w-4 h-4 text-muted hidden" />
              <span id="setup-sound-text">SFX Enabled</span>
            </button>
          </div>

        </div>

        <!-- BIG LAUNCH BUTTON -->
        <div class="pt-4 border-t border-border">
          <button
            id="launch-fullscreen-btn"
            type="button"
            class="w-full bg-primary hover:bg-primary/90 text-white font-mono font-extrabold py-4 px-6 rounded-2xl transition-all active:scale-[0.98] shadow-2xl cursor-pointer text-base tracking-wider uppercase flex items-center justify-center gap-3 border border-primary/40 select-none"
          >
            <Play class="w-6 h-6 fill-white" />
            <span>🚀 LAUNCH FULLSCREEN FLIGHT</span>
          </button>
        </div>

      </div>

      <!-- Flight Operations & Autoland Manual Card -->
      <div class="lg:col-span-5 border border-border bg-card p-6 rounded-2xl space-y-5 shadow-lg font-mono text-xs">
        <div class="border-b border-border pb-3 flex items-center justify-between">
          <h3 class="font-bold text-amber-400 uppercase tracking-wider flex items-center gap-2">
            <HelpCircle class="w-4 h-4 text-amber-400" />
            <span>Flight & Autoland Manual</span>
          </h3>
          <span class="text-[10px] text-muted">v0.9.0</span>
        </div>

        <!-- Autoland Autopilot Info -->
        <div class="space-y-2 bg-indigo-950/40 border border-indigo-500/40 p-3.5 rounded-xl">
          <div class="font-bold text-indigo-400 uppercase tracking-wider text-[11px] flex items-center gap-1.5">
            <Bot class="w-4 h-4 text-indigo-400" />
            <span>🤖 Autoland Autopilot System</span>
          </div>
          <p class="text-[11px] text-indigo-200/90 leading-relaxed font-sans">
            Tap <strong>[🤖 AUTOLAND]</strong> on the HUD at any time! The autopilot will lock onto the nearest airbase runway, align heading, manage throttle to 140 KTS, deploy gear & flaps, and execute a textbook touchdown automatically.
          </p>
        </div>

        <!-- Safe Landing Parameters -->
        <div class="space-y-2 bg-emerald-950/30 border border-emerald-500/30 p-3.5 rounded-xl">
          <div class="font-bold text-emerald-400 uppercase tracking-wider text-[11px] flex items-center gap-1.5">
            <span>🛬 Manual Landing Parameters</span>
          </div>
          <ul class="space-y-1.5 text-[11px] text-emerald-200/90 leading-relaxed font-sans">
            <li>• <strong>Touchdown Speed:</strong> Below <strong>160 KTS</strong> (Throttle ~25%).</li>
            <li>• <strong>Altitude Ceiling:</strong> Service ceiling up to <strong>50,000 FT</strong>.</li>
            <li>• <strong>Airbases:</strong> Repeating runways located every 4,000m along the map.</li>
            <li>• <strong>ILS Beacons:</strong> Follow green & amber approach lights to runway.</li>
          </ul>
        </div>

      </div>

    </main>

  </div>

  <!-- STAGE 2: Fullscreen Flight Cockpit Container (Overlays 100% of viewport during flight) -->
  <div id="fullscreen-flight-container" class="hidden fixed inset-0 z-50 w-screen h-screen bg-[#020617] overflow-hidden select-none touch-none">
    
    <!-- Mode-7 3D Canvas -->
    <canvas id="flight-canvas" class="w-full h-full block touch-none"></canvas>

    <!-- Cockpit HUD Overlay (All controls simultaneously visible) -->
    <div class="absolute inset-0 pointer-events-none p-3 sm:p-5 flex flex-col justify-between z-10 font-mono text-xs">
      
      <!-- Top HUD Header Bar -->
      <div class="flex justify-between items-start gap-2">
        <!-- Artificial Horizon & Telemetry -->
        <div class="bg-black/85 backdrop-blur-md border border-primary/40 p-2.5 rounded-xl text-primary space-y-1 shrink-0 shadow-lg">
          <div class="text-[10px] uppercase text-muted tracking-wider">Horizon & Telemetry</div>
          <div class="w-24 sm:w-28 h-2 bg-primary/20 relative overflow-hidden rounded border border-primary/40">
            <div id="hud-pitch-bar" class="absolute inset-x-0 h-full bg-primary transition-all duration-75"></div>
          </div>
          <div class="text-[11px] font-bold text-white flex justify-between gap-2">
            <span id="hud-speed-text">350 KTS</span>
            <span id="hud-alt-text" class="text-primary">850 FT</span>
          </div>
        </div>

        <!-- Center Wayfinding Navigation Box -->
        <div class="bg-black/85 backdrop-blur-md border border-amber-500/50 px-3.5 py-2 rounded-xl text-amber-400 font-mono text-xs font-bold tracking-wider flex items-center gap-2 shadow-xl" id="hud-wayfinding-box">
          <Navigation class="w-4 h-4 text-amber-500 animate-pulse shrink-0" />
          <span id="hud-wayfinding-text">TARGET: FREE FLIGHT</span>
        </div>

        <!-- Top Right Radar Minimap, Autoland & Exit Button -->
        <div class="flex items-center gap-2 pointer-events-auto">
          <!-- Autoland Autopilot Quick Button -->
          <button
            id="hud-autoland-btn"
            type="button"
            class="bg-indigo-600 hover:bg-indigo-500 text-white font-mono text-xs font-bold px-3 py-2.5 rounded-xl transition-all active:scale-95 cursor-pointer shadow-xl flex items-center gap-1.5 select-none"
            title="Toggle Autoland Autopilot"
          >
            <Bot class="w-4 h-4" />
            <span id="hud-autoland-label">AUTOLAND</span>
          </button>

          <!-- Radar Minimap -->
          <div class="w-16 h-16 sm:w-20 sm:h-20 bg-black/85 border border-primary/50 rounded-full relative overflow-hidden flex items-center justify-center shadow-lg shrink-0">
            <div class="absolute inset-2 border border-primary/20 rounded-full"></div>
            <div class="absolute inset-5 border border-primary/15 rounded-full"></div>
            <div class="absolute inset-x-0 top-1/2 h-[1px] bg-primary/30"></div>
            <div class="absolute inset-y-0 left-1/2 w-[1px] bg-primary/30"></div>
            <div class="w-2 h-2 bg-primary rounded-full z-10 shadow-[0_0_8px_var(--primary)]"></div>
            <div id="radar-blips" class="absolute inset-0"></div>
          </div>

          <!-- Exit Fullscreen Button -->
          <button
            id="exit-fullscreen-btn"
            type="button"
            class="bg-rose-600 hover:bg-rose-500 text-white font-mono text-xs font-bold px-3 py-2.5 rounded-xl transition-all active:scale-95 cursor-pointer shadow-xl flex items-center gap-1.5 select-none"
            title="Exit Flight Mode"
          >
            <X class="w-4 h-4" />
            <span class="hidden sm:inline">EXIT</span>
          </button>
        </div>
      </div>

      <!-- Stall Warning Indicator -->
      <div id="stall-warning" class="self-center bg-rose-600/90 text-white px-4 py-1.5 rounded-xl font-mono text-xs font-bold animate-pulse hidden flex items-center gap-1.5 shadow-xl">
        <ShieldAlert class="w-4 h-4" /> STALL WARNING // AIRSPEED CRITICAL // PITCH DOWN
      </div>

      <!-- Bottom Touch Cockpit HUD Controls -->
      <div class="flex justify-between items-end gap-3 pointer-events-auto">
        
        <!-- Left Side: Touch Yoke Gesture Area Indicator -->
        <div class="bg-black/75 backdrop-blur-md border border-border px-3 py-2 rounded-xl text-muted text-[11px] pointer-events-none hidden sm:block">
          <span>🕹️ Left Thumb: Drag Flight Yoke (Pitch & Roll)</span>
        </div>

        <!-- Right Side: Vertical Throttle Lever + Action Buttons -->
        <div class="flex items-end gap-3">
          
          <!-- Vertical Touch Throttle Lever -->
          <div id="touch-throttle-box" class="flex flex-col items-center gap-1 bg-black/85 backdrop-blur-md p-2 rounded-xl border border-primary/50 select-none shadow-xl">
            <span class="text-[10px] font-mono text-amber-400 font-bold uppercase tracking-wider">THROTTLE</span>
            <div id="touch-throttle-track" class="w-8 h-32 sm:h-36 bg-primary/20 border border-primary/50 rounded-lg relative overflow-hidden touch-none cursor-pointer">
              <div id="touch-throttle-bar" class="absolute bottom-0 inset-x-0 bg-primary/80 transition-all duration-75"></div>
              <div id="touch-throttle-knob" class="absolute inset-x-0 h-4 bg-amber-400 rounded border border-white shadow-md transition-all duration-75" style="bottom: 60%"></div>
            </div>
            <span id="touch-throttle-val" class="text-[11px] font-mono text-white font-bold">60%</span>
          </div>

          <!-- Touch Action Buttons Column (Gear, Flaps, Cannon, Camera) -->
          <div class="flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <button
                id="touch-gear-btn"
                class="bg-black/85 hover:bg-primary/20 border border-border hover:border-primary text-foreground font-mono text-xs px-3 py-2 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg select-none"
              >
                <span id="touch-gear-label">🛞 GEAR (UP)</span>
              </button>
              <button
                id="touch-flaps-btn"
                class="bg-black/85 hover:bg-primary/20 border border-border hover:border-primary text-foreground font-mono text-xs px-3 py-2 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg select-none"
              >
                <span id="touch-flaps-label">✈️ FLAPS (UP)</span>
              </button>
            </div>

            <div class="flex items-center gap-2">
              <button
                id="touch-cam-btn"
                class="bg-black/85 hover:bg-primary/20 border border-border hover:border-primary text-foreground font-mono text-xs px-3 py-2 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg select-none"
              >
                <span id="touch-cam-label">📹 CAM</span>
              </button>
              <button
                id="touch-cannon-btn"
                class="flex-grow bg-rose-600 hover:bg-rose-500 text-white font-mono text-xs font-bold py-3 px-4 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg flex items-center justify-center gap-1.5 select-none"
              >
                <Flame class="w-4 h-4 fill-white" />
                <span>CANNON</span>
              </button>
            </div>
          </div>

        </div>

      </div>

    </div>

    <!-- Overlay Mission Complete / Crash Dialog inside Fullscreen -->
    <div id="fullscreen-overlay" class="hidden absolute inset-0 bg-black/85 backdrop-blur-sm flex flex-col items-center justify-center p-6 text-center z-20 pointer-events-auto">
      <div class="space-y-4 max-w-md bg-black/90 border border-primary/40 p-6 rounded-2xl shadow-2xl">
        <div class="w-14 h-14 rounded-2xl bg-primary/20 border border-primary/40 flex items-center justify-center mx-auto text-primary">
          <Plane class="w-7 h-7" />
        </div>
        <h3 id="overlay-title" class="text-2xl font-extrabold tracking-tight text-white font-mono uppercase">
          MISSION OVER
        </h3>
        <p id="overlay-desc" class="text-sm text-muted leading-relaxed font-sans">
          Flight report details...
        </p>
        <div class="flex gap-3">
          <button
            id="overlay-restart-btn"
            class="flex-1 bg-primary hover:bg-primary/90 text-white font-mono font-bold py-3 px-4 rounded-xl transition-transform active:scale-95 shadow-lg cursor-pointer text-xs uppercase"
          >
            Restart Flight
          </button>
          <button
            id="overlay-exit-btn"
            class="flex-1 bg-card hover:bg-background border border-border text-foreground font-mono font-bold py-3 px-4 rounded-xl transition-transform active:scale-95 cursor-pointer text-xs uppercase"
          >
            Return to Setup
          </button>
        </div>
      </div>
    </div>

  </div>

  <script>
    // --- 16-BIT FLIGHT SIMULATOR ENGINE (FULLSCREEN STAGE 2) ---
    const fullscreenContainer = document.getElementById('fullscreen-flight-container')!;
    const canvas = document.getElementById('flight-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    // Stage 1 Setup Buttons
    const setupMissionFree = document.getElementById('setup-mission-free')!;
    const setupMissionRings = document.getElementById('setup-mission-rings')!;
    const setupMissionLanding = document.getElementById('setup-mission-landing')!;
    const setupMissionBtns = [setupMissionFree, setupMissionRings, setupMissionLanding];

    const setupSkyBtns = document.querySelectorAll('.setup-sky-btn');
    const setupSoundBtn = document.getElementById('setup-sound-btn')!;
    const setupSoundIconOn = document.getElementById('setup-sound-icon-on')!;
    const setupSoundIconOff = document.getElementById('setup-sound-icon-off')!;
    const setupSoundText = document.getElementById('setup-sound-text')!;
    const launchFullscreenBtn = document.getElementById('launch-fullscreen-btn')!;

    // Stage 2 Fullscreen HUD Elements
    const exitFullscreenBtn = document.getElementById('exit-fullscreen-btn')!;
    const hudAutolandBtn = document.getElementById('hud-autoland-btn')!;
    const hudAutolandLabel = document.getElementById('hud-autoland-label')!;

    const hudPitchBar = document.getElementById('hud-pitch-bar')!;
    const hudSpeedText = document.getElementById('hud-speed-text')!;
    const hudAltText = document.getElementById('hud-alt-text')!;
    const hudWayfindingText = document.getElementById('hud-wayfinding-text')!;
    const radarBlipsEl = document.getElementById('radar-blips')!;
    const stallWarningEl = document.getElementById('stall-warning')!;

    // Fullscreen Overlay Dialog
    const fullscreenOverlay = document.getElementById('fullscreen-overlay')!;
    const overlayTitle = document.getElementById('overlay-title')!;
    const overlayDesc = document.getElementById('overlay-desc')!;
    const overlayRestartBtn = document.getElementById('overlay-restart-btn')!;
    const overlayExitBtn = document.getElementById('overlay-exit-btn')!;

    // Touch Cockpit Controls
    const touchGearBtn = document.getElementById('touch-gear-btn')!;
    const touchGearLabel = document.getElementById('touch-gear-label')!;
    const touchFlapsBtn = document.getElementById('touch-flaps-btn')!;
    const touchFlapsLabel = document.getElementById('touch-flaps-label')!;
    const touchCamBtn = document.getElementById('touch-cam-btn')!;
    const touchCannonBtn = document.getElementById('touch-cannon-btn')!;

    const touchThrottleTrack = document.getElementById('touch-throttle-track')!;
    const touchThrottleBar = document.getElementById('touch-throttle-bar')!;
    const touchThrottleKnob = document.getElementById('touch-throttle-knob')!;
    const touchThrottleVal = document.getElementById('touch-throttle-val')!;

    // --- Sound Synthesis Engine ---
    let soundEnabled = true;
    let audioCtx: AudioContext | null = null;
    let engineOsc: OscillatorNode | null = null;
    let engineGain: GainNode | null = null;

    function getAudioCtx() {
      try {
        if (!audioCtx) {
          const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
          if (AudioContextClass) {
            audioCtx = new AudioContextClass();
          }
        }
        if (audioCtx && audioCtx.state === 'suspended') {
          audioCtx.resume().catch(() => {});
        }
      } catch (e) {}
      return audioCtx;
    }

    function initEngineSound() {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioCtx();
        if (ctx && !engineOsc) {
          engineOsc = ctx.createOscillator();
          engineGain = ctx.createGain();

          engineOsc.type = 'sawtooth';
          engineOsc.frequency.setValueAtTime(55, ctx.currentTime);
          engineGain.gain.setValueAtTime(0.04, ctx.currentTime);

          engineOsc.connect(engineGain);
          engineGain.connect(ctx.destination);
          engineOsc.start();
        }
      } catch (e) {}
    }

    function updateEngineSound(throttlePct: number) {
      if (!soundEnabled || !engineOsc || !engineGain) return;
      try {
        const ctx = getAudioCtx();
        if (ctx) {
          const freq = 45 + throttlePct * 2.5;
          engineOsc.frequency.setTargetAtTime(freq, ctx.currentTime, 0.1);
        }
      } catch (e) {}
    }

    function playSFX(type: 'cannon' | 'ring' | 'stall' | 'crash' | 'land') {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioCtx();
        if (!ctx) return;
        const now = ctx.currentTime;

        if (type === 'cannon') {
          [0, 0.05].forEach((offset) => {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'square';
            osc.frequency.setValueAtTime(450, now + offset);
            osc.frequency.exponentialRampToValueAtTime(90, now + offset + 0.08);
            gain.gain.setValueAtTime(0.35, now + offset);
            gain.gain.exponentialRampToValueAtTime(0.01, now + offset + 0.08);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start(now + offset);
            osc.stop(now + offset + 0.08);
          });
        } else if (type === 'ring') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'triangle';
          osc.frequency.setValueAtTime(523.25, now);
          osc.frequency.setValueAtTime(783.99, now + 0.08);
          gain.gain.setValueAtTime(0.25, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now + 0.08);
          osc.stop(now + 0.2);
        } else if (type === 'land') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sine';
          osc.frequency.setValueAtTime(440, now);
          osc.frequency.setValueAtTime(659.25, now + 0.1);
          gain.gain.setValueAtTime(0.3, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.35);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.35);
        } else if (type === 'crash') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sawtooth';
          osc.frequency.setValueAtTime(140, now);
          osc.frequency.linearRampToValueAtTime(35, now + 0.5);
          gain.gain.setValueAtTime(0.4, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.5);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.5);
        }
      } catch (e) {}
    }

    setupSoundBtn.addEventListener('click', () => {
      soundEnabled = !soundEnabled;
      if (soundEnabled) {
        setupSoundIconOn.classList.remove('hidden');
        setupSoundIconOff.classList.add('hidden');
        setupSoundText.textContent = 'SFX Enabled';
        initEngineSound();
      } else {
        setupSoundIconOn.classList.add('hidden');
        setupSoundIconOff.classList.remove('hidden');
        setupSoundText.textContent = 'Muted';
        if (engineGain) engineGain.gain.value = 0;
      }
    });

    // --- State Variables ---
    let width = window.innerWidth;
    let height = window.innerHeight;

    let isPlaying = false;
    let isPaused = false;
    let isCrashed = false;
    let isLanded = false;
    let isAutolandActive = false;

    let currentMission = 'free'; // 'free' | 'rings' | 'landing'
    let skyTheme = 'day'; // 'day' | 'sunset' | 'night'
    let cameraMode = 'chase'; // 'chase' | 'cockpit'

    // F-14 Aerodynamic Physics Model
    const plane = {
      x: 0,
      y: 3500, // Altitude in feet (Ceiling: 50,000 FT)
      z: 0,
      pitch: 0, // deg (-45 to +45)
      roll: 0,  // deg (-60 to +60)
      yaw: 0,   // heading deg (0 to 360)
      speed: 420, // airspeed in knots
      throttle: 60, // engine thrust %
      gearDown: false,
      flapsDown: false,
      stalling: false,
      muzzleFlash: 0,
      recoilShake: 0
    };

    let bullets: { x: number; y: number; z: number; vx: number; vy: number; vz: number; life: number }[] = [];
    let targetRings: { id: number; x: number; y: number; z: number; radius: number; passed: boolean }[] = [];
    let ringsPassedCount = 0;

    // World Repeating Airbases (every 4000m along Z axis)
    function getNearestRunway(planeZ: number) {
      const spacing = 4000;
      const index = Math.round(planeZ / spacing);
      const targetZ = index * spacing + 1200;
      return {
        id: Math.abs(index) + 1,
        x: 0,
        z: targetZ,
        length: 1600,
        width: 200
      };
    }

    const skyPalettes = {
      day: {
        skyTop: '#0f172a',
        skyMid: '#1e3a8a',
        skyBottom: '#38bdf8',
        groundBase: '#15803d',
        gridLine: '#16a34a'
      },
      sunset: {
        skyTop: '#1e1b4b',
        skyMid: '#4c1d95',
        skyBottom: '#f97316',
        groundBase: '#7c2d12',
        gridLine: '#ea580c'
      },
      night: {
        skyTop: '#020617',
        skyMid: '#090d16',
        skyBottom: '#1e1b4b',
        groundBase: '#09090b',
        gridLine: '#6366f1'
      }
    };

    const keys: Record<string, boolean> = {};

    const touchYoke = {
      active: false,
      startX: 0,
      startY: 0,
      pitchInput: 0,
      rollInput: 0,
      touchId: null as number | null
    };

    // --- Responsive Canvas Setup ---
    function resizeCanvas() {
      width = window.innerWidth;
      height = window.innerHeight;

      const dpr = window.devicePixelRatio || 1;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.scale(dpr, dpr);
    }

    window.addEventListener('resize', resizeCanvas);

    // --- Fullscreen Launch & Exit Logic ---
    function launchFullscreenFlight() {
      getAudioCtx();
      fullscreenContainer.classList.remove('hidden');

      const el = fullscreenContainer as any;
      if (el.requestFullscreen) {
        el.requestFullscreen().catch(() => {});
      } else if (el.webkitRequestFullscreen) {
        el.webkitRequestFullscreen();
      }

      resizeCanvas();
      resetFlight();
    }

    function exitFullscreenFlight() {
      isPlaying = false;
      isAutolandActive = false;
      if (document.exitFullscreen) {
        document.exitFullscreen().catch(() => {});
      } else if ((document as any).webkitExitFullscreen) {
        (document as any).webkitExitFullscreen();
      }
      fullscreenContainer.classList.add('hidden');
      fullscreenOverlay.classList.add('hidden');
      if (engineGain) engineGain.gain.value = 0;
    }

    launchFullscreenBtn.addEventListener('click', launchFullscreenFlight);
    exitFullscreenBtn.addEventListener('click', exitFullscreenFlight);
    overlayExitBtn.addEventListener('click', exitFullscreenFlight);
    overlayRestartBtn.addEventListener('click', () => {
      fullscreenOverlay.classList.add('hidden');
      resetFlight();
    });

    // Toggle Autoland System
    function toggleAutoland() {
      isAutolandActive = !isAutolandActive;
      if (isAutolandActive) {
        hudAutolandBtn.className = 'bg-emerald-600 hover:bg-emerald-500 text-white font-mono text-xs font-bold px-3 py-2.5 rounded-xl transition-all active:scale-95 cursor-pointer shadow-xl flex items-center gap-1.5 select-none animate-pulse';
        hudAutolandLabel.textContent = 'AUTOLAND (ON)';
      } else {
        hudAutolandBtn.className = 'bg-indigo-600 hover:bg-indigo-500 text-white font-mono text-xs font-bold px-3 py-2.5 rounded-xl transition-all active:scale-95 cursor-pointer shadow-xl flex items-center gap-1.5 select-none';
        hudAutolandLabel.textContent = 'AUTOLAND';
      }
    }

    hudAutolandBtn.addEventListener('click', toggleAutoland);

    // --- Mission Setup Handlers ---
    setupMissionBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        setupMissionBtns.forEach(b => {
          b.className = 'setup-mission-btn border border-border bg-background hover:border-primary text-foreground p-3 rounded-xl transition-all font-bold cursor-pointer text-left space-y-1 shadow-sm';
        });
        const target = e.currentTarget as HTMLButtonElement;
        target.className = 'setup-mission-btn border-2 border-primary bg-primary/15 text-primary p-3 rounded-xl transition-all font-bold cursor-pointer text-left space-y-1 shadow-sm';

        if (target.id === 'setup-mission-rings') currentMission = 'rings';
        else if (target.id === 'setup-mission-landing') currentMission = 'landing';
        else currentMission = 'free';
      });
    });

    setupSkyBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        setupSkyBtns.forEach(b => {
          b.className = 'setup-sky-btn border border-border bg-background text-muted p-2.5 rounded-xl transition-all cursor-pointer text-center';
        });
        const target = e.currentTarget as HTMLButtonElement;
        target.className = 'setup-sky-btn border-2 border-primary bg-primary/15 text-primary p-2.5 rounded-xl transition-all font-bold cursor-pointer text-center';
        skyTheme = target.dataset.sky || 'day';
      });
    });

    // --- Mission Builder ---
    function initMission() {
      ringsPassedCount = 0;
      targetRings = [];

      if (currentMission === 'rings') {
        for (let i = 0; i < 8; i++) {
          const angle = (i / 8) * Math.PI * 1.2;
          const dist = 800 + i * 550;
          targetRings.push({
            id: i + 1,
            x: Math.sin(angle) * dist,
            y: 800 + Math.sin(i * 1.4) * 350,
            z: Math.cos(angle) * dist + 400,
            radius: 120,
            passed: false
          });
        }
      } else if (currentMission === 'landing') {
        const rw = getNearestRunway(plane.z);
        plane.x = 0;
        plane.y = 850;
        plane.z = rw.z - 1800;
        plane.pitch = -2;
        plane.speed = 145;
        plane.gearDown = true;
        plane.flapsDown = true;
        touchGearLabel.textContent = '🛞 GEAR (DN)';
        touchFlapsLabel.textContent = '✈️ FLAPS (DN)';
      }
    }

    function updateThrottleUI(pct: number) {
      plane.throttle = Math.max(0, Math.min(100, pct));
      touchThrottleBar.style.height = `${plane.throttle}%`;
      touchThrottleKnob.style.bottom = `${Math.max(0, Math.min(85, plane.throttle * 0.85))}%`;
      touchThrottleVal.textContent = `${Math.round(plane.throttle)}%`;
    }

    function showFullscreenOverlay(title: string, desc: string) {
      overlayTitle.textContent = title;
      overlayDesc.textContent = desc;
      fullscreenOverlay.classList.remove('hidden');
    }

    function resetFlight() {
      plane.x = 0;
      plane.y = 3500;
      plane.z = 0;
      plane.pitch = 0;
      plane.roll = 0;
      plane.yaw = 0;
      plane.speed = 420;
      plane.gearDown = false;
      plane.flapsDown = false;
      plane.stalling = false;
      plane.muzzleFlash = 0;
      plane.recoilShake = 0;
      isAutolandActive = false;

      updateThrottleUI(60);

      touchGearLabel.textContent = '🛞 GEAR (UP)';
      touchFlapsLabel.textContent = '✈️ FLAPS (UP)';

      isCrashed = false;
      isLanded = false;
      isPaused = false;
      isPlaying = true;

      bullets = [];

      initMission();
      fullscreenOverlay.classList.add('hidden');
      stallWarningEl.classList.add('hidden');
      initEngineSound();
    }

    // --- Cannon Vector Calculation ---
    function fireCannon() {
      if (!isPlaying || isCrashed) return;
      playSFX('cannon');
      plane.muzzleFlash = 5;
      plane.recoilShake = 4;

      const radYaw = (plane.yaw * Math.PI) / 180;
      const radPitch = (plane.pitch * Math.PI) / 180;

      const fx = Math.sin(radYaw) * Math.cos(radPitch);
      const fy = Math.sin(radPitch);
      const fz = Math.cos(radYaw) * Math.cos(radPitch);

      const speed = 40;

      const wingOffset = 22;
      const lx = plane.x - Math.cos(radYaw) * wingOffset;
      const rx = plane.x + Math.cos(radYaw) * wingOffset;
      const lz = plane.z + Math.sin(radYaw) * wingOffset;
      const rz = plane.z - Math.sin(radYaw) * wingOffset;

      bullets.push({
        x: lx,
        y: plane.y - 4,
        z: lz,
        vx: fx * speed + Math.sin(radYaw) * plane.speed * 0.08,
        vy: fy * speed,
        vz: fz * speed + Math.cos(radYaw) * plane.speed * 0.08,
        life: 45
      });

      bullets.push({
        x: rx,
        y: plane.y - 4,
        z: rz,
        vx: fx * speed + Math.sin(radYaw) * plane.speed * 0.08,
        vy: fy * speed,
        vz: fz * speed + Math.cos(radYaw) * plane.speed * 0.08,
        life: 45
      });
    }

    // --- Aerodynamic Flight Dynamics & Autoland Physics Loop ---
    function updatePhysics(dt: number) {
      if (!isPlaying || isPaused || isCrashed) return;

      const currentRunway = getNearestRunway(plane.z);

      // --- AUTOLAND AUTOPILOT COMPUTER ---
      if (isAutolandActive) {
        plane.gearDown = true;
        plane.flapsDown = true;
        touchGearLabel.textContent = '🛞 GEAR (DN)';
        touchFlapsLabel.textContent = '✈️ FLAPS (DN)';

        // Target approach speed ~140 KTS
        const targetThrottle = 25;
        updateThrottleUI(plane.throttle + (targetThrottle - plane.throttle) * 0.05 * dt);

        // Align X centerline
        const targetX = currentRunway.x;
        const dx = targetX - plane.x;
        plane.roll = Math.max(-25, Math.min(25, dx * 0.15));

        // Align Heading with 000° North runway direction
        let targetYaw = 0;
        if (dx > 20) targetYaw = 8;
        if (dx < -20) targetYaw = 352;
        plane.yaw += (targetYaw - plane.yaw) * 0.05 * dt;

        // Glide slope descent calculation (-2.5° pitch down until flare at 50 FT)
        if (plane.y > 50) {
          plane.pitch += (-2.5 - plane.pitch) * 0.08 * dt;
        } else {
          plane.pitch += (2.0 - plane.pitch) * 0.1 * dt; // Touchdown Flare!
        }
      } else {
        // Manual Flight Inputs
        let pitchInput = touchYoke.pitchInput;
        let rollInput = touchYoke.rollInput;

        if (keys['w'] || keys['W'] || keys['ArrowUp']) pitchInput -= 1;
        if (keys['s'] || keys['S'] || keys['ArrowDown']) pitchInput += 1;
        if (keys['a'] || keys['A'] || keys['ArrowLeft']) rollInput -= 1;
        if (keys['d'] || keys['D'] || keys['ArrowRight']) rollInput += 1;

        if (keys['i'] || keys['I']) updateThrottleUI(plane.throttle + 1.2 * dt);
        if (keys['k'] || keys['K']) updateThrottleUI(plane.throttle - 1.2 * dt);

        plane.pitch += pitchInput * 1.8 * dt;
        plane.roll += rollInput * 2.5 * dt;
        plane.yaw += (plane.roll * 0.04) * dt;

        if (rollInput === 0 && !touchYoke.active) plane.roll *= 0.92;
        if (pitchInput === 0 && !touchYoke.active) plane.pitch *= 0.93;
      }

      plane.pitch = Math.max(-45, Math.min(45, plane.pitch));
      plane.roll = Math.max(-75, Math.min(75, plane.roll));
      plane.yaw = (plane.yaw + 360) % 360;

      if (plane.muzzleFlash > 0) plane.muzzleFlash -= 1;
      if (plane.recoilShake > 0) plane.recoilShake *= 0.8;

      // Realistic Jet Speed Physics (130 KTS to 850 KTS Mach 1.2)
      const targetSpeed = 130 + plane.throttle * 7.2 + (plane.flapsDown ? -40 : 0);
      plane.speed += (targetSpeed - plane.speed) * 0.05 * dt;

      const radPitch = (plane.pitch * Math.PI) / 180;
      const radYaw = (plane.yaw * Math.PI) / 180;

      // Aerodynamic Lift vs Weight
      const flapLiftBonus = plane.flapsDown ? 1.25 : 1.0;
      const minStallSpeed = plane.flapsDown ? 95 : 110;

      const climbRate = Math.sin(radPitch) * plane.speed * 0.35 + (plane.speed - minStallSpeed) * 0.08 * flapLiftBonus;
      plane.y += climbRate * dt;

      // Service Ceiling Limit (50,000 FT)
      if (plane.y > 50000) {
        plane.y = 50000;
        if (plane.pitch > 0) plane.pitch *= 0.8;
      }

      // Movement Vector
      plane.x += Math.sin(radYaw) * plane.speed * 0.08 * dt;
      plane.z += Math.cos(radYaw) * plane.speed * 0.08 * dt;

      // Aerodynamic Stall Check
      if (plane.speed < minStallSpeed && plane.pitch > 8) {
        plane.stalling = true;
        stallWarningEl.classList.remove('hidden');
        plane.y -= 18 * dt; // Aerodynamic sink drop!
        playSFX('stall');
      } else {
        plane.stalling = false;
        stallWarningEl.classList.add('hidden');
      }

      // Ground Collision & Landing Touchdown Mechanics
      if (plane.y <= 0) {
        plane.y = 0;

        const distRunwayX = Math.abs(plane.x - currentRunway.x);
        const distRunwayZ = Math.abs(plane.z - currentRunway.z);

        const isRunwayAlignment = distRunwayX < currentRunway.width && distRunwayZ < currentRunway.length;
        const isSafeSpeed = plane.speed <= 160;
        const isSafeAttitude = Math.abs(plane.pitch) <= 8 && Math.abs(plane.roll) <= 15;

        if (plane.gearDown && isRunwayAlignment && isSafeSpeed && isSafeAttitude) {
          isLanded = true;
          isPlaying = false;
          isAutolandActive = false;
          playSFX('land');
          showFullscreenOverlay('TOUCHDOWN SUCCESSFUL!', `Textbook landing at ${Math.round(plane.speed)} KTS on Airbase Runway #${currentRunway.id}! Pitch: ${Math.round(plane.pitch)}°.`);
        } else {
          isCrashed = true;
          isPlaying = false;
          isAutolandActive = false;
          playSFX('crash');

          let crashReason = `Ground impact at ${Math.round(plane.speed)} KTS.`;
          if (!plane.gearDown) crashReason = 'Belly scrape crash! Landing Gear was UP.';
          else if (!isRunwayAlignment) crashReason = `Off-runway terrain crash! Target nearest Airbase Runway #${currentRunway.id}.`;
          else if (!isSafeSpeed) crashReason = `Hard impact! Speed was ${Math.round(plane.speed)} KTS (Max allowed: 160 KTS).`;
          else if (!isSafeAttitude) crashReason = `Unstable attitude! Pitch was ${Math.round(plane.pitch)}° (Keep between -8° and +8°).`;

          showFullscreenOverlay('AIRCRAFT CRASHED', crashReason);
        }
      }

      // Wayfinding Updates
      if (isAutolandActive) {
        hudWayfindingText.textContent = `🤖 AUTOLAND ACTIVE // ILS GLIDE SLOPE RUNWAY #${currentRunway.id} (${Math.round(Math.abs(currentRunway.z - plane.z))}m)`;
      } else if (currentMission === 'rings') {
        const nextRing = targetRings.find(r => !r.passed);

        if (nextRing) {
          const dx = nextRing.x - plane.x;
          const dy = nextRing.y - plane.y;
          const dz = nextRing.z - plane.z;
          const dist = Math.round(Math.sqrt(dx * dx + dy * dy + dz * dz));

          const ringHdg = Math.round((Math.atan2(dx, dz) * (180 / Math.PI) + 360) % 360);
          let hdgDiff = ringHdg - plane.yaw;
          if (hdgDiff > 180) hdgDiff -= 360;
          if (hdgDiff < -180) hdgDiff += 360;

          let arrow = '⬆';
          if (hdgDiff > 30) arrow = '➡️';
          else if (hdgDiff < -30) arrow = '⬅';

          hudWayfindingText.textContent = `${arrow} RING #${nextRing.id}: ${dist}m (HDG ${String(ringHdg).padStart(3, '0')}°)`;

          if (dist < nextRing.radius + 45) {
            nextRing.passed = true;
            ringsPassedCount++;
            playSFX('ring');

            if (ringsPassedCount >= 8) {
              showFullscreenOverlay('COURSE CLEARED!', 'Outstanding aviator precision! All 8 target rings cleared!');
            }
          }
        }
      } else {
        const distRunway = Math.round(Math.abs(currentRunway.z - plane.z));
        hudWayfindingText.textContent = `🛬 AIRBASE RUNWAY #${currentRunway.id}: ${distRunway}m | ALT ${Math.round(plane.y)} FT`;
      }

      // Cannon Bullets Update
      for (let i = bullets.length - 1; i >= 0; i--) {
        const b = bullets[i];
        b.x += b.vx * dt;
        b.y += b.vy * dt;
        b.z += b.vz * dt;
        b.life -= dt;
        if (b.life <= 0) {
          bullets.splice(i, 1);
        }
      }

      updateEngineSound(plane.throttle);

      hudSpeedText.textContent = `${Math.round(plane.speed)} KTS`;
      hudAltText.textContent = `${Math.round(plane.y).toLocaleString()} FT`;

      if (hudPitchBar) hudPitchBar.style.transform = `translateY(${-plane.pitch * 0.8}px) rotate(${-plane.roll}deg)`;

      updateRadarUI(currentRunway);
    }

    function updateRadarUI(currentRunway: any) {
      if (!radarBlipsEl) return;
      radarBlipsEl.innerHTML = '';

      // Runway Blip on Radar
      const rwRelX = (currentRunway.x - plane.x) / 45;
      const rwRelZ = (currentRunway.z - plane.z) / 45;
      if (Math.abs(rwRelX) < 42 && Math.abs(rwRelZ) < 42) {
        const blip = document.createElement('div');
        blip.className = 'absolute w-3 h-3 bg-emerald-400 border border-white rounded-sm';
        blip.style.left = `${36 + rwRelX}px`;
        blip.style.top = `${36 - rwRelZ}px`;
        radarBlipsEl.appendChild(blip);
      }

      if (currentMission === 'rings') {
        targetRings.forEach(ring => {
          if (!ring.passed) {
            const relX = (ring.x - plane.x) / 45;
            const relZ = (ring.z - plane.z) / 45;
            if (Math.abs(relX) < 42 && Math.abs(relZ) < 42) {
              const blip = document.createElement('div');
              blip.className = 'absolute w-2 h-2 bg-amber-400 rounded-full animate-ping';
              blip.style.left = `${36 + relX}px`;
              blip.style.top = `${36 - relZ}px`;
              radarBlipsEl.appendChild(blip);
            }
          }
        });
      }
    }

    // --- Mode-7 Dynamic 3D Renderer ---
    function draw() {
      const palette = skyPalettes[skyTheme as keyof typeof skyPalettes];

      const shakeX = (Math.random() - 0.5) * plane.recoilShake;
      const shakeY = (Math.random() - 0.5) * plane.recoilShake;

      // 50,000 FT High Altitude Horizon & Grid Perspective Scaling
      const altScale = Math.max(0.2, 1 - (plane.y / 50000) * 0.75);
      const horizonY = height / 2 + (plane.pitch * 3.5) + shakeY;

      ctx.save();
      ctx.translate(width / 2 + shakeX, horizonY);
      ctx.rotate((-plane.roll * Math.PI) / 180);

      // Stratospheric Dynamic Gradient (Shifts to deep space blue near 50k FT)
      const skyGrad = ctx.createLinearGradient(0, -height * 2.5, 0, 0);
      skyGrad.addColorStop(0, palette.skyTop);
      skyGrad.addColorStop(0.5, palette.skyMid);
      skyGrad.addColorStop(1, palette.skyBottom);

      ctx.fillStyle = skyGrad;
      ctx.fillRect(-width * 1.5, -height * 2.5, width * 3, height * 2.5);

      // Ground Base
      ctx.fillStyle = palette.groundBase;
      ctx.fillRect(-width * 1.5, 0, width * 3, height * 2.5);

      // Mode-7 Grid Lines with Altitude Perspective Scaling
      ctx.strokeStyle = palette.gridLine;
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = Math.max(0.15, 0.45 * altScale);

      const gridSize = 140 * altScale;
      const offsetX = (plane.x % gridSize);
      const offsetZ = (plane.z % gridSize);

      for (let i = -14; i <= 14; i++) {
        const xStart = i * 45 * altScale - offsetX * 0.2;
        const xEnd = i * 240 * altScale - offsetX * 1.8;
        ctx.beginPath();
        ctx.moveTo(xStart, 0);
        ctx.lineTo(xEnd, height * 2);
        ctx.stroke();
      }

      for (let j = 1; j <= 14; j++) {
        const zPos = (j * 45 - (offsetZ * 0.4)) % 550;
        if (zPos > 0) {
          const yPos = Math.pow(zPos / 22, 1.85) * 3.2 * altScale;
          if (yPos > 0 && yPos < height * 2) {
            ctx.beginPath();
            ctx.moveTo(-width * 1.5, yPos);
            ctx.lineTo(width * 1.5, yPos);
            ctx.stroke();
          }
        }
      }
      ctx.globalAlpha = 1.0;

      // 3D Repeating Airbase Runways & ILS Approach Beacons
      const currentRunway = getNearestRunway(plane.z);
      const relRunwayZ = currentRunway.z - plane.z;
      const relRunwayX = currentRunway.x - plane.x;

      if (relRunwayZ > -400 && relRunwayZ < 4500) {
        const scale = 300 / (relRunwayZ + 350);
        const rwScreenX = relRunwayX * scale;
        const rwScreenY = (plane.y + 40) * scale;
        const rwWidth = currentRunway.width * scale;

        // Asphalt Pavement
        ctx.fillStyle = '#1e293b';
        ctx.fillRect(rwScreenX - rwWidth / 2, rwScreenY, rwWidth, 110 * scale);

        // Centerline Stripes
        ctx.fillStyle = '#f8fafc';
        ctx.fillRect(rwScreenX - 3, rwScreenY, 6, 110 * scale);

        // ILS Approach Beacons (Green Threshold & Amber Glide Slope Lights)
        for (let b = -4; b <= 4; b++) {
          ctx.fillStyle = '#22c55e';
          ctx.shadowColor = '#22c55e';
          ctx.shadowBlur = 8;
          ctx.fillRect(rwScreenX + b * 22 * scale - 4, rwScreenY - 6 * scale, 8 * scale, 8 * scale);
        }
        ctx.shadowBlur = 0;
      }

      // 3D Target Rings
      if (currentMission === 'rings') {
        const nextRing = targetRings.find(r => !r.passed);

        targetRings.forEach(ring => {
          if (!ring.passed) {
            const dz = ring.z - plane.z;
            const dx = ring.x - plane.x;
            const dy = ring.y - plane.y;

            if (dz > 30 && dz < 3500) {
              const scale = 300 / dz;
              const screenX = dx * scale;
              const screenY = -dy * scale;
              const radiusScreen = ring.radius * scale;

              const isNext = (nextRing && nextRing.id === ring.id);

              if (isNext) {
                const beamGradient = ctx.createLinearGradient(screenX, screenY - 400 * scale, screenX, screenY);
                beamGradient.addColorStop(0, 'rgba(245, 158, 11, 0)');
                beamGradient.addColorStop(1, 'rgba(245, 158, 11, 0.45)');
                ctx.fillStyle = beamGradient;
                ctx.fillRect(screenX - 10 * scale, screenY - 400 * scale, 20 * scale, 400 * scale);
              }

              ctx.strokeStyle = isNext ? '#fbbf24' : '#f59e0b';
              ctx.lineWidth = Math.max(2, (isNext ? 8 : 4) * scale);
              ctx.shadowColor = '#f59e0b';
              ctx.shadowBlur = isNext ? 16 : 6;
              ctx.beginPath();
              ctx.arc(screenX, screenY, Math.max(6, radiusScreen), 0, Math.PI * 2);
              ctx.stroke();
              ctx.shadowBlur = 0;

              ctx.fillStyle = '#ffffff';
              ctx.font = `bold ${Math.max(10, Math.round(14 * scale))}px monospace`;
              ctx.textAlign = 'center';
              ctx.fillText(`#${ring.id}`, screenX, screenY - radiusScreen - 8 * scale);
            }
          }
        });
      }

      // Plasma Cannon Tracers
      bullets.forEach(b => {
        const dz = b.z - plane.z;
        const dx = b.x - plane.x;
        const dy = b.y - plane.y;

        if (dz > 10 && dz < 2500) {
          const scale = 300 / dz;
          const screenX = dx * scale;
          const screenY = -dy * scale;

          ctx.strokeStyle = '#f43f5e';
          ctx.shadowColor = '#f43f5e';
          ctx.shadowBlur = 12;
          ctx.lineWidth = Math.max(3, 6 * scale);

          ctx.beginPath();
          ctx.moveTo(screenX, screenY);
          ctx.lineTo(screenX, screenY - 30 * scale);
          ctx.stroke();
          ctx.shadowBlur = 0;
        }
      });

      ctx.restore();

      // Ground Shadow
      if (plane.y < 1200) {
        const shadowAlpha = Math.max(0, 1 - plane.y / 1200) * 0.45;
        const shadowOffsetY = Math.min(120, (plane.y / 1200) * 100);
        ctx.save();
        ctx.translate(width / 2, height - 90 + shadowOffsetY);
        ctx.rotate((-plane.roll * Math.PI) / 180 * 0.4);
        ctx.fillStyle = `rgba(0, 0, 0, ${shadowAlpha})`;
        ctx.beginPath();
        ctx.ellipse(0, 0, 52, 14, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      // Touch Yoke Indicator Ring
      if (touchYoke.active) {
        ctx.save();
        ctx.translate(touchYoke.startX, touchYoke.startY);
        
        ctx.strokeStyle = 'rgba(99, 102, 241, 0.4)';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.arc(0, 0, 50, 0, Math.PI * 2);
        ctx.stroke();

        const knobX = touchYoke.rollInput * 50;
        const knobY = touchYoke.pitchInput * 50;
        ctx.fillStyle = '#6366f1';
        ctx.shadowColor = '#6366f1';
        ctx.shadowBlur = 12;
        ctx.beginPath();
        ctx.arc(knobX, knobY, 16, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;

        ctx.restore();
      }

      // F-14 Aircraft Sprite
      if (cameraMode === 'chase') {
        drawDetailed16BitFighterJet(width / 2, height - 90, plane.roll, plane.pitch, plane.throttle, plane.gearDown, plane.flapsDown, plane.muzzleFlash);
      }
    }

    // F-14 Tomcat Jet Renderer
    function drawDetailed16BitFighterJet(x: number, y: number, roll: number, pitch: number, throttle: number, gearDown: boolean, flapsDown: boolean, muzzleFlash: number) {
      ctx.save();
      ctx.translate(x, y);
      
      ctx.rotate((roll * Math.PI) / 180);
      const pitchScaleY = 1 - Math.sin((pitch * Math.PI) / 180) * 0.25;
      ctx.scale(1, pitchScaleY);

      if (muzzleFlash > 0) {
        ctx.fillStyle = '#fef08a';
        ctx.shadowColor = '#fef08a';
        ctx.shadowBlur = 20;
        ctx.beginPath();
        ctx.arc(-62, 14, 10, 0, Math.PI * 2);
        ctx.arc(62, 14, 10, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      // Flaps Extension Visual
      if (flapsDown) {
        ctx.fillStyle = '#f59e0b';
        ctx.fillRect(-50, 16, 22, 6);
        ctx.fillRect(28, 16, 22, 6);
      }

      ctx.fillStyle = '#334155';
      ctx.strokeStyle = '#64748b';
      ctx.lineWidth = 1.5;

      ctx.beginPath();
      ctx.moveTo(0, -32);
      ctx.lineTo(64, 16);
      ctx.lineTo(22, 12);
      ctx.lineTo(24, 32);
      ctx.lineTo(-24, 32);
      ctx.lineTo(-22, 12);
      ctx.lineTo(-64, 16);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = '#475569';
      ctx.beginPath();
      ctx.moveTo(0, -18);
      ctx.lineTo(44, 14);
      ctx.lineTo(14, 10);
      ctx.lineTo(-14, 10);
      ctx.lineTo(-44, 14);
      ctx.closePath();
      ctx.fill();

      ctx.fillStyle = '#64748b';
      ctx.beginPath();
      ctx.ellipse(0, 0, 12, 34, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = '#38bdf8';
      ctx.shadowColor = '#38bdf8';
      ctx.shadowBlur = 10;
      ctx.beginPath();
      ctx.ellipse(0, -12, 6, 14, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;

      // Nav Lights
      ctx.fillStyle = '#ef4444';
      ctx.shadowColor = '#ef4444';
      ctx.shadowBlur = 6;
      ctx.beginPath();
      ctx.arc(-63, 15, 3, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = '#22c55e';
      ctx.shadowColor = '#22c55e';
      ctx.shadowBlur = 6;
      ctx.beginPath();
      ctx.arc(63, 15, 3, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;

      // Thrust Flame
      if (throttle > 10) {
        const flameLen = 14 + (throttle / 100) * 32 + Math.random() * 8;

        ctx.fillStyle = '#f97316';
        ctx.beginPath();
        ctx.moveTo(-10, 32);
        ctx.lineTo(-5, 32 + flameLen);
        ctx.lineTo(0, 32);
        ctx.lineTo(5, 32 + flameLen);
        ctx.lineTo(10, 32);
        ctx.closePath();
        ctx.fill();

        ctx.fillStyle = '#fef08a';
        ctx.beginPath();
        ctx.moveTo(-8, 32);
        ctx.lineTo(-5, 32 + flameLen * 0.65);
        ctx.lineTo(0, 32);
        ctx.lineTo(5, 32 + flameLen * 0.65);
        ctx.lineTo(8, 32);
        ctx.closePath();
        ctx.fill();
      }

      if (gearDown) {
        ctx.fillStyle = '#0f172a';
        ctx.fillRect(-24, 12, 6, 9);
        ctx.fillRect(18, 12, 6, 9);
        ctx.fillRect(-3, -22, 6, 7);
      }

      ctx.restore();
    }

    // Main Game Loop
    let lastTime = 0;
    function mainLoop(timestamp = 0) {
      if (timestamp && lastTime) {
        const deltaTime = timestamp - lastTime;
        const dt = Math.max(0.2, Math.min(2.0, deltaTime / 16.667));
        updatePhysics(dt);
      } else {
        updatePhysics(1.0);
      }
      if (timestamp) lastTime = timestamp;

      draw();
      requestAnimationFrame(mainLoop);
    }

    // --- Throttle Control Handler ---
    function handleThrottleTouch(e: TouchEvent | MouseEvent) {
      const rect = touchThrottleTrack.getBoundingClientRect();
      const clientY = (e as TouchEvent).touches ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
      const relY = Math.max(0, Math.min(rect.height, clientY - rect.top));
      const pct = 100 - (relY / rect.height) * 100;
      updateThrottleUI(pct);
    }

    let isThrottleDragging = false;
    touchThrottleTrack.addEventListener('touchstart', (e) => {
      e.stopPropagation();
      isThrottleDragging = true;
      handleThrottleTouch(e);
    }, { passive: false });

    touchThrottleTrack.addEventListener('touchmove', (e) => {
      if (!isThrottleDragging) return;
      e.stopPropagation();
      e.preventDefault();
      handleThrottleTouch(e);
    }, { passive: false });

    touchThrottleTrack.addEventListener('touchend', () => { isThrottleDragging = false; });
    touchThrottleTrack.addEventListener('touchcancel', () => { isThrottleDragging = false; });

    touchThrottleTrack.addEventListener('mousedown', (e) => {
      isThrottleDragging = true;
      handleThrottleTouch(e);
    });
    window.addEventListener('mousemove', (e) => {
      if (isThrottleDragging) handleThrottleTouch(e);
    });
    window.addEventListener('mouseup', () => { isThrottleDragging = false; });

    // --- Touch Yoke Gesture Event Listeners ---
    canvas.addEventListener('touchstart', (e) => {
      getAudioCtx();
      for (let i = 0; i < e.changedTouches.length; i++) {
        const touch = e.changedTouches[i];
        const rect = canvas.getBoundingClientRect();
        const scaleX = width / rect.width;
        const scaleY = height / rect.height;
        const tx = (touch.clientX - rect.left) * scaleX;

        if (tx < width * 0.75 && !touchYoke.active) {
          touchYoke.active = true;
          touchYoke.touchId = touch.identifier;
          touchYoke.startX = tx;
          touchYoke.startY = (touch.clientY - rect.top) * scaleY;
          touchYoke.pitchInput = 0;
          touchYoke.rollInput = 0;
        }
      }
    }, { passive: false });

    canvas.addEventListener('touchmove', (e) => {
      if (!touchYoke.active) return;
      e.preventDefault();

      for (let i = 0; i < e.changedTouches.length; i++) {
        const touch = e.changedTouches[i];
        if (touch.identifier === touchYoke.touchId) {
          const rect = canvas.getBoundingClientRect();
          const scaleX = width / rect.width;
          const scaleY = height / rect.height;
          const tx = (touch.clientX - rect.left) * scaleX;
          const ty = (touch.clientY - rect.top) * scaleY;

          const dx = tx - touchYoke.startX;
          const dy = ty - touchYoke.startY;

          const maxRadius = 50;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const clampDist = Math.min(maxRadius, dist);
          const angle = Math.atan2(dy, dx);

          touchYoke.rollInput = (Math.cos(angle) * clampDist) / maxRadius;
          touchYoke.pitchInput = (Math.sin(angle) * clampDist) / maxRadius;
        }
      }
    }, { passive: false });

    function resetTouchYoke() {
      touchYoke.active = false;
      touchYoke.touchId = null;
      touchYoke.pitchInput = 0;
      touchYoke.rollInput = 0;
    }

    canvas.addEventListener('touchend', (e) => {
      for (let i = 0; i < e.changedTouches.length; i++) {
        if (e.changedTouches[i].identifier === touchYoke.touchId) {
          resetTouchYoke();
        }
      }
    });
    canvas.addEventListener('touchcancel', resetTouchYoke);

    // Keyboard Event Handlers
    window.addEventListener('keydown', (e) => {
      getAudioCtx();
      keys[e.key] = true;

      if (e.key === ' ') {
        e.preventDefault();
        fireCannon();
      } else if (e.key === 'g' || e.key === 'G') {
        toggleGear();
      } else if (e.key === 'f' || e.key === 'F') {
        toggleFlaps();
      }
    });

    window.addEventListener('keyup', (e) => {
      keys[e.key] = false;
    });

    // Touch Action Buttons Event Handlers
    touchCannonBtn.addEventListener('click', fireCannon);
    touchGearBtn.addEventListener('click', toggleGear);
    touchFlapsBtn.addEventListener('click', toggleFlaps);
    touchCamBtn.addEventListener('click', () => {
      cameraMode = cameraMode === 'chase' ? 'cockpit' : 'chase';
    });

    function toggleGear() {
      plane.gearDown = !plane.gearDown;
      if (touchGearLabel) touchGearLabel.textContent = plane.gearDown ? '🛞 GEAR (DN)' : '🛞 GEAR (UP)';
    }

    function toggleFlaps() {
      plane.flapsDown = !plane.flapsDown;
      if (touchFlapsLabel) touchFlapsLabel.textContent = plane.flapsDown ? '✈️ FLAPS (DN)' : '✈️ FLAPS (UP)';
    }

    // Start Loop
    mainLoop();
  </script>
</Layout>
