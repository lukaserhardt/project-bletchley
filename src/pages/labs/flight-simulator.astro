---
import Layout from '../../layouts/Layout.astro';
import { Plane, Compass, Volume2, VolumeX, RefreshCw, Play, Pause, Zap, Trophy, ShieldAlert, Camera, Flame, Navigation, Maximize, Minimize, X } from '@lucide/astro';
---

<Layout title="Project Bletchley - 16-Bit Flight Simulator" description="Retro 16-bit flight simulator with fullscreen touch cockpit, vertical throttle lever, F-14 fighter jet sprite, 3D target ring beacons, and landing approach missions.">
  <div class="space-y-8 flex-grow flex flex-col relative">
    
    <!-- Hero Background Glow Blobs -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground">Labs</span>
      <span>/</span>
      <span class="text-foreground font-bold">16-Bit Flight Simulator</span>
    </nav>

    <!-- Page Header -->
    <header class="border-b border-border pb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-start gap-4">
        <div class="p-3 bg-primary/10 rounded-xl text-primary mt-1 border border-primary/20 shrink-0">
          <Plane class="w-8 h-8" />
        </div>
        <div>
          <div class="flex items-center gap-2">
            <h1 class="text-3xl font-extrabold tracking-tight">16-Bit Flight Simulator</h1>
            <span class="bg-primary/20 text-primary font-mono text-xs font-semibold px-2.5 py-0.5 rounded-full border border-primary/30">
              Node 11 // Mode-7 3D
            </span>
          </div>
          <p class="text-sm text-muted mt-2 max-w-2xl leading-relaxed">
            Full-screen touch flight simulator. All flight controls including vertical throttle lever, touch joystick, gear/flaps, and plasma cannons directly visible on screen.
          </p>
        </div>
      </div>

      <!-- Header Action Controls -->
      <div class="flex items-center gap-2 shrink-0">
        <button
          id="fullscreen-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
          title="Toggle Fullscreen Immersive Mode"
        >
          <Maximize id="fullscreen-icon-enter" class="w-4 h-4 text-primary" />
          <Minimize id="fullscreen-icon-exit" class="w-4 h-4 text-primary hidden" />
          <span id="fullscreen-label">Fullscreen</span>
        </button>
        <button
          id="camera-toggle-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
        >
          <Camera class="w-4 h-4 text-primary" />
          <span id="camera-label">Chase Cam</span>
        </button>
        <button
          id="sound-toggle-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
        >
          <Volume2 id="sound-icon-on" class="w-4 h-4 text-primary" />
          <VolumeX id="sound-icon-off" class="w-4 h-4 text-muted hidden" />
          <span id="sound-label" class="hidden sm:inline">SFX On</span>
        </button>
        <button
          id="reset-flight-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
        >
          <RefreshCw class="w-4 h-4" />
          <span>Reset</span>
        </button>
      </div>
    </header>

    <!-- Main Simulator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch flex-grow">
      
      <!-- Pre-Flight Setup Sidebar -->
      <section class="lg:col-span-4 border border-border bg-card p-6 rounded-xl space-y-6 flex flex-col justify-between shadow-sm">
        <div class="space-y-6">
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider border-b border-border pb-2 text-foreground flex items-center justify-between">
            <span>Pre-Flight Avionics & Setup</span>
            <span class="text-xs text-primary font-normal font-mono" id="mission-badge">Free Flight</span>
          </h2>

          <div class="space-y-5">
            <!-- Mission Selection -->
            <div class="space-y-2">
              <label class="block font-mono text-xs uppercase tracking-wider text-muted">Flight Mission</label>
              <div class="grid grid-cols-3 gap-1.5 font-mono text-xs">
                <button
                  type="button"
                  id="mission-free"
                  class="mission-btn border border-primary bg-primary/10 text-primary p-2 rounded-md transition-all font-semibold cursor-pointer text-center"
                >
                  Free Flight
                </button>
                <button
                  type="button"
                  id="mission-rings"
                  class="mission-btn border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-all font-semibold cursor-pointer text-center"
                >
                  Ring Course
                </button>
                <button
                  type="button"
                  id="mission-landing"
                  class="mission-btn border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-all font-semibold cursor-pointer text-center"
                >
                  Landing
                </button>
              </div>
            </div>

            <!-- Sky Atmosphere Switcher -->
            <div class="space-y-2">
              <label class="block font-mono text-xs uppercase tracking-wider text-muted">Sky & Environment</label>
              <div class="grid grid-cols-3 gap-1.5 font-mono text-xs">
                <button type="button" data-time="day" class="sky-btn border border-primary bg-primary/10 text-primary p-1.5 rounded-md transition-all font-semibold cursor-pointer text-center">Daylight</button>
                <button type="button" data-time="sunset" class="sky-btn border border-border bg-background text-muted p-1.5 rounded-md transition-all cursor-pointer text-center">Sunset</button>
                <button type="button" data-time="night" class="sky-btn border border-border bg-background text-muted p-1.5 rounded-md transition-all cursor-pointer text-center">Cyber Night</button>
              </div>
            </div>

            <!-- Engine Throttle Slider -->
            <div class="space-y-1.5 border-t border-border/60 pt-3">
              <div class="flex justify-between text-xs font-mono">
                <span class="uppercase tracking-wider text-muted flex items-center gap-1">
                  <Zap class="w-3.5 h-3.5 text-amber-500" /> Engine Throttle
                </span>
                <span id="throttle-val-text" class="font-bold text-primary">60%</span>
              </div>
              <input
                type="range"
                id="throttle-slider"
                min="0"
                max="100"
                value="60"
                step="1"
                class="w-full h-2 bg-border appearance-none cursor-pointer accent-primary rounded-lg"
              />
            </div>

            <!-- Gear & Flaps Quick Controls -->
            <div class="grid grid-cols-2 gap-2 font-mono text-xs border-t border-border/60 pt-3">
              <button
                type="button"
                id="gear-toggle-btn"
                class="border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-colors font-semibold cursor-pointer flex items-center justify-between"
              >
                <span>Landing Gear [G]</span>
                <span id="gear-status" class="text-emerald-500 font-bold">DOWN</span>
              </button>
              <button
                type="button"
                id="flaps-toggle-btn"
                class="border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-colors font-semibold cursor-pointer flex items-center justify-between"
              >
                <span>Flaps [F]</span>
                <span id="flaps-status" class="text-muted font-bold">UP</span>
              </button>
            </div>
          </div>

          <!-- Real-Time Telemetry -->
          <div class="border border-border/80 bg-background/50 p-4 rounded-xl space-y-3 font-mono text-xs">
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Airspeed</span>
              <span id="telemetry-speed" class="font-bold text-foreground text-sm">90 KTS</span>
            </div>
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Altitude (ALT)</span>
              <span id="telemetry-alt" class="font-bold text-primary text-sm">850 FT</span>
            </div>
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Heading (HDG)</span>
              <span id="telemetry-hdg" class="font-bold text-foreground">045° NNE</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-muted uppercase tracking-wider">Mission Target</span>
              <span id="telemetry-mission" class="font-bold text-amber-500">Free Exploration</span>
            </div>
          </div>
        </div>

        <div class="font-mono text-xs text-muted border-t border-border pt-4 leading-relaxed space-y-2">
          <div class="flex items-center gap-1.5 text-foreground font-semibold">
            <span>🕹️ Fullscreen Touch Flight:</span>
          </div>
          <p>Tapping <strong>Take Off Now</strong> enters full-screen flight mode where all yoke gestures, vertical throttle lever, gear, flaps, and cannon buttons are visible simultaneously.</p>
        </div>
      </section>

      <!-- Main Flight Screen & Cockpit Canvas -->
      <section class="lg:col-span-8 border border-border bg-card rounded-xl overflow-hidden shadow-sm flex flex-col items-stretch min-h-[560px]" id="flight-section">
        
        <!-- Screen Header Status Bar -->
        <div class="border-b border-border bg-background px-4 py-3 font-mono text-xs flex items-center justify-between gap-2">
          <div class="flex items-center gap-3">
            <span class="text-primary font-bold tracking-wider uppercase flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
              <span id="flight-status-text">Level Cruise // 850 FT</span>
            </span>
          </div>
          
          <div class="flex items-center gap-3">
            <span id="stall-warning" class="text-rose-500 font-bold font-mono text-xs animate-pulse hidden flex items-center gap-1">
              <ShieldAlert class="w-4 h-4" /> STALL WARNING
            </span>
            <button 
              id="pause-btn"
              class="border border-border bg-card hover:bg-background text-foreground font-mono text-xs px-3 py-1 rounded-md transition-colors cursor-pointer hover:border-primary flex items-center gap-1"
            >
              <Pause id="pause-icon" class="w-3.5 h-3.5 text-primary" />
              <Play id="play-icon" class="w-3.5 h-3.5 text-primary hidden" />
              <span id="pause-text">Pause</span>
            </button>
          </div>
        </div>

        <!-- Flight Viewport & Canvas Area -->
        <div class="flex-grow bg-[#020617] relative flex flex-col items-center justify-center overflow-hidden select-none" id="viewport-wrapper">
          
          <canvas id="flight-canvas" class="w-full h-full block min-h-[460px] touch-none"></canvas>

          <!-- Cockpit HUD Overlay -->
          <div class="absolute inset-0 pointer-events-none p-3 sm:p-4 flex flex-col justify-between z-10 font-mono text-xs">
            
            <!-- Top HUD Bar -->
            <div class="flex justify-between items-start gap-2">
              <!-- Horizon Bar -->
              <div class="bg-black/75 backdrop-blur-md border border-primary/40 px-3 py-2 rounded-lg text-primary space-y-1 shrink-0">
                <div class="text-[10px] uppercase text-muted tracking-wider">Artificial Horizon</div>
                <div class="w-24 sm:w-28 h-2 bg-primary/20 relative overflow-hidden rounded border border-primary/40">
                  <div id="hud-pitch-bar" class="absolute inset-x-0 h-full bg-primary transition-all duration-75"></div>
                </div>
              </div>

              <!-- Center Wayfinding Target Box -->
              <div class="bg-black/85 backdrop-blur-md border border-amber-500/50 px-3 py-1.5 rounded-lg text-amber-400 font-mono text-xs font-bold tracking-wider flex items-center gap-2 shadow-lg" id="hud-wayfinding-box">
                <Navigation class="w-4 h-4 text-amber-500 animate-pulse shrink-0" />
                <span id="hud-wayfinding-text">TARGET: FREE FLIGHT</span>
              </div>

              <!-- Radar Minimap -->
              <div class="w-20 h-20 sm:w-24 sm:h-24 bg-black/85 border border-primary/50 rounded-full relative overflow-hidden flex items-center justify-center shadow-lg shrink-0">
                <div class="absolute inset-2 border border-primary/20 rounded-full"></div>
                <div class="absolute inset-6 border border-primary/15 rounded-full"></div>
                <div class="absolute inset-x-0 top-1/2 h-[1px] bg-primary/30"></div>
                <div class="absolute inset-y-0 left-1/2 w-[1px] bg-primary/30"></div>
                <div class="w-2 h-2 bg-primary rounded-full z-10 shadow-[0_0_8px_var(--primary)]"></div>
                <div id="radar-blips" class="absolute inset-0"></div>
              </div>
            </div>

            <!-- Bottom Touch Cockpit HUD Controls (ALL-IN-ONE VISIBLE TOUCH CONTROLS) -->
            <div class="flex justify-between items-end gap-3 pointer-events-auto">
              
              <!-- Left Touch Telemetry & View Controls -->
              <div class="flex flex-col gap-2">
                <div class="bg-black/80 backdrop-blur-md border border-border px-3 py-1.5 rounded-lg text-muted pointer-events-none hidden sm:block">
                  <span>GEAR: <strong id="hud-gear-val" class="text-emerald-400">DOWN</strong></span> | 
                  <span>FLAPS: <strong id="hud-flaps-val" class="text-muted">UP</strong></span>
                </div>
              </div>

              <!-- Right Touch Controls: Vertical Throttle Lever + Action Buttons -->
              <div class="flex items-end gap-3">
                
                <!-- Vertical Touch Throttle Slider -->
                <div id="touch-throttle-box" class="flex flex-col items-center gap-1 bg-black/85 backdrop-blur-md p-2 rounded-xl border border-primary/50 select-none shadow-xl">
                  <span class="text-[10px] font-mono text-amber-400 font-bold uppercase tracking-wider">THROTTLE</span>
                  <div id="touch-throttle-track" class="w-7 h-28 sm:h-32 bg-primary/20 border border-primary/50 rounded-lg relative overflow-hidden touch-none cursor-pointer">
                    <div id="touch-throttle-bar" class="absolute bottom-0 inset-x-0 bg-primary/80 transition-all duration-75"></div>
                    <div id="touch-throttle-knob" class="absolute inset-x-0 h-4 bg-amber-400 rounded border border-white shadow-md transition-all duration-75" style="bottom: 60%"></div>
                  </div>
                  <span id="touch-throttle-val" class="text-[11px] font-mono text-white font-bold">60%</span>
                </div>

                <!-- Touch Action Buttons Column (Gear, Flaps, Cannon) -->
                <div class="flex flex-col gap-2">
                  <div class="flex items-center gap-2">
                    <button
                      id="touch-gear-btn"
                      class="bg-black/85 hover:bg-primary/20 border border-border hover:border-primary text-foreground font-mono text-xs px-3 py-2 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg select-none"
                    >
                      <span id="touch-gear-label">🛞 GEAR</span>
                    </button>
                    <button
                      id="touch-flaps-btn"
                      class="bg-black/85 hover:bg-primary/20 border border-border hover:border-primary text-foreground font-mono text-xs px-3 py-2 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg select-none"
                    >
                      <span id="touch-flaps-label">✈️ FLAPS</span>
                    </button>
                  </div>
                  <button
                    id="touch-cannon-btn"
                    class="w-full bg-rose-600 hover:bg-rose-500 text-white font-mono text-xs font-bold py-3 px-4 rounded-xl transition-all active:scale-95 cursor-pointer shadow-lg flex items-center justify-center gap-1.5 select-none"
                  >
                    <Flame class="w-4 h-4 fill-white" />
                    <span>FIRE CANNON</span>
                  </button>
                </div>

              </div>

            </div>

          </div>

          <!-- Overlay Start / Crash Dialog -->
          <div id="flight-overlay" class="absolute inset-0 bg-black/85 backdrop-blur-sm flex flex-col items-center justify-center p-6 text-center z-20 transition-all duration-300">
            <div class="space-y-4 max-w-md">
              <div class="w-14 h-14 rounded-2xl bg-primary/20 border border-primary/40 flex items-center justify-center mx-auto text-primary">
                <Plane class="w-7 h-7" />
              </div>
              <h3 id="overlay-title" class="text-2xl font-extrabold tracking-tight text-white font-mono uppercase">
                16-BIT FLIGHT SIMULATOR
              </h3>
              <p id="overlay-desc" class="text-sm text-muted leading-relaxed font-sans">
                Take off into retro 3D skies. Fullscreen touch cockpit with vertical throttle lever, touch joystick gestures, and plasma cannon FX.
              </p>
              <button
                id="start-flight-btn"
                class="w-full bg-primary hover:bg-primary/90 text-white font-mono font-bold py-3 px-6 rounded-xl transition-transform active:scale-95 shadow-lg cursor-pointer text-sm tracking-wider uppercase flex items-center justify-center gap-2"
              >
                <Play class="w-4 h-4" />
                <span>Take Off Now (Fullscreen)</span>
              </button>
            </div>
          </div>

        </div>

      </section>

    </div>
  </div>

  <script>
    // --- 16-BIT FLIGHT SIMULATOR ENGINE ---
    const canvas = document.getElementById('flight-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const wrapper = document.getElementById('viewport-wrapper')!;
    const flightSection = document.getElementById('flight-section')!;

    // UI Elements
    const flightStatusEl = document.getElementById('flight-status-text')!;
    const stallWarningEl = document.getElementById('stall-warning')!;
    const telemetrySpeedEl = document.getElementById('telemetry-speed')!;
    const telemetryAltEl = document.getElementById('telemetry-alt')!;
    const telemetryHdgEl = document.getElementById('telemetry-hdg')!;
    const telemetryAttitudeEl = document.getElementById('telemetry-attitude')!;
    const telemetryMissionEl = document.getElementById('telemetry-mission')!;
    const missionBadgeEl = document.getElementById('mission-badge')!;

    // HUD Elements
    const hudPitchBar = document.getElementById('hud-pitch-bar')!;
    const hudGearVal = document.getElementById('hud-gear-val')!;
    const hudFlapsVal = document.getElementById('hud-flaps-val')!;
    const radarBlipsEl = document.getElementById('radar-blips')!;
    const cameraLabel = document.getElementById('camera-label')!;
    const hudWayfindingText = document.getElementById('hud-wayfinding-text')!;

    // Fullscreen Elements
    const fullscreenBtn = document.getElementById('fullscreen-btn')!;
    const fullscreenIconEnter = document.getElementById('fullscreen-icon-enter')!;
    const fullscreenIconExit = document.getElementById('fullscreen-icon-exit')!;
    const fullscreenLabel = document.getElementById('fullscreen-label')!;

    // Overlay
    const overlay = document.getElementById('flight-overlay')!;
    const overlayTitle = document.getElementById('overlay-title')!;
    const overlayDesc = document.getElementById('overlay-desc')!;
    const startFlightBtn = document.getElementById('start-flight-btn')!;

    // Controls UI
    const pauseBtn = document.getElementById('pause-btn')!;
    const pauseIcon = document.getElementById('pause-icon')!;
    const playIcon = document.getElementById('play-icon')!;
    const pauseText = document.getElementById('pause-text')!;
    const resetFlightBtn = document.getElementById('reset-flight-btn')!;
    const cameraToggleBtn = document.getElementById('camera-toggle-btn')!;
    const soundToggleBtn = document.getElementById('sound-toggle-btn')!;
    const soundIconOn = document.getElementById('sound-icon-on')!;
    const soundIconOff = document.getElementById('sound-icon-off')!;
    const soundLabel = document.getElementById('sound-label')!;

    const throttleSlider = document.getElementById('throttle-slider') as HTMLInputElement;
    const throttleValText = document.getElementById('throttle-val-text')!;
    const gearToggleBtn = document.getElementById('gear-toggle-btn')!;
    const gearStatusEl = document.getElementById('gear-status')!;
    const flapsToggleBtn = document.getElementById('flaps-toggle-btn')!;
    const flapsStatusEl = document.getElementById('flaps-status')!;

    // Touch Controls
    const touchCannonBtn = document.getElementById('touch-cannon-btn')!;
    const touchGearBtn = document.getElementById('touch-gear-btn')!;
    const touchGearLabel = document.getElementById('touch-gear-label')!;
    const touchFlapsBtn = document.getElementById('touch-flaps-btn')!;
    const touchFlapsLabel = document.getElementById('touch-flaps-label')!;

    const touchThrottleTrack = document.getElementById('touch-throttle-track')!;
    const touchThrottleBar = document.getElementById('touch-throttle-bar')!;
    const touchThrottleKnob = document.getElementById('touch-throttle-knob')!;
    const touchThrottleVal = document.getElementById('touch-throttle-val')!;

    // --- Web Audio SFX Engine ---
    let soundEnabled = true;
    let audioCtx: AudioContext | null = null;
    let engineOsc: OscillatorNode | null = null;
    let engineGain: GainNode | null = null;

    function getAudioCtx() {
      if (!audioCtx) {
        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
        audioCtx = new AudioContextClass();
      }
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      return audioCtx;
    }

    function initEngineSound() {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioCtx();
        if (!engineOsc) {
          engineOsc = ctx.createOscillator();
          engineGain = ctx.createGain();

          engineOsc.type = 'sawtooth';
          engineOsc.frequency.setValueAtTime(55, ctx.currentTime);
          engineGain.gain.setValueAtTime(0.04, ctx.currentTime);

          engineOsc.connect(engineGain);
          engineGain.connect(ctx.destination);
          engineOsc.start();
        }
      } catch (e) {}
    }

    function updateEngineSound(throttlePct: number) {
      if (!soundEnabled || !engineOsc || !engineGain) return;
      try {
        const freq = 45 + throttlePct * 1.5;
        engineOsc.frequency.setTargetAtTime(freq, getAudioCtx().currentTime, 0.1);
      } catch (e) {}
    }

    function playSFX(type: 'cannon' | 'ring' | 'stall' | 'crash' | 'land') {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioCtx();
        const now = ctx.currentTime;

        if (type === 'cannon') {
          [0, 0.05].forEach((offset) => {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'square';
            osc.frequency.setValueAtTime(450, now + offset);
            osc.frequency.exponentialRampToValueAtTime(90, now + offset + 0.08);
            gain.gain.setValueAtTime(0.35, now + offset);
            gain.gain.exponentialRampToValueAtTime(0.01, now + offset + 0.08);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start(now + offset);
            osc.stop(now + offset + 0.08);
          });
        } else if (type === 'ring') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'triangle';
          osc.frequency.setValueAtTime(523.25, now);
          osc.frequency.setValueAtTime(783.99, now + 0.08);
          gain.gain.setValueAtTime(0.25, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now + 0.08);
          osc.stop(now + 0.2);
        } else if (type === 'land') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sine';
          osc.frequency.setValueAtTime(440, now);
          osc.frequency.setValueAtTime(659.25, now + 0.1);
          gain.gain.setValueAtTime(0.3, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.35);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.35);
        } else if (type === 'crash') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sawtooth';
          osc.frequency.setValueAtTime(140, now);
          osc.frequency.linearRampToValueAtTime(35, now + 0.5);
          gain.gain.setValueAtTime(0.4, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.5);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.5);
        }
      } catch (e) {}
    }

    soundToggleBtn.addEventListener('click', () => {
      soundEnabled = !soundEnabled;
      if (soundEnabled) {
        soundIconOn.classList.remove('hidden');
        soundIconOff.classList.add('hidden');
        soundLabel.textContent = 'SFX On';
        initEngineSound();
      } else {
        soundIconOn.classList.add('hidden');
        soundIconOff.classList.remove('hidden');
        soundLabel.textContent = 'Muted';
        if (engineGain) engineGain.gain.value = 0;
      }
    });

    // --- State Variables ---
    let width = 800;
    let height = 450;

    let isPlaying = false;
    let isPaused = false;
    let isCrashed = false;
    let isLanded = false;
    let isFullscreen = false;

    let currentMission = 'free';
    let skyTheme = 'day';
    let cameraMode = 'chase';

    // Plane Flight Physics State
    const plane = {
      x: 0,
      y: 850,
      z: 0,
      pitch: 0,
      roll: 0,
      yaw: 45,
      speed: 90,
      throttle: 60,
      gearDown: false,
      flapsDown: false,
      stalling: false,
      muzzleFlash: 0,
      recoilShake: 0
    };

    // Cannon Plasma Tracer Bolts
    let bullets: { x: number; y: number; z: number; vx: number; vy: number; vz: number; life: number; side: number }[] = [];

    // Target Rings & Wayfinding
    let targetRings: { id: number; x: number; y: number; z: number; radius: number; passed: boolean }[] = [];
    let ringsPassedCount = 0;

    // Runway 3D Location
    const runway = {
      x: 0,
      z: 1200,
      length: 1400,
      width: 180
    };

    // Sky Color Palettes
    const skyPalettes = {
      day: {
        skyTop: '#1e3a8a',
        skyBottom: '#38bdf8',
        groundBase: '#15803d',
        gridLine: '#16a34a'
      },
      sunset: {
        skyTop: '#4c1d95',
        skyBottom: '#f97316',
        groundBase: '#7c2d12',
        gridLine: '#ea580c'
      },
      night: {
        skyTop: '#020617',
        skyBottom: '#1e1b4b',
        groundBase: '#09090b',
        gridLine: '#6366f1'
      }
    };

    // Keyboard & Virtual Touch States
    const keys: Record<string, boolean> = {};

    // Touch Joystick State
    const touchYoke = {
      active: false,
      startX: 0,
      startY: 0,
      pitchInput: 0,
      rollInput: 0,
      touchId: null as number | null
    };

    // --- Responsive Canvas Setup & Fullscreen ---
    function resizeCanvas() {
      const rect = wrapper.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;

      width = rect.width;
      height = Math.max(380, rect.height);

      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.scale(dpr, dpr);
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function toggleFullscreen() {
      isFullscreen = !isFullscreen;
      if (isFullscreen) {
        if (wrapper.requestFullscreen) {
          wrapper.requestFullscreen().catch(() => {});
        } else if ((wrapper as any).webkitRequestFullscreen) {
          (wrapper as any).webkitRequestFullscreen();
        }
        wrapper.classList.add('fixed', 'inset-0', 'z-50', 'w-screen', 'h-screen');
        fullscreenIconEnter.classList.add('hidden');
        fullscreenIconExit.classList.remove('hidden');
        fullscreenLabel.textContent = 'Exit';
      } else {
        if (document.exitFullscreen) {
          document.exitFullscreen().catch(() => {});
        } else if ((document as any).webkitExitFullscreen) {
          (document as any).webkitExitFullscreen();
        }
        wrapper.classList.remove('fixed', 'inset-0', 'z-50', 'w-screen', 'h-screen');
        fullscreenIconEnter.classList.remove('hidden');
        fullscreenIconExit.classList.add('hidden');
        fullscreenLabel.textContent = 'Fullscreen';
      }
      setTimeout(resizeCanvas, 100);
    }

    fullscreenBtn.addEventListener('click', toggleFullscreen);

    // --- Mission Builder ---
    function initMission() {
      ringsPassedCount = 0;
      targetRings = [];

      if (currentMission === 'rings') {
        for (let i = 0; i < 8; i++) {
          const angle = (i / 8) * Math.PI * 1.2;
          const dist = 600 + i * 450;
          targetRings.push({
            id: i + 1,
            x: Math.sin(angle) * dist,
            y: 550 + Math.sin(i * 1.4) * 220,
            z: Math.cos(angle) * dist + 350,
            radius: 95,
            passed: false
          });
        }
        telemetryMissionEl.textContent = 'Rings: 0 / 8';
      } else if (currentMission === 'landing') {
        plane.x = 0;
        plane.y = 400;
        plane.z = -700;
        plane.pitch = -2;
        plane.speed = 85;
        plane.gearDown = true;
        plane.flapsDown = true;
        gearStatusEl.textContent = 'DOWN';
        flapsStatusEl.textContent = 'DOWN';
        hudGearVal.textContent = 'DOWN';
        hudFlapsVal.textContent = 'DOWN';
        touchGearLabel.textContent = '🛞 GEAR (DN)';
        touchFlapsLabel.textContent = '✈️ FLAPS (DN)';
        telemetryMissionEl.textContent = 'Runway Approach';
      } else {
        telemetryMissionEl.textContent = 'Free Exploration';
      }
    }

    function updateThrottleUI(pct: number) {
      plane.throttle = Math.max(0, Math.min(100, pct));
      throttleSlider.value = String(Math.round(plane.throttle));
      throttleValText.textContent = `${Math.round(plane.throttle)}%`;

      touchThrottleBar.style.height = `${plane.throttle}%`;
      touchThrottleKnob.style.bottom = `${Math.max(0, Math.min(85, plane.throttle * 0.85))}%`;
      touchThrottleVal.textContent = `${Math.round(plane.throttle)}%`;
    }

    function resetFlight() {
      plane.x = 0;
      plane.y = 850;
      plane.z = 0;
      plane.pitch = 0;
      plane.roll = 0;
      plane.yaw = 45;
      plane.speed = 90;
      plane.gearDown = false;
      plane.flapsDown = false;
      plane.stalling = false;
      plane.muzzleFlash = 0;
      plane.recoilShake = 0;

      updateThrottleUI(60);

      gearStatusEl.textContent = 'UP';
      flapsStatusEl.textContent = 'UP';
      hudGearVal.textContent = 'UP';
      hudFlapsVal.textContent = 'UP';
      touchGearLabel.textContent = '🛞 GEAR (UP)';
      touchFlapsLabel.textContent = '✈️ FLAPS (UP)';

      isCrashed = false;
      isLanded = false;
      isPaused = false;
      isPlaying = true;

      bullets = [];

      initMission();
      hideOverlay();
      flightStatusEl.textContent = 'Level Cruise // 850 FT';
      stallWarningEl.classList.add('hidden');
      initEngineSound();
    }

    function showOverlay(title: string, desc: string, btnText: string) {
      overlayTitle.textContent = title;
      overlayDesc.textContent = desc;
      startFlightBtn.querySelector('span')!.textContent = btnText;
      overlay.classList.remove('opacity-0', 'pointer-events-none');
    }

    function hideOverlay() {
      overlay.classList.add('opacity-0', 'pointer-events-none');
    }

    // --- Camera View Toggle ---
    cameraToggleBtn.addEventListener('click', () => {
      cameraMode = cameraMode === 'chase' ? 'cockpit' : 'chase';
      cameraLabel.textContent = cameraMode === 'chase' ? 'Chase Cam' : 'Cockpit HUD';
    });

    // --- Cannon Plasma Laser Fire ---
    function fireCannon() {
      if (!isPlaying || isCrashed) return;
      playSFX('cannon');
      plane.muzzleFlash = 5;
      plane.recoilShake = 4;

      const radYaw = (plane.yaw * Math.PI) / 180;
      const radPitch = (plane.pitch * Math.PI) / 180;

      const speed = 24;

      bullets.push({
        x: plane.x - Math.cos(radYaw) * 16,
        y: plane.y - 4,
        z: plane.z - Math.sin(radYaw) * 16,
        vx: Math.sin(radYaw) * speed,
        vy: Math.sin(radPitch) * speed,
        vz: Math.cos(radYaw) * speed,
        life: 50,
        side: -1
      });

      bullets.push({
        x: plane.x + Math.cos(radYaw) * 16,
        y: plane.y - 4,
        z: plane.z + Math.sin(radYaw) * 16,
        vx: Math.sin(radYaw) * speed,
        vy: Math.sin(radPitch) * speed,
        vz: Math.cos(radYaw) * speed,
        life: 50,
        side: 1
      });
    }

    // --- Flight Dynamics Physics Loop ---
    function updatePhysics(dt: number) {
      if (!isPlaying || isPaused || isCrashed) return;

      // 1. Read Inputs
      let pitchInput = touchYoke.pitchInput;
      let rollInput = touchYoke.rollInput;

      if (keys['w'] || keys['W'] || keys['ArrowUp']) pitchInput -= 1;
      if (keys['s'] || keys['S'] || keys['ArrowDown']) pitchInput += 1;
      if (keys['a'] || keys['A'] || keys['ArrowLeft']) rollInput -= 1;
      if (keys['d'] || keys['D'] || keys['ArrowRight']) rollInput += 1;

      if (keys['i'] || keys['I']) updateThrottleUI(plane.throttle + 1.2 * dt);
      if (keys['k'] || keys['K']) updateThrottleUI(plane.throttle - 1.2 * dt);

      plane.pitch += pitchInput * 1.8 * dt;
      plane.roll += rollInput * 2.5 * dt;

      plane.yaw += (plane.roll * 0.04) * dt;

      if (rollInput === 0 && !touchYoke.active) plane.roll *= 0.92;
      if (pitchInput === 0 && !touchYoke.active) plane.pitch *= 0.93;

      plane.pitch = Math.max(-45, Math.min(45, plane.pitch));
      plane.roll = Math.max(-75, Math.min(75, plane.roll));
      plane.yaw = (plane.yaw + 360) % 360;

      if (plane.muzzleFlash > 0) plane.muzzleFlash -= 1;
      if (plane.recoilShake > 0) plane.recoilShake *= 0.8;

      // 2. Speed & Movement
      const targetSpeed = 45 + plane.throttle * 1.5 + (plane.flapsDown ? -18 : 0);
      plane.speed += (targetSpeed - plane.speed) * 0.04 * dt;

      const radPitch = (plane.pitch * Math.PI) / 180;
      const radYaw = (plane.yaw * Math.PI) / 180;

      const climbRate = Math.sin(radPitch) * plane.speed * 0.25;
      plane.y += climbRate * dt;

      plane.x += Math.sin(radYaw) * plane.speed * 0.06 * dt;
      plane.z += Math.cos(radYaw) * plane.speed * 0.06 * dt;

      // Stall Check
      if (plane.speed < 48 && plane.pitch > 15) {
        plane.stalling = true;
        stallWarningEl.classList.remove('hidden');
        plane.y -= 10 * dt;
        playSFX('stall');
      } else {
        plane.stalling = false;
        stallWarningEl.classList.add('hidden');
      }

      // 3. Touchdown System
      if (plane.y <= 0) {
        plane.y = 0;

        const distRunwayX = Math.abs(plane.x - runway.x);
        const distRunwayZ = Math.abs(plane.z - runway.z);

        if (
          plane.gearDown &&
          distRunwayX < runway.width &&
          distRunwayZ < runway.length &&
          plane.speed < 115 &&
          Math.abs(plane.pitch) < 18 &&
          Math.abs(plane.roll) < 18
        ) {
          isLanded = true;
          isPlaying = false;
          playSFX('land');
          flightStatusEl.textContent = 'Touchdown Complete';
          showOverlay('TOUCHDOWN SUCCESSFUL!', `Smooth touchdown at ${Math.round(plane.speed)} KTS on Runway 09!`, 'Fly Again');
        } else {
          isCrashed = true;
          isPlaying = false;
          playSFX('crash');
          flightStatusEl.textContent = 'CRASH DETECTED';
          showOverlay('AIRCRAFT CRASHED', `Ground impact at ${Math.round(plane.speed)} KTS. Keep pitch level and lower gear [G] for landing.`, 'Try Again');
        }
      }

      // 4. Mission Target Rings & Wayfinding
      if (currentMission === 'rings') {
        const nextRing = targetRings.find(r => !r.passed);

        if (nextRing) {
          const dx = nextRing.x - plane.x;
          const dy = nextRing.y - plane.y;
          const dz = nextRing.z - plane.z;
          const dist = Math.round(Math.sqrt(dx * dx + dy * dy + dz * dz));

          const ringHdg = Math.round((Math.atan2(dx, dz) * (180 / Math.PI) + 360) % 360);
          let hdgDiff = ringHdg - plane.yaw;
          if (hdgDiff > 180) hdgDiff -= 360;
          if (hdgDiff < -180) hdgDiff += 360;

          let arrow = '⬆';
          if (hdgDiff > 30) arrow = '➡️';
          else if (hdgDiff < -30) arrow = '⬅';

          hudWayfindingText.textContent = `${arrow} RING #${nextRing.id}: ${dist}m (HDG ${String(ringHdg).padStart(3, '0')}°)`;

          if (dist < nextRing.radius + 35) {
            nextRing.passed = true;
            ringsPassedCount++;
            playSFX('ring');
            telemetryMissionEl.textContent = `Rings: ${ringsPassedCount} / 8`;

            if (ringsPassedCount >= 8) {
              showOverlay('COURSE CLEARED!', 'Outstanding flying! All 8 target rings cleared with 16-bit precision!', 'Next Flight');
            }
          }
        }
      } else if (currentMission === 'landing') {
        const distRunway = Math.round(Math.abs(runway.z - plane.z));
        hudWayfindingText.textContent = `🛬 RUNWAY 09: ${distRunway}m | ALT ${Math.round(plane.y)} FT`;
      } else {
        hudWayfindingText.textContent = `FREE EXPLORATION // HDG ${String(Math.round(plane.yaw)).padStart(3, '0')}°`;
      }

      // 5. Cannon Plasma Tracer Bolts
      for (let i = bullets.length - 1; i >= 0; i--) {
        const b = bullets[i];
        b.x += b.vx * dt;
        b.y += b.vy * dt;
        b.z += b.vz * dt;
        b.life -= dt;
        if (b.life <= 0) {
          bullets.splice(i, 1);
        }
      }

      updateEngineSound(plane.throttle);

      telemetrySpeedEl.textContent = `${Math.round(plane.speed)} KTS`;
      telemetryAltEl.textContent = `${Math.round(plane.y).toLocaleString()} FT`;

      const hdgDeg = Math.round(plane.yaw);
      const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
      const dirStr = dirs[Math.floor((hdgDeg + 22.5) / 45) % 8];
      telemetryHdgEl.textContent = `${String(hdgDeg).padStart(3, '0')}° ${dirStr}`;
      telemetryAttitudeEl.textContent = `${Math.round(plane.pitch)}° / ${Math.round(plane.roll)}°`;

      hudPitchBar.style.transform = `translateY(${-plane.pitch * 0.8}px) rotate(${-plane.roll}deg)`;

      if (plane.y > 0) {
        flightStatusEl.textContent = `Airborne // ${Math.round(plane.y)} FT`;
      }

      updateRadarUI();
    }

    function updateRadarUI() {
      radarBlipsEl.innerHTML = '';
      if (currentMission === 'rings') {
        targetRings.forEach(ring => {
          if (!ring.passed) {
            const relX = (ring.x - plane.x) / 35;
            const relZ = (ring.z - plane.z) / 35;
            if (Math.abs(relX) < 42 && Math.abs(relZ) < 42) {
              const blip = document.createElement('div');
              blip.className = 'absolute w-2 h-2 bg-amber-400 rounded-full animate-ping';
              blip.style.left = `${44 + relX}px`;
              blip.style.top = `${44 - relZ}px`;
              radarBlipsEl.appendChild(blip);
            }
          }
        });
      }
    }

    // --- Mode-7 Dynamic 3D Renderer ---
    function draw() {
      const palette = skyPalettes[skyTheme as keyof typeof skyPalettes];

      const shakeX = (Math.random() - 0.5) * plane.recoilShake;
      const shakeY = (Math.random() - 0.5) * plane.recoilShake;

      const horizonY = height / 2 + (plane.pitch * 3.5) + shakeY;

      ctx.save();
      ctx.translate(width / 2 + shakeX, horizonY);
      ctx.rotate((-plane.roll * Math.PI) / 180);

      // Sky Background
      ctx.fillStyle = palette.skyTop;
      ctx.fillRect(-width * 1.5, -height * 2.5, width * 3, height * 2.5);

      const skyGlow = ctx.createLinearGradient(0, -120, 0, 0);
      skyGlow.addColorStop(0, palette.skyTop);
      skyGlow.addColorStop(1, palette.skyBottom);
      ctx.fillStyle = skyGlow;
      ctx.fillRect(-width * 1.5, -150, width * 3, 150);

      // Ground Base
      ctx.fillStyle = palette.groundBase;
      ctx.fillRect(-width * 1.5, 0, width * 3, height * 2.5);

      // Mode-7 Scrolling Grid Lines
      ctx.strokeStyle = palette.gridLine;
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = 0.45;

      const gridSize = 140;
      const offsetX = (plane.x % gridSize);
      const offsetZ = (plane.z % gridSize);

      for (let i = -14; i <= 14; i++) {
        const xStart = i * 45 - offsetX * 0.2;
        const xEnd = i * 240 - offsetX * 1.8;
        ctx.beginPath();
        ctx.moveTo(xStart, 0);
        ctx.lineTo(xEnd, height * 2);
        ctx.stroke();
      }

      for (let j = 1; j <= 14; j++) {
        const zPos = (j * 45 - (offsetZ * 0.4)) % 550;
        if (zPos > 0) {
          const yPos = Math.pow(zPos / 22, 1.85) * 3.2;
          if (yPos > 0 && yPos < height * 2) {
            ctx.beginPath();
            ctx.moveTo(-width * 1.5, yPos);
            ctx.lineTo(width * 1.5, yPos);
            ctx.stroke();
          }
        }
      }
      ctx.globalAlpha = 1.0;

      // 3D Runway
      const relRunwayZ = runway.z - plane.z;
      const relRunwayX = runway.x - plane.x;

      if (relRunwayZ > -400 && relRunwayZ < 3500) {
        const scale = 300 / (relRunwayZ + 350);
        const rwScreenX = relRunwayX * scale;
        const rwScreenY = (plane.y + 40) * scale;
        const rwWidth = runway.width * scale;

        ctx.fillStyle = '#334155';
        ctx.fillRect(rwScreenX - rwWidth / 2, rwScreenY, rwWidth, 90 * scale);

        ctx.fillStyle = '#f8fafc';
        ctx.fillRect(rwScreenX - 2, rwScreenY, 4, 90 * scale);
      }

      // 3D Target Rings & Wayfinding Beacons
      if (currentMission === 'rings') {
        const nextRing = targetRings.find(r => !r.passed);

        targetRings.forEach(ring => {
          if (!ring.passed) {
            const dz = ring.z - plane.z;
            const dx = ring.x - plane.x;
            const dy = ring.y - plane.y;

            if (dz > 30 && dz < 3500) {
              const scale = 300 / dz;
              const screenX = dx * scale;
              const screenY = -dy * scale;
              const radiusScreen = ring.radius * scale;

              const isNext = (nextRing && nextRing.id === ring.id);

              if (isNext) {
                const beamGradient = ctx.createLinearGradient(screenX, screenY - 400 * scale, screenX, screenY);
                beamGradient.addColorStop(0, 'rgba(245, 158, 11, 0)');
                beamGradient.addColorStop(1, 'rgba(245, 158, 11, 0.45)');
                ctx.fillStyle = beamGradient;
                ctx.fillRect(screenX - 10 * scale, screenY - 400 * scale, 20 * scale, 400 * scale);
              }

              ctx.strokeStyle = isNext ? '#fbbf24' : '#f59e0b';
              ctx.lineWidth = Math.max(2, (isNext ? 8 : 4) * scale);
              ctx.shadowColor = '#f59e0b';
              ctx.shadowBlur = isNext ? 16 : 6;
              ctx.beginPath();
              ctx.arc(screenX, screenY, Math.max(6, radiusScreen), 0, Math.PI * 2);
              ctx.stroke();
              ctx.shadowBlur = 0;

              ctx.fillStyle = '#ffffff';
              ctx.font = `bold ${Math.max(10, Math.round(14 * scale))}px monospace`;
              ctx.textAlign = 'center';
              ctx.fillText(`#${ring.id}`, screenX, screenY - radiusScreen - 8 * scale);
            }
          }
        });
      }

      // Plasma Cannon Tracers
      bullets.forEach(b => {
        const dz = b.z - plane.z;
        const dx = b.x - plane.x;
        const dy = b.y - plane.y;

        if (dz > 10 && dz < 2500) {
          const scale = 300 / dz;
          const screenX = dx * scale;
          const screenY = -dy * scale;

          ctx.strokeStyle = '#f43f5e';
          ctx.shadowColor = '#f43f5e';
          ctx.shadowBlur = 12;
          ctx.lineWidth = Math.max(3, 6 * scale);

          ctx.beginPath();
          ctx.moveTo(screenX, screenY);
          ctx.lineTo(screenX, screenY - 30 * scale);
          ctx.stroke();
          ctx.shadowBlur = 0;
        }
      });

      ctx.restore();

      // Ground Shadow
      if (plane.y < 900) {
        const shadowAlpha = Math.max(0, 1 - plane.y / 900) * 0.45;
        const shadowOffsetY = Math.min(120, (plane.y / 900) * 100);
        ctx.save();
        ctx.translate(width / 2, height - 90 + shadowOffsetY);
        ctx.rotate((-plane.roll * Math.PI) / 180 * 0.4);
        ctx.fillStyle = `rgba(0, 0, 0, ${shadowAlpha})`;
        ctx.beginPath();
        ctx.ellipse(0, 0, 52, 14, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      // Touch Yoke Indicator Ring
      if (touchYoke.active) {
        ctx.save();
        ctx.translate(touchYoke.startX, touchYoke.startY);
        
        ctx.strokeStyle = 'rgba(99, 102, 241, 0.4)';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.arc(0, 0, 50, 0, Math.PI * 2);
        ctx.stroke();

        const knobX = touchYoke.rollInput * 50;
        const knobY = touchYoke.pitchInput * 50;
        ctx.fillStyle = '#6366f1';
        ctx.shadowColor = '#6366f1';
        ctx.shadowBlur = 12;
        ctx.beginPath();
        ctx.arc(knobX, knobY, 16, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;

        ctx.restore();
      }

      // F-14 Aircraft Sprite
      if (cameraMode === 'chase') {
        drawDetailed16BitFighterJet(width / 2, height - 90, plane.roll, plane.pitch, plane.throttle, plane.gearDown, plane.muzzleFlash);
      }
    }

    // F-14 Tomcat Jet Renderer
    function drawDetailed16BitFighterJet(x: number, y: number, roll: number, pitch: number, throttle: number, gearDown: boolean, muzzleFlash: number) {
      ctx.save();
      ctx.translate(x, y);
      
      ctx.rotate((roll * Math.PI) / 180);
      const pitchScaleY = 1 - Math.sin((pitch * Math.PI) / 180) * 0.25;
      ctx.scale(1, pitchScaleY);

      if (muzzleFlash > 0) {
        ctx.fillStyle = '#fef08a';
        ctx.shadowColor = '#fef08a';
        ctx.shadowBlur = 20;
        ctx.beginPath();
        ctx.arc(-62, 14, 10, 0, Math.PI * 2);
        ctx.arc(62, 14, 10, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      ctx.fillStyle = '#334155';
      ctx.strokeStyle = '#64748b';
      ctx.lineWidth = 1.5;

      ctx.beginPath();
      ctx.moveTo(0, -32);
      ctx.lineTo(64, 16);
      ctx.lineTo(22, 12);
      ctx.lineTo(24, 32);
      ctx.lineTo(-24, 32);
      ctx.lineTo(-22, 12);
      ctx.lineTo(-64, 16);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = '#475569';
      ctx.beginPath();
      ctx.moveTo(0, -18);
      ctx.lineTo(44, 14);
      ctx.lineTo(14, 10);
      ctx.lineTo(-14, 10);
      ctx.lineTo(-44, 14);
      ctx.closePath();
      ctx.fill();

      ctx.fillStyle = '#64748b';
      ctx.beginPath();
      ctx.ellipse(0, 0, 12, 34, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = '#38bdf8';
      ctx.shadowColor = '#38bdf8';
      ctx.shadowBlur = 10;
      ctx.beginPath();
      ctx.ellipse(0, -12, 6, 14, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;

      // Nav Lights
      ctx.fillStyle = '#ef4444';
      ctx.shadowColor = '#ef4444';
      ctx.shadowBlur = 6;
      ctx.beginPath();
      ctx.arc(-63, 15, 3, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = '#22c55e';
      ctx.shadowColor = '#22c55e';
      ctx.shadowBlur = 6;
      ctx.beginPath();
      ctx.arc(63, 15, 3, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;

      // Thrust Flame
      if (throttle > 10) {
        const flameLen = 14 + (throttle / 100) * 32 + Math.random() * 8;

        ctx.fillStyle = '#f97316';
        ctx.beginPath();
        ctx.moveTo(-10, 32);
        ctx.lineTo(-5, 32 + flameLen);
        ctx.lineTo(0, 32);
        ctx.lineTo(5, 32 + flameLen);
        ctx.lineTo(10, 32);
        ctx.closePath();
        ctx.fill();

        ctx.fillStyle = '#fef08a';
        ctx.beginPath();
        ctx.moveTo(-8, 32);
        ctx.lineTo(-5, 32 + flameLen * 0.65);
        ctx.lineTo(0, 32);
        ctx.lineTo(5, 32 + flameLen * 0.65);
        ctx.lineTo(8, 32);
        ctx.closePath();
        ctx.fill();
      }

      if (gearDown) {
        ctx.fillStyle = '#0f172a';
        ctx.fillRect(-24, 12, 6, 9);
        ctx.fillRect(18, 12, 6, 9);
        ctx.fillRect(-3, -22, 6, 7);
      }

      ctx.restore();
    }

    // Normalized Delta Time Loop
    let lastTime = 0;
    function mainLoop(timestamp = 0) {
      if (timestamp && lastTime) {
        const deltaTime = timestamp - lastTime;
        const dt = Math.max(0.2, Math.min(2.0, deltaTime / 16.667));
        updatePhysics(dt);
      } else {
        updatePhysics(1.0);
      }
      if (timestamp) lastTime = timestamp;

      draw();
      requestAnimationFrame(mainLoop);
    }

    // --- Vertical Touch Throttle Lever Handler ---
    function handleThrottleTouch(e: TouchEvent | MouseEvent) {
      const rect = touchThrottleTrack.getBoundingClientRect();
      const clientY = (e as TouchEvent).touches ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
      const relY = Math.max(0, Math.min(rect.height, clientY - rect.top));
      const pct = 100 - (relY / rect.height) * 100;
      updateThrottleUI(pct);
    }

    let isThrottleDragging = false;
    touchThrottleTrack.addEventListener('touchstart', (e) => {
      e.stopPropagation();
      isThrottleDragging = true;
      handleThrottleTouch(e);
    }, { passive: false });

    touchThrottleTrack.addEventListener('touchmove', (e) => {
      if (!isThrottleDragging) return;
      e.stopPropagation();
      e.preventDefault();
      handleThrottleTouch(e);
    }, { passive: false });

    touchThrottleTrack.addEventListener('touchend', () => { isThrottleDragging = false; });
    touchThrottleTrack.addEventListener('touchcancel', () => { isThrottleDragging = false; });

    touchThrottleTrack.addEventListener('mousedown', (e) => {
      isThrottleDragging = true;
      handleThrottleTouch(e);
    });
    window.addEventListener('mousemove', (e) => {
      if (isThrottleDragging) handleThrottleTouch(e);
    });
    window.addEventListener('mouseup', () => { isThrottleDragging = false; });

    // --- Touch Yoke Gesture Event Listeners ---
    canvas.addEventListener('touchstart', (e) => {
      getAudioCtx();
      if (!isPlaying) {
        resetFlight();
        if (!isFullscreen) toggleFullscreen();
        return;
      }

      for (let i = 0; i < e.changedTouches.length; i++) {
        const touch = e.changedTouches[i];
        const rect = canvas.getBoundingClientRect();
        const scaleX = width / rect.width;
        const scaleY = height / rect.height;
        const tx = (touch.clientX - rect.left) * scaleX;

        // Avoid touch joystick if touching throttle on right
        if (tx < width * 0.75 && !touchYoke.active) {
          touchYoke.active = true;
          touchYoke.touchId = touch.identifier;
          touchYoke.startX = tx;
          touchYoke.startY = (touch.clientY - rect.top) * scaleY;
          touchYoke.pitchInput = 0;
          touchYoke.rollInput = 0;
        }
      }
    }, { passive: false });

    canvas.addEventListener('touchmove', (e) => {
      if (!touchYoke.active) return;
      e.preventDefault();

      for (let i = 0; i < e.changedTouches.length; i++) {
        const touch = e.changedTouches[i];
        if (touch.identifier === touchYoke.touchId) {
          const rect = canvas.getBoundingClientRect();
          const scaleX = width / rect.width;
          const scaleY = height / rect.height;
          const tx = (touch.clientX - rect.left) * scaleX;
          const ty = (touch.clientY - rect.top) * scaleY;

          const dx = tx - touchYoke.startX;
          const dy = ty - touchYoke.startY;

          const maxRadius = 50;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const clampDist = Math.min(maxRadius, dist);
          const angle = Math.atan2(dy, dx);

          touchYoke.rollInput = (Math.cos(angle) * clampDist) / maxRadius;
          touchYoke.pitchInput = (Math.sin(angle) * clampDist) / maxRadius;
        }
      }
    }, { passive: false });

    function resetTouchYoke() {
      touchYoke.active = false;
      touchYoke.touchId = null;
      touchYoke.pitchInput = 0;
      touchYoke.rollInput = 0;
    }

    canvas.addEventListener('touchend', (e) => {
      for (let i = 0; i < e.changedTouches.length; i++) {
        if (e.changedTouches[i].identifier === touchYoke.touchId) {
          resetTouchYoke();
        }
      }
    });
    canvas.addEventListener('touchcancel', resetTouchYoke);

    // Keyboard Event Handlers
    window.addEventListener('keydown', (e) => {
      getAudioCtx();
      keys[e.key] = true;

      if (e.key === ' ') {
        e.preventDefault();
        fireCannon();
      } else if (e.key === 'g' || e.key === 'G') {
        toggleGear();
      } else if (e.key === 'f' || e.key === 'F') {
        toggleFlaps();
      }
    });

    window.addEventListener('keyup', (e) => {
      keys[e.key] = false;
    });

    // Touch Action Buttons Event Handlers
    touchCannonBtn.addEventListener('click', fireCannon);
    touchGearBtn.addEventListener('click', toggleGear);
    touchFlapsBtn.addEventListener('click', toggleFlaps);

    function toggleGear() {
      plane.gearDown = !plane.gearDown;
      gearStatusEl.textContent = plane.gearDown ? 'DOWN' : 'UP';
      gearStatusEl.className = plane.gearDown ? 'text-emerald-500 font-bold' : 'text-muted font-bold';
      hudGearVal.textContent = plane.gearDown ? 'DOWN' : 'UP';
      hudGearVal.className = plane.gearDown ? 'text-emerald-400' : 'text-muted';
      touchGearLabel.textContent = plane.gearDown ? '🛞 GEAR (DN)' : '🛞 GEAR (UP)';
    }

    function toggleFlaps() {
      plane.flapsDown = !plane.flapsDown;
      flapsStatusEl.textContent = plane.flapsDown ? 'DOWN' : 'UP';
      flapsStatusEl.className = plane.flapsDown ? 'text-amber-500 font-bold' : 'text-muted font-bold';
      hudFlapsVal.textContent = plane.flapsDown ? 'DOWN' : 'UP';
      hudFlapsVal.className = plane.flapsDown ? 'text-amber-400' : 'text-muted';
      touchFlapsLabel.textContent = plane.flapsDown ? '✈️ FLAPS (DN)' : '✈️ FLAPS (UP)';
    }

    gearToggleBtn.addEventListener('click', toggleGear);
    flapsToggleBtn.addEventListener('click', toggleFlaps);

    throttleSlider.addEventListener('input', () => {
      updateThrottleUI(parseInt(throttleSlider.value));
    });

    // Pause & Start Controls
    startFlightBtn.addEventListener('click', () => {
      getAudioCtx();
      if (!isFullscreen) toggleFullscreen();
      resetFlight();
    });

    resetFlightBtn.addEventListener('click', resetFlight);

    pauseBtn.addEventListener('click', () => {
      if (!isPlaying || isCrashed) return;
      isPaused = !isPaused;
      if (isPaused) {
        pauseIcon.classList.add('hidden');
        playIcon.classList.remove('hidden');
        pauseText.textContent = 'Resume';
        flightStatusEl.textContent = 'Flight Paused';
      } else {
        pauseIcon.classList.remove('hidden');
        playIcon.classList.add('hidden');
        pauseText.textContent = 'Pause';
        flightStatusEl.textContent = `Airborne // ${Math.round(plane.y)} FT`;
      }
    });

    // Mission Selection
    const missionBtns = document.querySelectorAll('.mission-btn');
    missionBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        missionBtns.forEach(b => b.className = 'mission-btn border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-all font-semibold cursor-pointer text-center');
        target.className = 'mission-btn border border-primary bg-primary/10 text-primary p-2 rounded-md transition-all font-semibold cursor-pointer text-center';

        if (target.id === 'mission-free') {
          currentMission = 'free';
          missionBadgeEl.textContent = 'Free Flight';
        } else if (target.id === 'mission-rings') {
          currentMission = 'rings';
          missionBadgeEl.textContent = 'Ring Course';
        } else if (target.id === 'mission-landing') {
          currentMission = 'landing';
          missionBadgeEl.textContent = 'Landing';
        }
        resetFlight();
      });
    });

    // Sky Atmosphere Switcher
    const skyBtns = document.querySelectorAll('.sky-btn');
    skyBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        skyBtns.forEach(b => b.className = 'sky-btn border border-border bg-background text-muted p-1.5 rounded-md transition-all cursor-pointer text-center');
        target.className = 'sky-btn border border-primary bg-primary/10 text-primary p-1.5 rounded-md font-semibold transition-all cursor-pointer text-center';
        skyTheme = target.dataset.time || 'day';
      });
    });

    // Start Loop
    mainLoop();
  </script>
</Layout>
