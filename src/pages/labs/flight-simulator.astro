---
import Layout from '../../layouts/Layout.astro';
import { Plane, Compass, Wind, Volume2, VolumeX, RefreshCw, Play, Pause, Zap, Trophy, ShieldAlert, Camera, Eye } from '@lucide/astro';
---

<Layout title="Project Bletchley - 16-Bit Flight Simulator" description="Retro 16-bit flight simulator with 3D Mode-7 scrolling terrain, chase cam airplane visualization, horizon tilt, cockpit HUD telemetry, and landing missions.">
  <div class="space-y-8 flex-grow flex flex-col relative">
    
    <!-- Hero Background Glow Blobs -->
    <div class="absolute -top-16 -left-20 w-72 h-72 rounded-full bg-gradient-to-tr from-primary/10 to-purple-500/5 blur-[80px] -z-10 pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-gradient-to-br from-indigo-500/5 to-primary/10 blur-[100px] -z-10 pointer-events-none"></div>

    <!-- Navigation Breadcrumbs -->
    <nav class="font-mono text-sm text-muted flex items-center gap-2">
      <a href="/project-bletchley/" class="hover:text-primary hover:underline">Hub</a>
      <span>/</span>
      <span class="text-foreground">Labs</span>
      <span>/</span>
      <span class="text-foreground font-bold">16-Bit Flight Simulator</span>
    </nav>

    <!-- Page Header -->
    <header class="border-b border-border pb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-start gap-4">
        <div class="p-3 bg-primary/10 rounded-xl text-primary mt-1 border border-primary/20 shrink-0">
          <Plane class="w-8 h-8" />
        </div>
        <div>
          <div class="flex items-center gap-2">
            <h1 class="text-3xl font-extrabold tracking-tight">16-Bit Flight Simulator</h1>
            <span class="bg-primary/20 text-primary font-mono text-xs font-semibold px-2.5 py-0.5 rounded-full border border-primary/30">
              Node 11 // Mode-7 3D
            </span>
          </div>
          <p class="text-sm text-muted mt-2 max-w-2xl leading-relaxed">
            Real-time Mode-7 scrolling 3D flight engine. Experience 16-bit plane banking, horizon tilts, level flight stability, ring courses, and runway approach touchdowns.
          </p>
        </div>
      </div>

      <!-- Header Action Controls -->
      <div class="flex items-center gap-2 shrink-0">
        <button
          id="camera-toggle-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
          title="Toggle Camera View (Chase Cam / Cockpit)"
        >
          <Camera class="w-4 h-4 text-primary" />
          <span id="camera-label">Chase Cam</span>
        </button>
        <button
          id="sound-toggle-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
          title="Toggle Synthesized Engine SFX"
        >
          <Volume2 id="sound-icon-on" class="w-4 h-4 text-primary" />
          <VolumeX id="sound-icon-off" class="w-4 h-4 text-muted hidden" />
          <span id="sound-label" class="hidden sm:inline">SFX On</span>
        </button>
        <button
          id="reset-flight-btn"
          class="border border-border bg-card hover:bg-background text-sm font-mono px-3 py-1.5 rounded-md transition-colors cursor-pointer hover:border-primary text-foreground flex items-center gap-1.5 shadow-sm"
        >
          <RefreshCw class="w-4 h-4" />
          <span>Reset Flight</span>
        </button>
      </div>
    </header>

    <!-- Main Simulator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch flex-grow">
      
      <!-- Control Panel & Avionics Sidebar -->
      <section class="lg:col-span-4 border border-border bg-card p-6 rounded-xl space-y-6 flex flex-col justify-between shadow-sm">
        <div class="space-y-6">
          <h2 class="font-mono text-sm font-bold uppercase tracking-wider border-b border-border pb-2 text-foreground flex items-center justify-between">
            <span>Flight Avionics & Setup</span>
            <span class="text-xs text-primary font-normal font-mono" id="mission-badge">Free Flight</span>
          </h2>

          <div class="space-y-5">
            <!-- Mission Selection -->
            <div class="space-y-2">
              <label class="block font-mono text-xs uppercase tracking-wider text-muted">Flight Mission</label>
              <div class="grid grid-cols-3 gap-1.5 font-mono text-xs">
                <button
                  type="button"
                  id="mission-free"
                  class="mission-btn border border-primary bg-primary/10 text-primary p-2 rounded-md transition-all font-semibold cursor-pointer text-center"
                >
                  Free Flight
                </button>
                <button
                  type="button"
                  id="mission-rings"
                  class="mission-btn border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-all font-semibold cursor-pointer text-center"
                >
                  Ring Course
                </button>
                <button
                  type="button"
                  id="mission-landing"
                  class="mission-btn border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-all font-semibold cursor-pointer text-center"
                >
                  Landing
                </button>
              </div>
            </div>

            <!-- Atmosphere / Sky Time Theme -->
            <div class="space-y-2">
              <label class="block font-mono text-xs uppercase tracking-wider text-muted">Sky & Environment</label>
              <div class="grid grid-cols-3 gap-1.5 font-mono text-xs">
                <button type="button" data-time="day" class="sky-btn border border-primary bg-primary/10 text-primary p-1.5 rounded-md transition-all font-semibold cursor-pointer text-center">Daylight</button>
                <button type="button" data-time="sunset" class="sky-btn border border-border bg-background text-muted p-1.5 rounded-md transition-all cursor-pointer text-center">Sunset</button>
                <button type="button" data-time="night" class="sky-btn border border-border bg-background text-muted p-1.5 rounded-md transition-all cursor-pointer text-center">Cyber Night</button>
              </div>
            </div>

            <!-- Engine Throttle Control Slider -->
            <div class="space-y-1.5 border-t border-border/60 pt-3">
              <div class="flex justify-between text-xs font-mono">
                <span class="uppercase tracking-wider text-muted flex items-center gap-1">
                  <Zap class="w-3.5 h-3.5 text-amber-500" /> Engine Throttle
                </span>
                <span id="throttle-val-text" class="font-bold text-primary">60%</span>
              </div>
              <input
                type="range"
                id="throttle-slider"
                min="0"
                max="100"
                value="60"
                step="1"
                class="w-full h-2 bg-border appearance-none cursor-pointer accent-primary rounded-lg"
              />
              <div class="flex justify-between text-[10px] font-mono text-muted">
                <span>0% (Idle)</span>
                <span>50% (Cruise)</span>
                <span>100% (Afterburner)</span>
              </div>
            </div>

            <!-- Flight Gear & Controls -->
            <div class="grid grid-cols-2 gap-2 font-mono text-xs border-t border-border/60 pt-3">
              <button
                type="button"
                id="gear-toggle-btn"
                class="border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-colors font-semibold cursor-pointer flex items-center justify-between"
              >
                <span>Landing Gear [G]</span>
                <span id="gear-status" class="text-emerald-500 font-bold">DOWN</span>
              </button>
              <button
                type="button"
                id="flaps-toggle-btn"
                class="border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-colors font-semibold cursor-pointer flex items-center justify-between"
              >
                <span>Flaps [F]</span>
                <span id="flaps-status" class="text-muted font-bold">UP</span>
              </button>
            </div>
          </div>

          <!-- Real-Time Flight Telemetry Dashboard -->
          <div class="border border-border/80 bg-background/50 p-4 rounded-xl space-y-3 font-mono text-xs">
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Airspeed</span>
              <span id="telemetry-speed" class="font-bold text-foreground text-sm">150 KTS</span>
            </div>
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Altitude (ALT)</span>
              <span id="telemetry-alt" class="font-bold text-primary text-sm">850 FT</span>
            </div>
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Heading (HDG)</span>
              <span id="telemetry-hdg" class="font-bold text-foreground">045° NNE</span>
            </div>
            <div class="flex items-center justify-between border-b border-border/40 pb-2">
              <span class="text-muted uppercase tracking-wider">Pitch / Roll</span>
              <span id="telemetry-attitude" class="font-bold text-foreground">0° / 0°</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-muted uppercase tracking-wider">Mission Target</span>
              <span id="telemetry-mission" class="font-bold text-amber-500">Free Exploration</span>
            </div>
          </div>
        </div>

        <!-- Controls Guide Footnote -->
        <div class="font-mono text-xs text-muted border-t border-border pt-4 leading-relaxed space-y-2">
          <div class="flex items-center gap-1.5 text-foreground font-semibold">
            <span>🕹️ Flight Yoke Instructions:</span>
          </div>
          <p><strong>Pull Back [S / Down Arrow]:</strong> Pitch Nose UP (Climb)</p>
          <p><strong>Push Forward [W / Up Arrow]:</strong> Pitch Nose DOWN (Dive)</p>
          <p><strong>Bank [A / D / Left-Right Arrows]:</strong> Bank & Roll Wings Left/Right</p>
          <p><strong>Throttle [I / K]:</strong> Increase / Decrease Engine Thrust</p>
        </div>
      </section>

      <!-- Main Flight Screen & Cockpit Canvas -->
      <section class="lg:col-span-8 border border-border bg-card rounded-xl overflow-hidden shadow-sm flex flex-col items-stretch min-h-[540px]">
        
        <!-- Screen Status Header Bar -->
        <div class="border-b border-border bg-background px-4 py-3 font-mono text-xs flex items-center justify-between gap-2">
          <div class="flex items-center gap-3">
            <span class="text-primary font-bold tracking-wider uppercase flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
              <span id="flight-status-text">Level Cruise // 850 FT</span>
            </span>
          </div>
          
          <div class="flex items-center gap-3">
            <span id="stall-warning" class="text-rose-500 font-bold font-mono text-xs animate-pulse hidden flex items-center gap-1">
              <ShieldAlert class="w-4 h-4" /> STALL WARNING
            </span>
            <button 
              id="pause-btn"
              class="border border-border bg-card hover:bg-background text-foreground font-mono text-xs px-3 py-1 rounded-md transition-colors cursor-pointer hover:border-primary flex items-center gap-1"
            >
              <Pause id="pause-icon" class="w-3.5 h-3.5 text-primary" />
              <Play id="play-icon" class="w-3.5 h-3.5 text-primary hidden" />
              <span id="pause-text">Pause</span>
            </button>
          </div>
        </div>

        <!-- Flight Viewport & Canvas Area -->
        <div class="flex-grow bg-[#020617] relative flex flex-col items-center justify-center overflow-hidden select-none" id="viewport-wrapper">
          
          <canvas id="flight-canvas" class="w-full h-full block min-h-[440px] touch-none"></canvas>

          <!-- Cockpit HUD Instruments Overlay -->
          <div class="absolute inset-0 pointer-events-none p-4 flex flex-col justify-between z-10 font-mono text-xs">
            <!-- Top HUD Bar: Compass & Radar -->
            <div class="flex justify-between items-start">
              <!-- Pitch & Roll Artificial Horizon Indicator -->
              <div class="bg-black/70 backdrop-blur-md border border-primary/40 px-3 py-2 rounded-lg text-primary space-y-1">
                <div class="text-[10px] uppercase text-muted tracking-wider">Artificial Horizon</div>
                <div class="w-28 h-2 bg-primary/20 relative overflow-hidden rounded border border-primary/40">
                  <div id="hud-pitch-bar" class="absolute inset-x-0 h-full bg-primary transition-all duration-75"></div>
                </div>
              </div>

              <!-- Center Compass Strip -->
              <div class="bg-black/80 backdrop-blur-md border border-border px-4 py-1.5 rounded-lg text-foreground font-mono text-sm tracking-widest border-primary/30 flex items-center gap-3 shadow-md">
                <Compass class="w-4 h-4 text-primary" />
                <span id="hud-compass-text">HDG 045° [ NNE ]</span>
              </div>

              <!-- Radar Minimap -->
              <div class="w-24 h-24 bg-black/80 border border-primary/50 rounded-full relative overflow-hidden flex items-center justify-center shadow-lg">
                <!-- Radar grid rings -->
                <div class="absolute inset-2 border border-primary/20 rounded-full"></div>
                <div class="absolute inset-6 border border-primary/15 rounded-full"></div>
                <div class="absolute inset-x-0 top-1/2 h-[1px] bg-primary/30"></div>
                <div class="absolute inset-y-0 left-1/2 w-[1px] bg-primary/30"></div>
                <!-- Plane blip -->
                <div class="w-2 h-2 bg-primary rounded-full z-10 shadow-[0_0_8px_var(--primary)]"></div>
                <!-- Target blips container -->
                <div id="radar-blips" class="absolute inset-0"></div>
              </div>
            </div>

            <!-- Bottom HUD Controls Info -->
            <div class="flex justify-between items-end text-[11px]">
              <div class="bg-black/70 backdrop-blur-md border border-border px-3 py-1.5 rounded-lg text-muted">
                <span>GEAR: <strong id="hud-gear-val" class="text-emerald-400">DOWN</strong></span> | 
                <span>FLAPS: <strong id="hud-flaps-val" class="text-muted">UP</strong></span>
              </div>
              <div class="bg-black/70 backdrop-blur-md border border-border px-3 py-1.5 rounded-lg text-muted">
                <span id="camera-status-text">VIEW: CHASE CAM (THIRD-PERSON)</span>
              </div>
            </div>
          </div>

          <!-- Overlay Start / Crash Dialog -->
          <div id="flight-overlay" class="absolute inset-0 bg-black/85 backdrop-blur-sm flex flex-col items-center justify-center p-6 text-center z-20 transition-all duration-300">
            <div class="space-y-4 max-w-md">
              <div class="w-14 h-14 rounded-2xl bg-primary/20 border border-primary/40 flex items-center justify-center mx-auto text-primary">
                <Plane class="w-7 h-7" />
              </div>
              <h3 id="overlay-title" class="text-2xl font-extrabold tracking-tight text-white font-mono uppercase">
                16-BIT FLIGHT SIMULATOR
              </h3>
              <p id="overlay-desc" class="text-sm text-muted leading-relaxed font-sans">
                Take off into retro 3D skies. Fly over Mode-7 landscapes, maneuver through target rings, and perform smooth runway approach landings!
              </p>
              <button
                id="start-flight-btn"
                class="w-full bg-primary hover:bg-primary/90 text-white font-mono font-bold py-3 px-6 rounded-xl transition-transform active:scale-95 shadow-lg cursor-pointer text-sm tracking-wider uppercase flex items-center justify-center gap-2"
              >
                <Play class="w-4 h-4" />
                <span>Take Off Now</span>
              </button>
            </div>
          </div>

        </div>

        <!-- Mobile Touch Control Pad -->
        <div class="border-t border-border bg-background p-3 flex items-center justify-between gap-3 font-mono text-xs">
          <div class="flex items-center gap-2">
            <span class="text-muted text-[11px]">Mobile Touch Controls:</span>
          </div>

          <!-- Virtual Flight Yoke Buttons -->
          <div class="flex items-center gap-1.5">
            <button
              id="btn-pitch-down"
              class="bg-card active:bg-primary active:text-white border border-border px-3 py-2 rounded-lg text-foreground font-bold text-xs select-none touch-none"
              title="Push Nose Down"
            >
              ▲ DIVE
            </button>
            <button
              id="btn-pitch-up"
              class="bg-card active:bg-primary active:text-white border border-border px-3 py-2 rounded-lg text-foreground font-bold text-xs select-none touch-none"
              title="Pull Nose Up"
            >
              ▼ CLIMB
            </button>
            <button
              id="btn-roll-left"
              class="bg-card active:bg-primary active:text-white border border-border px-3 py-2 rounded-lg text-foreground font-bold text-xs select-none touch-none"
            >
              ◀ BANK L
            </button>
            <button
              id="btn-roll-right"
              class="bg-card active:bg-primary active:text-white border border-border px-3 py-2 rounded-lg text-foreground font-bold text-xs select-none touch-none"
            >
              BANK R ▶
            </button>
            <button
              id="btn-fire-cannon"
              class="bg-rose-500/20 hover:bg-rose-600 text-rose-400 hover:text-white border border-rose-500/40 px-3 py-2 rounded-lg font-bold text-xs uppercase cursor-pointer select-none"
            >
              🚀 CANNON
            </button>
          </div>
        </div>

      </section>

    </div>
  </div>

  <script>
    // --- 16-BIT FLIGHT SIMULATOR ENGINE ---
    const canvas = document.getElementById('flight-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const wrapper = document.getElementById('viewport-wrapper')!;

    // UI Elements
    const flightStatusEl = document.getElementById('flight-status-text')!;
    const stallWarningEl = document.getElementById('stall-warning')!;
    const telemetrySpeedEl = document.getElementById('telemetry-speed')!;
    const telemetryAltEl = document.getElementById('telemetry-alt')!;
    const telemetryHdgEl = document.getElementById('telemetry-hdg')!;
    const telemetryAttitudeEl = document.getElementById('telemetry-attitude')!;
    const telemetryMissionEl = document.getElementById('telemetry-mission')!;
    const missionBadgeEl = document.getElementById('mission-badge')!;

    // HUD Elements
    const hudCompassText = document.getElementById('hud-compass-text')!;
    const hudPitchBar = document.getElementById('hud-pitch-bar')!;
    const hudGearVal = document.getElementById('hud-gear-val')!;
    const hudFlapsVal = document.getElementById('hud-flaps-val')!;
    const radarBlipsEl = document.getElementById('radar-blips')!;
    const cameraStatusText = document.getElementById('camera-status-text')!;
    const cameraLabel = document.getElementById('camera-label')!;

    // Overlay
    const overlay = document.getElementById('flight-overlay')!;
    const overlayTitle = document.getElementById('overlay-title')!;
    const overlayDesc = document.getElementById('overlay-desc')!;
    const startFlightBtn = document.getElementById('start-flight-btn')!;

    // Controls UI
    const pauseBtn = document.getElementById('pause-btn')!;
    const pauseIcon = document.getElementById('pause-icon')!;
    const playIcon = document.getElementById('play-icon')!;
    const pauseText = document.getElementById('pause-text')!;
    const resetFlightBtn = document.getElementById('reset-flight-btn')!;
    const cameraToggleBtn = document.getElementById('camera-toggle-btn')!;
    const soundToggleBtn = document.getElementById('sound-toggle-btn')!;
    const soundIconOn = document.getElementById('sound-icon-on')!;
    const soundIconOff = document.getElementById('sound-icon-off')!;
    const soundLabel = document.getElementById('sound-label')!;

    const throttleSlider = document.getElementById('throttle-slider') as HTMLInputElement;
    const throttleValText = document.getElementById('throttle-val-text')!;
    const gearToggleBtn = document.getElementById('gear-toggle-btn')!;
    const gearStatusEl = document.getElementById('gear-status')!;
    const flapsToggleBtn = document.getElementById('flaps-toggle-btn')!;
    const flapsStatusEl = document.getElementById('flaps-status')!;

    // Mobile Action buttons
    const btnPitchUp = document.getElementById('btn-pitch-up')!;
    const btnPitchDown = document.getElementById('btn-pitch-down')!;
    const btnRollLeft = document.getElementById('btn-roll-left')!;
    const btnRollRight = document.getElementById('btn-roll-right')!;
    const btnFireCannon = document.getElementById('btn-fire-cannon')!;

    // --- Sound Synthesis Engine ---
    let soundEnabled = true;
    let audioCtx: AudioContext | null = null;
    let engineOsc: OscillatorNode | null = null;
    let engineGain: GainNode | null = null;

    function getAudioCtx() {
      if (!audioCtx) {
        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
        audioCtx = new AudioContextClass();
      }
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      return audioCtx;
    }

    function initEngineSound() {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioCtx();
        if (!engineOsc) {
          engineOsc = ctx.createOscillator();
          engineGain = ctx.createGain();

          engineOsc.type = 'sawtooth';
          engineOsc.frequency.setValueAtTime(55, ctx.currentTime);
          engineGain.gain.setValueAtTime(0.04, ctx.currentTime);

          engineOsc.connect(engineGain);
          engineGain.connect(ctx.destination);
          engineOsc.start();
        }
      } catch (e) {}
    }

    function updateEngineSound(throttlePct: number) {
      if (!soundEnabled || !engineOsc || !engineGain) return;
      try {
        const freq = 45 + throttlePct * 1.6;
        engineOsc.frequency.setTargetAtTime(freq, getAudioCtx().currentTime, 0.1);
      } catch (e) {}
    }

    function playSFX(type: 'cannon' | 'ring' | 'stall' | 'crash' | 'land') {
      if (!soundEnabled) return;
      try {
        const ctx = getAudioCtx();
        const now = ctx.currentTime;

        if (type === 'cannon') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'square';
          osc.frequency.setValueAtTime(320, now);
          osc.frequency.exponentialRampToValueAtTime(70, now + 0.1);
          gain.gain.setValueAtTime(0.3, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.1);
        } else if (type === 'ring') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'triangle';
          osc.frequency.setValueAtTime(523.25, now);
          osc.frequency.setValueAtTime(783.99, now + 0.08);
          gain.gain.setValueAtTime(0.25, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.2);
        } else if (type === 'land') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sine';
          osc.frequency.setValueAtTime(440, now);
          osc.frequency.setValueAtTime(659.25, now + 0.1);
          gain.gain.setValueAtTime(0.3, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.35);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.35);
        } else if (type === 'crash') {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sawtooth';
          osc.frequency.setValueAtTime(140, now);
          osc.frequency.linearRampToValueAtTime(35, now + 0.5);
          gain.gain.setValueAtTime(0.4, now);
          gain.gain.exponentialRampToValueAtTime(0.01, now + 0.5);
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.start(now);
          osc.stop(now + 0.5);
        }
      } catch (e) {}
    }

    soundToggleBtn.addEventListener('click', () => {
      soundEnabled = !soundEnabled;
      if (soundEnabled) {
        soundIconOn.classList.remove('hidden');
        soundIconOff.classList.add('hidden');
        soundLabel.textContent = 'SFX On';
        initEngineSound();
      } else {
        soundIconOn.classList.add('hidden');
        soundIconOff.classList.remove('hidden');
        soundLabel.textContent = 'Muted';
        if (engineGain) engineGain.gain.value = 0;
      }
    });

    // --- State Variables ---
    let width = 800;
    let height = 450;

    let isPlaying = false;
    let isPaused = false;
    let isCrashed = false;
    let isLanded = false;

    let currentMission = 'free'; // 'free' | 'rings' | 'landing'
    let skyTheme = 'day'; // 'day' | 'sunset' | 'night'
    let cameraMode = 'chase'; // 'chase' | 'cockpit'

    // Plane Flight Physics State
    const plane = {
      x: 0,
      y: 850, // Altitude in feet (Safe level flight start!)
      z: 0,
      pitch: 0, // deg (-45 to +45)
      roll: 0,  // deg (-60 to +60)
      yaw: 45,  // heading deg (0 to 360)
      speed: 150, // knots
      throttle: 60, // 0 to 100%
      gearDown: false,
      flapsDown: false,
      stalling: false
    };

    // Cannon Particles & Bullets
    let bullets: { x: number; y: number; z: number; vx: number; vy: number; vz: number; life: number }[] = [];

    // Target Rings
    let targetRings: { x: number; y: number; z: number; radius: number; passed: boolean }[] = [];
    let ringsPassedCount = 0;

    // Runway 3D Location
    const runway = {
      x: 0,
      z: 1200,
      length: 1400,
      width: 180
    };

    // Sky Color Palettes
    const skyPalettes = {
      day: {
        skyTop: '#1e3a8a',
        skyBottom: '#38bdf8',
        groundBase: '#15803d',
        gridLine: '#16a34a'
      },
      sunset: {
        skyTop: '#4c1d95',
        skyBottom: '#f97316',
        groundBase: '#7c2d12',
        gridLine: '#ea580c'
      },
      night: {
        skyTop: '#020617',
        skyBottom: '#1e1b4b',
        groundBase: '#09090b',
        gridLine: '#6366f1'
      }
    };

    // Input States
    const keys: Record<string, boolean> = {};
    let mobilePitchUp = false;
    let mobilePitchDown = false;
    let mobileRollLeft = false;
    let mobileRollRight = false;

    // --- Responsive Canvas Setup ---
    function resizeCanvas() {
      const rect = wrapper.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;

      width = rect.width;
      height = Math.max(440, rect.height);

      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.scale(dpr, dpr);
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    // --- Mission Builder ---
    function initMission() {
      ringsPassedCount = 0;
      targetRings = [];

      if (currentMission === 'rings') {
        // Spawn 8 floating rings along scenic path in front of plane
        for (let i = 0; i < 8; i++) {
          const angle = (i / 8) * Math.PI * 1.5;
          const dist = 800 + i * 550;
          targetRings.push({
            x: Math.sin(angle) * dist,
            y: 650 + Math.sin(i * 1.5) * 250,
            z: Math.cos(angle) * dist + 500,
            radius: 90,
            passed: false
          });
        }
        telemetryMissionEl.textContent = 'Rings: 0 / 8';
      } else if (currentMission === 'landing') {
        plane.x = 0;
        plane.y = 450;
        plane.z = -800; // Aligned with runway
        plane.pitch = -3;
        plane.speed = 110;
        plane.gearDown = true;
        plane.flapsDown = true;
        gearStatusEl.textContent = 'DOWN';
        flapsStatusEl.textContent = 'DOWN';
        hudGearVal.textContent = 'DOWN';
        hudFlapsVal.textContent = 'DOWN';
        telemetryMissionEl.textContent = 'Runway Approach';
      } else {
        telemetryMissionEl.textContent = 'Free Exploration';
      }
    }

    function resetFlight() {
      plane.x = 0;
      plane.y = 850; // Safe initial cruising altitude
      plane.z = 0;
      plane.pitch = 0;
      plane.roll = 0;
      plane.yaw = 45;
      plane.speed = 150;
      plane.throttle = 60;
      plane.gearDown = false;
      plane.flapsDown = false;
      plane.stalling = false;

      throttleSlider.value = '60';
      throttleValText.textContent = '60%';
      gearStatusEl.textContent = 'UP';
      flapsStatusEl.textContent = 'UP';
      hudGearVal.textContent = 'UP';
      hudFlapsVal.textContent = 'UP';

      isCrashed = false;
      isLanded = false;
      isPaused = false;
      isPlaying = true;

      bullets = [];

      initMission();
      hideOverlay();
      flightStatusEl.textContent = 'Level Cruise // 850 FT';
      stallWarningEl.classList.add('hidden');
      initEngineSound();
    }

    function showOverlay(title: string, desc: string, btnText: string) {
      overlayTitle.textContent = title;
      overlayDesc.textContent = desc;
      startFlightBtn.querySelector('span')!.textContent = btnText;
      overlay.classList.remove('opacity-0', 'pointer-events-none');
    }

    function hideOverlay() {
      overlay.classList.add('opacity-0', 'pointer-events-none');
    }

    // --- Camera View Toggle ---
    cameraToggleBtn.addEventListener('click', () => {
      cameraMode = cameraMode === 'chase' ? 'cockpit' : 'chase';
      cameraLabel.textContent = cameraMode === 'chase' ? 'Chase Cam' : 'Cockpit HUD';
      cameraStatusText.textContent = cameraMode === 'chase' ? 'VIEW: CHASE CAM (THIRD-PERSON)' : 'VIEW: COCKPIT HUD (FIRST-PERSON)';
    });

    // --- Cannon Fire ---
    function fireCannon() {
      if (!isPlaying || isCrashed) return;
      playSFX('cannon');

      const radYaw = (plane.yaw * Math.PI) / 180;
      const radPitch = (plane.pitch * Math.PI) / 180;

      const speed = 28;
      bullets.push({
        x: plane.x,
        y: plane.y - 5,
        z: plane.z,
        vx: Math.sin(radYaw) * speed,
        vy: Math.sin(radPitch) * speed,
        vz: Math.cos(radYaw) * speed,
        life: 55
      });
    }

    // --- Flight Dynamics Physics Loop ---
    function updatePhysics(dt: number) {
      if (!isPlaying || isPaused || isCrashed) return;

      // 1. Read Inputs
      let pitchInput = 0;
      let rollInput = 0;

      // Pitch Down (W / Up Arrow / Dive Button)
      if (keys['w'] || keys['W'] || keys['ArrowUp'] || mobilePitchDown) pitchInput -= 1;
      // Pitch Up (S / Down Arrow / Climb Button)
      if (keys['s'] || keys['S'] || keys['ArrowDown'] || mobilePitchUp) pitchInput += 1;

      // Roll Left/Right
      if (keys['a'] || keys['A'] || keys['ArrowLeft'] || mobileRollLeft) rollInput -= 1;
      if (keys['d'] || keys['D'] || keys['ArrowRight'] || mobileRollRight) rollInput += 1;

      // Throttle Adjustment via Keys [I / K]
      if (keys['i'] || keys['I']) {
        plane.throttle = Math.min(100, plane.throttle + 1.5 * dt);
        throttleSlider.value = String(Math.round(plane.throttle));
        throttleValText.textContent = `${Math.round(plane.throttle)}%`;
      }
      if (keys['k'] || keys['K']) {
        plane.throttle = Math.max(0, plane.throttle - 1.5 * dt);
        throttleSlider.value = String(Math.round(plane.throttle));
        throttleValText.textContent = `${Math.round(plane.throttle)}%`;
      }

      // Pitch & Roll Dynamics
      plane.pitch += pitchInput * 2.2 * dt;
      plane.roll += rollInput * 3.0 * dt;

      // Auto Bank Turn: Rolling right turns heading clockwise, rolling left turns counter-clockwise
      plane.yaw += (plane.roll * 0.05) * dt;

      // Damping / Auto-centering when yoke is released
      if (rollInput === 0) {
        plane.roll *= 0.93;
      }
      if (pitchInput === 0) {
        plane.pitch *= 0.94; // Decays pitch toward 0 (Level Flight Trim)
      }

      // Clamp angles
      plane.pitch = Math.max(-50, Math.min(50, plane.pitch));
      plane.roll = Math.max(-75, Math.min(75, plane.roll));
      plane.yaw = (plane.yaw + 360) % 360;

      // 2. Throttle & Speed Calculation
      const targetSpeed = 60 + plane.throttle * 2.2 + (plane.flapsDown ? -25 : 0);
      plane.speed += (targetSpeed - plane.speed) * 0.04 * dt;

      // Altitude Change: Pitch > 0 climbs up, Pitch < 0 dives down
      const radPitch = (plane.pitch * Math.PI) / 180;
      const radYaw = (plane.yaw * Math.PI) / 180;

      const climbRate = Math.sin(radPitch) * plane.speed * 0.35;
      plane.y += climbRate * dt;

      // Forward Position Scrolling Movement
      plane.x += Math.sin(radYaw) * plane.speed * 0.25 * dt;
      plane.z += Math.cos(radYaw) * plane.speed * 0.25 * dt;

      // Stall Check
      if (plane.speed < 65 && plane.pitch > 15) {
        plane.stalling = true;
        stallWarningEl.classList.remove('hidden');
        plane.y -= 15 * dt;
        playSFX('stall');
      } else {
        plane.stalling = false;
        stallWarningEl.classList.add('hidden');
      }

      // 3. Ground Touchdown & Landing System
      if (plane.y <= 0) {
        plane.y = 0;

        const distRunwayX = Math.abs(plane.x - runway.x);
        const distRunwayZ = Math.abs(plane.z - runway.z);

        if (
          plane.gearDown &&
          distRunwayX < runway.width &&
          distRunwayZ < runway.length &&
          plane.speed < 135 &&
          Math.abs(plane.pitch) < 18 &&
          Math.abs(plane.roll) < 18
        ) {
          isLanded = true;
          isPlaying = false;
          playSFX('land');
          flightStatusEl.textContent = 'Touchdown Complete';
          showOverlay('TOUCHDOWN SUCCESSFUL!', `Perfect landing at ${Math.round(plane.speed)} KTS on Runway 09!`, 'Fly Again');
        } else {
          isCrashed = true;
          isPlaying = false;
          playSFX('crash');
          flightStatusEl.textContent = 'CRASH DETECTED';
          showOverlay('AIRCRAFT CRASHED', `Impact with ground at ${Math.round(plane.speed)} KTS. Keep nose level (-5° to +5°) and lower landing gear [G].`, 'Try Again');
        }
      }

      // 4. Ring Mission Tracking
      if (currentMission === 'rings') {
        targetRings.forEach(ring => {
          if (!ring.passed) {
            const dx = ring.x - plane.x;
            const dy = ring.y - plane.y;
            const dz = ring.z - plane.z;
            const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);

            if (dist < ring.radius + 40) {
              ring.passed = true;
              ringsPassedCount++;
              playSFX('ring');
              telemetryMissionEl.textContent = `Rings: ${ringsPassedCount} / 8`;

              if (ringsPassedCount >= 8) {
                showOverlay('COURSE CLEARED!', 'Outstanding flying! All 8 target rings cleared with 16-bit precision.', 'Next Flight');
              }
            }
          }
        });
      }

      // 5. Update Cannon Bullets
      for (let i = bullets.length - 1; i >= 0; i--) {
        const b = bullets[i];
        b.x += b.vx * dt;
        b.y += b.vy * dt;
        b.z += b.vz * dt;
        b.life -= dt;
        if (b.life <= 0) {
          bullets.splice(i, 1);
        }
      }

      // Engine Sound
      updateEngineSound(plane.throttle);

      // Telemetry Displays
      telemetrySpeedEl.textContent = `${Math.round(plane.speed)} KTS`;
      telemetryAltEl.textContent = `${Math.round(plane.y).toLocaleString()} FT`;

      const hdgDeg = Math.round(plane.yaw);
      const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
      const dirStr = dirs[Math.floor((hdgDeg + 22.5) / 45) % 8];
      telemetryHdgEl.textContent = `${String(hdgDeg).padStart(3, '0')}° ${dirStr}`;
      telemetryAttitudeEl.textContent = `${Math.round(plane.pitch)}° / ${Math.round(plane.roll)}°`;

      hudCompassText.textContent = `HDG ${String(hdgDeg).padStart(3, '0')}° [ ${dirStr} ]`;
      hudPitchBar.style.transform = `translateY(${-plane.pitch * 0.8}px) rotate(${-plane.roll}deg)`;

      if (plane.y > 0) {
        flightStatusEl.textContent = `Airborne // ${Math.round(plane.y)} FT`;
      }

      updateRadarUI();
    }

    function updateRadarUI() {
      radarBlipsEl.innerHTML = '';
      if (currentMission === 'rings') {
        targetRings.forEach(ring => {
          if (!ring.passed) {
            const relX = (ring.x - plane.x) / 35;
            const relZ = (ring.z - plane.z) / 35;
            if (Math.abs(relX) < 42 && Math.abs(relZ) < 42) {
              const blip = document.createElement('div');
              blip.className = 'absolute w-2 h-2 bg-amber-400 rounded-full animate-ping';
              blip.style.left = `${44 + relX}px`;
              blip.style.top = `${44 - relZ}px`;
              radarBlipsEl.appendChild(blip);
            }
          }
        });
      }
    }

    // --- Mode-7 Dynamic 3D Renderer ---
    function draw() {
      const palette = skyPalettes[skyTheme as keyof typeof skyPalettes];

      // 1. Horizon & Pitch Calculation
      const horizonY = height / 2 + (plane.pitch * 3.5);

      ctx.save();
      // Rotate viewport according to Aircraft Wing Roll Angle!
      ctx.translate(width / 2, horizonY);
      ctx.rotate((-plane.roll * Math.PI) / 180);

      // Sky Background
      ctx.fillStyle = palette.skyTop;
      ctx.fillRect(-width * 1.5, -height * 2.5, width * 3, height * 2.5);

      // Sky Horizon Gradient
      const skyGlow = ctx.createLinearGradient(0, -120, 0, 0);
      skyGlow.addColorStop(0, palette.skyTop);
      skyGlow.addColorStop(1, palette.skyBottom);
      ctx.fillStyle = skyGlow;
      ctx.fillRect(-width * 1.5, -150, width * 3, 150);

      // Ground Base
      ctx.fillStyle = palette.groundBase;
      ctx.fillRect(-width * 1.5, 0, width * 3, height * 2.5);

      // 2. Mode-7 Scrolling Grid Lines (Scrolling with plane.x & plane.z)
      ctx.strokeStyle = palette.gridLine;
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = 0.45;

      const gridSize = 140;
      const offsetX = (plane.x % gridSize);
      const offsetZ = (plane.z % gridSize);

      // Radiating perspective lines
      for (let i = -14; i <= 14; i++) {
        const xStart = i * 45 - offsetX * 0.2;
        const xEnd = i * 240 - offsetX * 1.8;
        ctx.beginPath();
        ctx.moveTo(xStart, 0);
        ctx.lineTo(xEnd, height * 2);
        ctx.stroke();
      }

      // Horizontal ground distance lines scrolling toward camera!
      for (let j = 1; j <= 14; j++) {
        const zPos = (j * 45 - (offsetZ * 0.4)) % 550;
        if (zPos > 0) {
          const yPos = Math.pow(zPos / 22, 1.85) * 3.2;
          if (yPos > 0 && yPos < height * 2) {
            ctx.beginPath();
            ctx.moveTo(-width * 1.5, yPos);
            ctx.lineTo(width * 1.5, yPos);
            ctx.stroke();
          }
        }
      }
      ctx.globalAlpha = 1.0;

      // 3. Render 3D Runway
      const relRunwayZ = runway.z - plane.z;
      const relRunwayX = runway.x - plane.x;

      if (relRunwayZ > -400 && relRunwayZ < 3500) {
        const scale = 300 / (relRunwayZ + 350);
        const rwScreenX = relRunwayX * scale;
        const rwScreenY = (plane.y + 40) * scale;
        const rwWidth = runway.width * scale;

        ctx.fillStyle = '#334155';
        ctx.fillRect(rwScreenX - rwWidth / 2, rwScreenY, rwWidth, 90 * scale);

        // Center dashes
        ctx.fillStyle = '#f8fafc';
        ctx.fillRect(rwScreenX - 2, rwScreenY, 4, 90 * scale);
      }

      // 4. Render 3D Target Rings
      if (currentMission === 'rings') {
        targetRings.forEach(ring => {
          if (!ring.passed) {
            const dz = ring.z - plane.z;
            const dx = ring.x - plane.x;
            const dy = ring.y - plane.y;

            if (dz > 40 && dz < 3200) {
              const scale = 300 / dz;
              const screenX = dx * scale;
              const screenY = -dy * scale;
              const radiusScreen = ring.radius * scale;

              ctx.strokeStyle = '#f59e0b';
              ctx.lineWidth = Math.max(2, 6 * scale);
              ctx.shadowColor = '#f59e0b';
              ctx.shadowBlur = 10;
              ctx.beginPath();
              ctx.arc(screenX, screenY, Math.max(5, radiusScreen), 0, Math.PI * 2);
              ctx.stroke();
              ctx.shadowBlur = 0;
            }
          }
        });
      }

      // 5. Render Cannon Bullets
      bullets.forEach(b => {
        const dz = b.z - plane.z;
        const dx = b.x - plane.x;
        const dy = b.y - plane.y;

        if (dz > 10 && dz < 2000) {
          const scale = 300 / dz;
          const screenX = dx * scale;
          const screenY = -dy * scale;

          ctx.fillStyle = '#fbbf24';
          ctx.beginPath();
          ctx.arc(screenX, screenY, Math.max(2, 4 * scale), 0, Math.PI * 2);
          ctx.fill();
        }
      });

      ctx.restore(); // Restore unrotated viewport transform

      // 6. Ground Shadow under plane (Visible when flying near terrain)
      if (plane.y < 900) {
        const shadowAlpha = Math.max(0, 1 - plane.y / 900) * 0.45;
        const shadowOffsetY = Math.min(120, (plane.y / 900) * 100);
        ctx.save();
        ctx.translate(width / 2, height - 90 + shadowOffsetY);
        ctx.rotate((-plane.roll * Math.PI) / 180 * 0.4);
        ctx.fillStyle = `rgba(0, 0, 0, ${shadowAlpha})`;
        ctx.beginPath();
        ctx.ellipse(0, 0, 48, 12, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }

      // 7. Third-Person Aircraft Model Rendering (In Chase Cam view!)
      if (cameraMode === 'chase') {
        draw16BitAircraftSprite(width / 2, height - 90, plane.roll, plane.pitch, plane.throttle, plane.gearDown);
      }
    }

    // Helper: Draw 16-Bit Fighter Jet Model
    function draw16BitAircraftSprite(x: number, y: number, roll: number, pitch: number, throttle: number, gearDown: boolean) {
      ctx.save();
      ctx.translate(x, y);
      
      // Banking Roll Tilt
      ctx.rotate((roll * Math.PI) / 180);
      
      // Pitch Perspective Squash
      const pitchScaleY = 1 - Math.sin((pitch * Math.PI) / 180) * 0.25;
      ctx.scale(1, pitchScaleY);

      // Jet Main Wings (16-Bit Retro Vector Polygon)
      ctx.fillStyle = '#475569'; // Slate dark wing color
      ctx.strokeStyle = '#94a3b8';
      ctx.lineWidth = 1.5;

      ctx.beginPath();
      ctx.moveTo(0, -28); // Nose tip
      ctx.lineTo(58, 14); // Right wingtip
      ctx.lineTo(16, 10);
      ctx.lineTo(20, 28); // Tail right
      ctx.lineTo(-20, 28); // Tail left
      ctx.lineTo(-16, 10);
      ctx.lineTo(-58, 14); // Left wingtip
      ctx.closePath();
      ctx.fill();
      ctx.stroke();

      // Fuselage Body
      ctx.fillStyle = '#64748b';
      ctx.beginPath();
      ctx.ellipse(0, -2, 11, 32, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();

      // Canopy Glass (Cyan Glow)
      ctx.fillStyle = '#38bdf8';
      ctx.shadowColor = '#38bdf8';
      ctx.shadowBlur = 8;
      ctx.beginPath();
      ctx.ellipse(0, -12, 5.5, 12, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;

      // Jet Engine Thrust Flame Animation
      if (throttle > 10) {
        const flameLen = 12 + (throttle / 100) * 28 + Math.random() * 6;
        ctx.fillStyle = '#f97316';
        ctx.beginPath();
        ctx.moveTo(-6, 30);
        ctx.lineTo(0, 30 + flameLen);
        ctx.lineTo(6, 30);
        ctx.closePath();
        ctx.fill();

        ctx.fillStyle = '#fef08a';
        ctx.beginPath();
        ctx.moveTo(-3, 30);
        ctx.lineTo(0, 30 + flameLen * 0.6);
        ctx.lineTo(3, 30);
        ctx.closePath();
        ctx.fill();
      }

      // Landing Gear Wheels
      if (gearDown) {
        ctx.fillStyle = '#0f172a';
        ctx.fillRect(-22, 10, 5, 8);
        ctx.fillRect(17, 10, 5, 8);
        ctx.fillRect(-2.5, -20, 5, 6);
      }

      ctx.restore();
    }

    // Normalized Delta Time Loop
    let lastTime = 0;
    function mainLoop(timestamp = 0) {
      if (timestamp && lastTime) {
        const deltaTime = timestamp - lastTime;
        const dt = Math.max(0.2, Math.min(2.0, deltaTime / 16.667));
        updatePhysics(dt);
      } else {
        updatePhysics(1.0);
      }
      if (timestamp) lastTime = timestamp;

      draw();
      requestAnimationFrame(mainLoop);
    }

    // --- Inputs & Event Handlers ---
    window.addEventListener('keydown', (e) => {
      getAudioCtx();
      keys[e.key] = true;

      if (e.key === ' ') {
        e.preventDefault();
        fireCannon();
      } else if (e.key === 'g' || e.key === 'G') {
        toggleGear();
      } else if (e.key === 'f' || e.key === 'F') {
        toggleFlaps();
      }
    });

    window.addEventListener('keyup', (e) => {
      keys[e.key] = false;
    });

    // Mobile Virtual Touch Controls
    btnPitchUp.addEventListener('touchstart', (e) => { e.preventDefault(); mobilePitchUp = true; });
    btnPitchUp.addEventListener('touchend', (e) => { e.preventDefault(); mobilePitchUp = false; });
    btnPitchUp.addEventListener('mousedown', () => { mobilePitchUp = true; });
    btnPitchUp.addEventListener('mouseup', () => { mobilePitchUp = false; });

    btnPitchDown.addEventListener('touchstart', (e) => { e.preventDefault(); mobilePitchDown = true; });
    btnPitchDown.addEventListener('touchend', (e) => { e.preventDefault(); mobilePitchDown = false; });
    btnPitchDown.addEventListener('mousedown', () => { mobilePitchDown = true; });
    btnPitchDown.addEventListener('mouseup', () => { mobilePitchDown = false; });

    btnRollLeft.addEventListener('touchstart', (e) => { e.preventDefault(); mobileRollLeft = true; });
    btnRollLeft.addEventListener('touchend', (e) => { e.preventDefault(); mobileRollLeft = false; });
    btnRollLeft.addEventListener('mousedown', () => { mobileRollLeft = true; });
    btnRollLeft.addEventListener('mouseup', () => { mobileRollLeft = false; });

    btnRollRight.addEventListener('touchstart', (e) => { e.preventDefault(); mobileRollRight = true; });
    btnRollRight.addEventListener('touchend', (e) => { e.preventDefault(); mobileRollRight = false; });
    btnRollRight.addEventListener('mousedown', () => { mobileRollRight = true; });
    btnRollRight.addEventListener('mouseup', () => { mobileRollRight = false; });

    btnFireCannon.addEventListener('click', fireCannon);

    // Gear & Flaps Controls
    function toggleGear() {
      plane.gearDown = !plane.gearDown;
      gearStatusEl.textContent = plane.gearDown ? 'DOWN' : 'UP';
      gearStatusEl.className = plane.gearDown ? 'text-emerald-500 font-bold' : 'text-muted font-bold';
      hudGearVal.textContent = plane.gearDown ? 'DOWN' : 'UP';
      hudGearVal.className = plane.gearDown ? 'text-emerald-400' : 'text-muted';
    }

    function toggleFlaps() {
      plane.flapsDown = !plane.flapsDown;
      flapsStatusEl.textContent = plane.flapsDown ? 'DOWN' : 'UP';
      flapsStatusEl.className = plane.flapsDown ? 'text-amber-500 font-bold' : 'text-muted font-bold';
      hudFlapsVal.textContent = plane.flapsDown ? 'DOWN' : 'UP';
      hudFlapsVal.className = plane.flapsDown ? 'text-amber-400' : 'text-muted';
    }

    gearToggleBtn.addEventListener('click', toggleGear);
    flapsToggleBtn.addEventListener('click', toggleFlaps);

    // Throttle Slider
    throttleSlider.addEventListener('input', () => {
      plane.throttle = parseInt(throttleSlider.value);
      throttleValText.textContent = `${plane.throttle}%`;
    });

    // Pause & Start Controls
    startFlightBtn.addEventListener('click', () => {
      getAudioCtx();
      resetFlight();
    });

    resetFlightBtn.addEventListener('click', resetFlight);

    pauseBtn.addEventListener('click', () => {
      if (!isPlaying || isCrashed) return;
      isPaused = !isPaused;
      if (isPaused) {
        pauseIcon.classList.add('hidden');
        playIcon.classList.remove('hidden');
        pauseText.textContent = 'Resume';
        flightStatusEl.textContent = 'Flight Paused';
      } else {
        pauseIcon.classList.remove('hidden');
        playIcon.classList.add('hidden');
        pauseText.textContent = 'Pause';
        flightStatusEl.textContent = `Airborne // ${Math.round(plane.y)} FT`;
      }
    });

    // Mission Selection
    const missionBtns = document.querySelectorAll('.mission-btn');
    missionBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        missionBtns.forEach(b => b.className = 'mission-btn border border-border bg-background hover:border-primary text-foreground p-2 rounded-md transition-all font-semibold cursor-pointer text-center');
        target.className = 'mission-btn border border-primary bg-primary/10 text-primary p-2 rounded-md transition-all font-semibold cursor-pointer text-center';

        if (target.id === 'mission-free') {
          currentMission = 'free';
          missionBadgeEl.textContent = 'Free Flight';
        } else if (target.id === 'mission-rings') {
          currentMission = 'rings';
          missionBadgeEl.textContent = 'Ring Course';
        } else if (target.id === 'mission-landing') {
          currentMission = 'landing';
          missionBadgeEl.textContent = 'Landing';
        }
        resetFlight();
      });
    });

    // Sky Atmosphere Switcher
    const skyBtns = document.querySelectorAll('.sky-btn');
    skyBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        skyBtns.forEach(b => b.className = 'sky-btn border border-border bg-background text-muted p-1.5 rounded-md transition-all cursor-pointer text-center');
        target.className = 'sky-btn border border-primary bg-primary/10 text-primary p-1.5 rounded-md font-semibold transition-all cursor-pointer text-center';
        skyTheme = target.dataset.time || 'day';
      });
    });

    // Start Loop
    mainLoop();
  </script>
</Layout>
