---
// Slideshow page does not use the standard layout because it requires an isolated full-screen wrapper
import '../../styles/global.css';
import { Presentation } from '@lucide/astro';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agent presentation - The Architecture of Agent-Led Software</title>
    <meta name="description" content="An interactive full-screen slideshow detailing the mechanics of out-of-band agent software development." />
    <!-- Inline script to force dark mode -->
    <script is:inline>
      document.documentElement.setAttribute('data-theme', 'dark');
    </script>
  </head>
  <body class="bg-[#020205] text-[#f3f4f6] min-h-screen overflow-hidden flex flex-col font-sans select-none antialiased">

    <!-- Glowing Background blobs for premium presentation look -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full bg-primary/10 blur-[120px] -z-10"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-96 h-96 rounded-full bg-purple-500/10 blur-[120px] -z-10"></div>

    <!-- Top Navigation Banner -->
    <header class="p-6 md:px-12 flex items-center justify-between border-b border-white/5 bg-[#020205]/40 backdrop-blur-md z-10">
      <div class="flex items-center gap-3">
        <Presentation class="w-5 h-5 text-primary shrink-0" />
        <span class="font-mono text-sm uppercase tracking-widest text-[#9ca3af]">Bletchley Presenter</span>
      </div>
      <div class="flex items-center gap-6 font-mono text-sm">
        <span id="slide-counter" class="text-muted font-bold">Slide 1 of 6</span>
        <a 
          href="/project-bletchley/" 
          class="border border-white/10 hover:border-primary hover:text-primary px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5 cursor-pointer bg-white/5"
        >
          Exit ✕
        </a>
      </div>
    </header>

    <!-- Slides Container -->
    <main class="flex-grow flex items-center justify-center p-6 md:p-12 relative overflow-hidden">
      
      <!-- Slide 1: Title -->
      <div class="slide-element absolute opacity-100 scale-100 transition-all duration-500 flex flex-col items-center text-center max-w-2xl space-y-6" data-index="0">
        <span class="font-mono text-xs text-primary uppercase tracking-widest bg-primary/10 px-3 py-1 rounded-full border border-primary/20">Presentation Node</span>
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight bg-gradient-to-r from-white via-indigo-200 to-purple-400 bg-clip-text text-transparent">
          The Architecture of Agent-Led Software
        </h1>
        <p class="text-base sm:text-lg text-[#9ca3af] leading-relaxed">
          How codebases are scaffolded, refactored, and maintained out-of-band by autonomous AI agents.
        </p>
        <div class="pt-6 font-mono text-sm text-[#9ca3af] flex gap-4 items-center justify-center">
          <span>➔ Use Left/Right keys or Swipe</span>
        </div>
      </div>

      <!-- Slide 2: The Agent Loop -->
      <div class="slide-element absolute opacity-0 scale-95 pointer-events-none transition-all duration-500 max-w-3xl space-y-6" data-index="1">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight bg-gradient-to-r from-white to-indigo-300 bg-clip-text text-transparent">
          The Human-Agent Loop
        </h2>
        <p class="text-sm sm:text-base text-[#9ca3af] leading-relaxed">
          Traditional engineering requires manual file writing, compiler debugging, and tooling setup. In an agent-first paradigm, the loop is refactored into high-level declarative planning:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2 font-mono text-xs">
          <div class="border border-white/5 bg-white/5 p-4 rounded-xl space-y-2">
            <span class="text-primary font-bold">🧑‍💻 The Architect (Human)</span>
            <p class="text-muted text-xs leading-relaxed">
              Provides visual direction, audits feature updates, sets version release criteria, and manages system priorities.
            </p>
          </div>
          <div class="border border-white/5 bg-white/5 p-4 rounded-xl space-y-2">
            <span class="text-purple-400 font-bold">🤖 The Builder (Agent)</span>
            <p class="text-muted text-xs leading-relaxed">
              Researches API endpoints, configures bundle tools, handles cross-origin proxy solutions, and manages git branches.
            </p>
          </div>
        </div>
      </div>

      <!-- Slide 3: CI/CD Deployment -->
      <div class="slide-element absolute opacity-0 scale-95 pointer-events-none transition-all duration-500 max-w-3xl space-y-6" data-index="2">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight bg-gradient-to-r from-white to-indigo-300 bg-clip-text text-transparent">
          Static Compilation & Deployments
        </h2>
        <p class="text-sm sm:text-base text-[#9ca3af] leading-relaxed">
          Maintaining an agent-first workspace requires robust build automation. Bletchley implements a modern compile pipeline:
        </p>
        <div class="border border-white/5 bg-white/5 p-5 rounded-xl space-y-3 font-mono text-xs">
          <div class="flex items-center gap-2">
            <span class="text-emerald-500">✔</span>
            <span>Astro v6 compiles pages into highly optimized, zero-JS-by-default static HTML files.</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-emerald-500">✔</span>
            <span>GitHub Actions triggers on every main commit, deploying assets to GitHub Pages.</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-emerald-500">✔</span>
            <span>Runner configurations are locked to Node.js v22 to ensure long-term compatibility.</span>
          </div>
        </div>
      </div>

      <!-- Slide 4: Variables & Typography -->
      <div class="slide-element absolute opacity-0 scale-95 pointer-events-none transition-all duration-500 max-w-3xl space-y-6" data-index="3">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight bg-gradient-to-r from-white to-indigo-300 bg-clip-text text-transparent">
          Variable Typography & CSS Tokens
        </h2>
        <p class="text-sm sm:text-base text-[#9ca3af] leading-relaxed">
          Aesthetically, Bletchley uses modern variable font settings for precise layout scaling:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2 font-mono text-xs text-muted">
          <div class="space-y-2">
            <span class="text-foreground font-bold">Vercel Geist Font Face</span>
            <p class="leading-relaxed text-[#9ca3af] text-xs">
              Loaded directly from Vercel's official package using relative CSS @font-face rules, allowing real-time 'wght' variations without requesting separate weight assets.
            </p>
          </div>
          <div class="space-y-2">
            <span class="text-foreground font-bold">Tailwind CSS v4 variables</span>
            <p class="leading-relaxed text-[#9ca3af] text-xs">
              Theme tokens (backgrounds, surfaces, borders, and accents) are mapped directly to reactive CSS custom properties for instant light/dark mode transitions.
            </p>
          </div>
        </div>
      </div>

      <!-- Slide 5: Solving CORS limits -->
      <div class="slide-element absolute opacity-0 scale-95 pointer-events-none transition-all duration-500 max-w-3xl space-y-6" data-index="4">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight bg-gradient-to-r from-white to-indigo-300 bg-clip-text text-transparent">
          CORS & Secure Client-Side Fetching
        </h2>
        <p class="text-sm sm:text-base text-[#9ca3af] leading-relaxed">
          Static pages served on GitHub Pages cannot run server-side route proxies. To access public endpoints (NHL schedule API, ESPN soccer standings) without cross-origin blocks:
        </p>
        <div class="border border-white/5 bg-white/5 p-4 rounded-xl font-mono text-xs text-primary space-y-2">
          <span>// Prepend CORS Proxy Prefix (using AllOrigins raw)</span>
          <pre class="text-[#f3f4f6] overflow-x-auto whitespace-pre-wrap">const response = await fetch("https://api.allorigins.win/raw?url=" + encodeURIComponent(apiUrl));</pre>
          <p class="text-muted text-xs leading-relaxed">
            This secures browser fetching directly in the client without needing a dedicated runtime backend.
          </p>
        </div>
      </div>

      <!-- Slide 6: Conclusion -->
      <div class="slide-element absolute opacity-0 scale-95 pointer-events-none transition-all duration-500 flex flex-col items-center text-center max-w-xl space-y-6" data-index="5">
        <span class="text-2xl">🚀</span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight bg-gradient-to-r from-white to-indigo-300 bg-clip-text text-transparent">
          The Future Sandbox
        </h2>
        <p class="text-sm sm:text-base text-[#9ca3af] leading-relaxed">
          Project Bletchley establishes a robust blueprint. The pages/labs/ architecture is now clean and fully automated, ready to host future presentation slides, visual calculators, and neural experiments.
        </p>
        <a 
          href="/project-bletchley/" 
          class="bg-primary text-white hover:bg-primary-hover text-sm font-mono px-5 py-2.5 rounded-lg transition-colors cursor-pointer shadow-md inline-block font-semibold"
        >
          Return to Hub Dashboard
        </a>
      </div>

    </main>

    <!-- Footer Controls -->
    <footer class="p-6 md:px-12 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 bg-[#020205]/40 backdrop-blur-md z-10">
      <!-- Progress Bar Indicator -->
      <div class="w-full sm:max-w-xs h-1 bg-white/10 rounded-full overflow-hidden">
        <div id="slide-progress" class="h-full bg-primary w-1/6 transition-all duration-300"></div>
      </div>

      <!-- Navigation buttons -->
      <div class="flex items-center gap-3">
        <button 
          id="prev-btn" 
          class="border border-white/10 hover:border-primary hover:text-primary font-mono text-sm px-4 py-2 rounded-md transition-colors cursor-pointer bg-white/5"
        >
          ◀ Prev
        </button>
        <button 
          id="next-btn" 
          class="border border-white/10 hover:border-primary hover:text-primary font-mono text-sm px-4 py-2 rounded-md transition-colors cursor-pointer bg-white/5"
        >
          Next ▶
        </button>
      </div>
    </footer>

    <!-- Interactive script controlling slide transitions, swipe gestures and arrow keys -->
    <script>
      let currentSlide = 0;
      const slides = document.querySelectorAll('.slide-element');
      const counter = document.getElementById('slide-counter');
      const progress = document.getElementById('slide-progress');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');

      const totalSlides = slides.length;

      function updateSlides() {
        slides.forEach((slide, idx) => {
          if (idx === currentSlide) {
            slide.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
            slide.classList.add('opacity-100', 'scale-100');
          } else {
            slide.classList.remove('opacity-100', 'scale-100');
            slide.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
          }
        });

        // Update indicators
        if (counter) {
          counter.textContent = `Slide ${currentSlide + 1} of ${totalSlides}`;
        }
        if (progress) {
          progress.style.width = `${((currentSlide + 1) / totalSlides) * 100}%`;
        }
      }

      function goNext() {
        if (currentSlide < totalSlides - 1) {
          currentSlide++;
          updateSlides();
        }
      }

      function goPrev() {
        if (currentSlide > 0) {
          currentSlide--;
          updateSlides();
        }
      }

      // Event listeners
      if (nextBtn) nextBtn.addEventListener('click', goNext);
      if (prevBtn) prevBtn.addEventListener('click', goPrev);

      // Keyboard support
      window.addEventListener('keydown', e => {
        if (e.key === 'ArrowRight' || e.key === ' ') {
          goNext();
        } else if (e.key === 'ArrowLeft') {
          goPrev();
        } else if (e.key === 'Escape') {
          window.location.href = '/project-bletchley/';
        }
      });

      // Swipe Gestures for Mobile
      let touchStartX = 0;
      let touchEndX = 0;

      window.addEventListener('touchstart', e => {
        touchStartX = e.changedTouches[0].screenX;
      });

      window.addEventListener('touchend', e => {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe();
      });

      function handleSwipe() {
        const deltaX = touchEndX - touchStartX;
        if (deltaX > 50) {
          // Swiped Right -> go Prev
          goPrev();
        } else if (deltaX < -50) {
          // Swiped Left -> go Next
          goNext();
        }
      }

      // Init
      updateSlides();
    </script>
  </body>
</html>
