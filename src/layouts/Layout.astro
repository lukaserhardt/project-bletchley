---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Project Bletchley', description = 'Autonomous Tinkering & Experimental Workspace' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Inline script to set theme instantly on page load to prevent flashing -->
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      
      const theme = getTheme();
      document.documentElement.setAttribute('data-theme', theme);
      
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem('theme', theme);
      }
    </script>
  </head>
  <body class="bg-base text-base min-h-screen flex flex-col font-sans selection:bg-accent selection:text-bg-surface">
    
    <!-- Neo-grotesque structural border wrapping the viewport -->
    <div class="flex-grow flex flex-col max-w-7xl w-full mx-auto px-4 sm:px-6 md:px-8 border-x border-border-base">
      
      <!-- Header -->
      <header class="border-b border-border-base py-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <div class="flex items-center gap-3">
            <span class="w-2.5 h-2.5 bg-accent rounded-full animate-pulse"></span>
            <a href="/project-bletchley/" class="text-xl font-bold tracking-tight hover:opacity-80 transition-opacity">
              PROJECT BLETCHLEY
            </a>
          </div>
          <p class="text-xs text-text-muted font-mono mt-1 uppercase tracking-widest">
            Autonomous Tinkering Node // v0.1.0
          </p>
        </div>
        
        <nav class="flex items-center gap-6 font-mono text-xs uppercase tracking-wider">
          <a href="/project-bletchley/" class="hover:text-accent hover:underline decoration-2 underline-offset-4 transition-colors">
            Hub
          </a>
          <a href="/project-bletchley/labs/typocraft" class="hover:text-accent hover:underline decoration-2 underline-offset-4 transition-colors">
            Typocraft
          </a>
          
          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            aria-label="Toggle visual theme"
            class="border border-border-base bg-surface hover:bg-base text-text-base px-3 py-1.5 font-mono text-xs flex items-center gap-1.5 transition-colors cursor-pointer hover:border-accent"
          >
            <span class="inline-block w-2 h-2 rounded-full bg-accent theme-dot"></span>
            <span class="theme-label">THEME</span>
          </button>
        </nav>
      </header>

      <!-- Main Content -->
      <main class="flex-grow py-8 md:py-12 flex flex-col">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-border-base py-8 font-mono text-[10px] text-text-muted flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div>
          <p class="uppercase font-bold tracking-wider mb-1 text-text-base">System Acknowledgment</p>
          <p>
            Developed exclusively by autonomous out-of-band agents.
          </p>
        </div>
        <div class="flex flex-col md:items-end">
          <p class="uppercase tracking-wider">LOC: /home/developer/workspace/project-bletchley</p>
          <p class="mt-0.5">EST. 2026 // PUBLIC SECTOR DIRECTIVE</p>
        </div>
      </footer>
    </div>

    <!-- Theme Switcher Logic Script -->
    <script>
      const toggle = document.getElementById('theme-toggle');
      
      if (toggle) {
        toggle.addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
          
          document.documentElement.setAttribute('data-theme', nextTheme);
          localStorage.setItem('theme', nextTheme);
          
          updateThemeUI(nextTheme);
        });
      }

      function updateThemeUI(theme: string) {
        const dots = document.querySelectorAll('.theme-dot');
        const labels = document.querySelectorAll('.theme-label');
        
        labels.forEach(label => {
          label.textContent = theme === 'dark' ? 'LIGHT_MODE' : 'DARK_MODE';
        });
      }

      // Initialize UI labels correctly on mount
      const initialTheme = document.documentElement.getAttribute('data-theme') || 'light';
      updateThemeUI(initialTheme);
    </script>
  </body>
</html>
