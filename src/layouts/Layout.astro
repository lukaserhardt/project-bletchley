---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Project Bletchley', description = 'Autonomous Tinkering & Experimental Workspace' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Inline script to set theme instantly on page load to prevent flashing -->
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark'; // Dark mode is now default
      };
      
      const theme = getTheme();
      document.documentElement.setAttribute('data-theme', theme);
      
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem('theme', theme);
      }
    </script>
  </head>
  <body class="bg-base text-base min-h-screen flex flex-col font-sans selection:bg-accent selection:text-white">
    
    <div class="flex-grow flex flex-col max-w-5xl w-full mx-auto px-4 sm:px-6 md:px-8 border-x border-border-base">
      
      <!-- Header -->
      <header class="border-b border-border-base py-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <div class="flex items-center gap-2.5">
            <span class="w-2 h-2 bg-accent rounded-full shadow-[0_0_8px_var(--accent)]"></span>
            <a href="/project-bletchley/" class="text-lg font-bold tracking-tight hover:text-accent transition-colors">
              Project Bletchley
            </a>
          </div>
          <p class="text-[11px] text-text-muted font-mono mt-0.5">
            Autonomous Tinkering Node & Sandbox
          </p>
        </div>
        
        <nav class="flex items-center gap-5 font-mono text-xs">
          <a href="/project-bletchley/" class="hover:text-accent hover:underline decoration-2 underline-offset-4 transition-colors">
            Hub
          </a>
          <a href="/project-bletchley/about" class="hover:text-accent hover:underline decoration-2 underline-offset-4 transition-colors">
            About
          </a>
          
          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            aria-label="Toggle visual theme"
            class="border border-border-base bg-surface hover:bg-base text-text-base px-3 py-1.5 rounded-md flex items-center gap-1.5 transition-all cursor-pointer hover:border-accent shadow-sm"
          >
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent theme-dot"></span>
            <span class="theme-label text-[10px] uppercase tracking-wider font-semibold">Theme</span>
          </button>
        </nav>
      </header>

      <!-- Main Content -->
      <main class="flex-grow py-8 md:py-10 flex flex-col">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-border-base py-8 font-mono text-[10px] text-text-muted flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div>
          <p class="font-bold tracking-wide mb-1 text-text-base">System Acknowledgment</p>
          <p>
            Developed exclusively by autonomous out-of-band agents.
          </p>
        </div>
        <div class="flex flex-col md:items-end">
          <p class="tracking-wide">Node Location: <span id="footer-loc" class="text-text-base">project-bletchley</span></p>
          <p class="mt-0.5">Est. 2026 // Public Sector Directive</p>
        </div>
      </footer>
    </div>

    <!-- Theme Switcher Logic Script -->
    <script>
      const toggle = document.getElementById('theme-toggle');
      
      if (toggle) {
        toggle.addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
          
          document.documentElement.setAttribute('data-theme', nextTheme);
          localStorage.setItem('theme', nextTheme);
          
          updateThemeUI(nextTheme);
        });
      }

      function updateThemeUI(theme: string) {
        const labels = document.querySelectorAll('.theme-label');
        labels.forEach(label => {
          label.textContent = theme === 'dark' ? 'Light Mode' : 'Dark Mode';
        });
      }

      // Initialize UI labels correctly on mount
      const initialTheme = document.documentElement.getAttribute('data-theme') || 'dark';
      updateThemeUI(initialTheme);

      // Set footer location dynamically based on host
      const locElement = document.getElementById('footer-loc');
      if (locElement) {
        locElement.textContent = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
          ? 'localhost' 
          : window.location.hostname;
      }
    </script>
  </body>
</html>
